# Sentry — error tracking (populate before production traffic)
SENTRY_DSN=
SENTRY_PROJECT=
SENTRY_ORG=
SENTRY_AUTH_TOKEN=

# Public site URL — used for canonical + OG tags
PUBLIC_SITE_URL=https://agency-breno-bar.vercel.app

# Resend — transactional email for the contact form
# Create a free account at resend.com, verify a domain (or use their sandbox until then),
# then drop the API key here. Without this set, the contact endpoint returns 503
# with a structured "service temporarily unavailable" — the form still renders
# but submission is gated.
RESEND_API_KEY=
RESEND_FROM=hello@breno-bar.vercel.app
NOTIFICATION_EMAIL=breno.ribeirobr@gmail.com
