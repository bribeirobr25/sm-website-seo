---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PAGE_STRINGS } from '@/lib/page-strings';
import { PORTFOLIO } from '@/lib/portfolio';
import { LOCALE_PREFIX, type Locale } from '@/lib/site';

export async function getStaticPaths() {
  return [
    { params: { locale: 'de' }, props: { locale: 'de' as const } },
    { params: { locale: 'pt-br' }, props: { locale: 'pt-br' as const } },
  ];
}

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const p = PAGE_STRINGS[locale].portfolio;
const prefix = LOCALE_PREFIX[locale];
---

<BaseLayout title={p.title} description={p.description} locale={locale} localePath="/portfolio">
  <Header locale={locale} localePath="/portfolio" />
  <main id="main">
    <section class="bg-hero-gradient">
      <div class="container-page py-24 sm:py-32 max-w-3xl">
        <p class="text-xs tracking-[0.18em] uppercase text-accent-deep font-medium mb-6">{p.heroEyebrow}</p>
        <h1 class="font-display text-[clamp(2.5rem,6vw,5.5rem)] font-semibold text-text leading-[1.04] tracking-[-0.03em]">{p.heroTitle}</h1>
        <p class="mt-6 text-lg text-text-muted leading-[1.5]">{p.heroSubtitle}</p>
      </div>
    </section>

    <section class="section bg-bg">
      <div class="container-page">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {PORTFOLIO.map((entry, i) => (
            <a
              href={`${prefix}/portfolio/${entry.slug}`}
              class="group reveal-rise block rounded-[22px] overflow-hidden bg-surface-elev border border-border hover:border-text/30 transition-colors"
              style={`animation-delay:${i * 40}ms`}
            >
              <div class="aspect-[16/10] overflow-hidden bg-surface">
                <img src={entry.imageSrc} alt={entry.imageAlt[locale]} loading={i < 3 ? 'eager' : 'lazy'} decoding="async" width="1600" height="1000" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-[var(--motion-warm)]" />
              </div>
              <div class="p-6">
                <p class="text-[11px] tracking-[0.12em] uppercase text-text-subtle font-medium">{entry.vertical}</p>
                <p class="mt-2 font-display text-xl font-semibold text-text tracking-[-0.01em]">{entry.name}</p>
                <p class="mt-2 text-sm text-text-muted line-clamp-2">{entry.shortDescription[locale]}</p>
                <p class="mt-4 text-xs text-text-subtle tabular">{entry.stackBadge}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
