---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PAGE_STRINGS } from '@/lib/page-strings';
import { type Locale, SITE } from '@/lib/site';

export async function getStaticPaths() {
  return [
    { params: { locale: 'de' }, props: { locale: 'de' as const } },
    { params: { locale: 'pt-br' }, props: { locale: 'pt-br' as const } },
  ];
}

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const p = PAGE_STRINGS[locale].privacy;

const locationLabel = locale === 'de' ? 'Standort' : 'Localização';
const processorsList = SITE.legal.processors
  .map((proc) => `• ${proc.name} — ${proc.purpose} (${locationLabel}: ${proc.location})`)
  .join('\n');

function resolve(body: string): string {
  const phoneLineEn = locale === 'de' ? '\nTelefon: ' : '\nTelefone: ';
  return body
    .replace(
      /\n?Telefon:\s*\{\{CONTROLLER_PHONE\}\}/g,
      SITE.legal.dataControllerPhone ? `${phoneLineEn}${SITE.legal.dataControllerPhone}` : '',
    )
    .replace(
      /\n?Telefone:\s*\{\{CONTROLLER_PHONE\}\}/g,
      SITE.legal.dataControllerPhone ? `${phoneLineEn}${SITE.legal.dataControllerPhone}` : '',
    )
    .replace(/\{\{LEGAL_ENTITY\}\}/g, SITE.legal.legalEntity)
    .replace(/\{\{CONTROLLER_EMAIL\}\}/g, SITE.legal.dataControllerEmail)
    .replace(/\{\{CONTROLLER_PHONE\}\}/g, SITE.legal.dataControllerPhone ?? '')
    .replace(/\{\{PROCESSORS_LIST\}\}/g, processorsList);
}
---

<BaseLayout title={p.title} description={p.description} locale={locale} localePath="/privacy">
  <Header locale={locale} localePath="/privacy" />
  <main id="main">
    <section class="hero-dark relative overflow-hidden">
      <div class="hero-dark__veil" aria-hidden="true"></div>
      <div class="relative container-page pt-24 pb-16 sm:pt-32 sm:pb-20 max-w-3xl">
        <p class="text-xs tracking-[0.18em] uppercase text-accent font-medium mb-6">{locale === 'de' ? 'Rechtliches' : 'Legal'}</p>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl text-white font-semibold tracking-[-0.02em]">{p.headingSuffix}</h1>
        <p class="mt-4 text-white/75">{p.lastUpdated}</p>
      </div>
    </section>

    <article class="container-page py-16 sm:py-20 max-w-3xl">
      <div class="space-y-10">
        {p.sections.map((s) => (
          <section>
            <h2 class="font-display text-xl sm:text-2xl font-semibold text-text tracking-[-0.01em]">{s.title}</h2>
            <p class="mt-3 text-text-muted leading-relaxed whitespace-pre-line">{resolve(s.body)}</p>
          </section>
        ))}
      </div>
    </article>
  </main>
  <Footer locale={locale} />
</BaseLayout>
