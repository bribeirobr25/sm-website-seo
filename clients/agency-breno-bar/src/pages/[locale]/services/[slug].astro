---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PAGE_STRINGS } from '@/lib/page-strings';
import { SERVICE_SLUGS, type ServiceSlug, getRelatedPortfolio } from '@/lib/services';
import { LOCALE_PREFIX, type Locale } from '@/lib/site';
import { heroSrcset } from '@/lib/srcset';

export async function getStaticPaths() {
  const locales: Locale[] = ['de', 'pt-br'];
  const paths: Array<{
    params: { locale: string; slug: string };
    props: { locale: Locale; slug: ServiceSlug };
  }> = [];
  for (const locale of locales) {
    for (const slug of SERVICE_SLUGS) {
      paths.push({ params: { locale, slug }, props: { locale, slug } });
    }
  }
  return paths;
}

interface Props {
  locale: Locale;
  slug: ServiceSlug;
}
const { locale, slug } = Astro.props;
const s = PAGE_STRINGS[locale].services.services[slug];
const pf = PAGE_STRINGS[locale].portfolio;
const prefix = LOCALE_PREFIX[locale];
const related = getRelatedPortfolio(slug, 3);
const bestForLabel = locale === 'de' ? 'Am besten für' : 'Melhor para';
const startProject = locale === 'de' ? 'Projekt starten' : 'Começar um projeto';
---

<BaseLayout title={s.seoTitle ?? `${s.name}, BAR Agency`} description={s.seoDescription ?? s.shortTagline} locale={locale} localePath={`/services/${slug}`}>
  <Header locale={locale} localePath={`/services/${slug}`} />
  <main id="main">
    <section class="hero-dark relative overflow-hidden">
      {s.heroImageSrc && (
        <img
          src={s.heroImageSrc}
          srcset={heroSrcset(s.heroImageSrc)}
          sizes="100vw"
          alt={s.heroImageAlt ?? ''}
          width="1920"
          height="823"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="hero-dark__img"
        />
      )}
      <div class="hero-dark__veil" aria-hidden="true"></div>
      <div class="relative container-page pt-28 pb-24 sm:pt-36 sm:pb-32 lg:pt-44 lg:pb-40 max-w-4xl">
        <p class="text-xs tracking-[0.18em] uppercase text-accent-light font-medium mb-6">{s.heroEyebrow}</p>
        <h1 class="font-display text-[clamp(2.5rem,6vw,5.5rem)] font-semibold text-white leading-[1.04] tracking-[-0.03em]">{s.heroTitle}</h1>
        <p class="mt-8 text-xl text-white/85 leading-[1.5] max-w-2xl">{s.heroBody}</p>
      </div>
    </section>

    <section class="section bg-bg">
      <div class="container-page">
        <div class="grid lg:grid-cols-3 gap-5">
          {s.bullets.map((b, i) => (
            <div class="reveal-rise rounded-[22px] border border-border bg-surface p-8 sm:p-10" style={`animation-delay:${i * 50}ms`}>
              <p class="font-display text-xl font-semibold text-text tracking-[-0.01em]">{b.title}</p>
              <p class="mt-3 text-text-muted leading-relaxed">{b.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-inverted-bg text-inverted-text">
      <div class="container-page">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          {s.secondaryImageSrc ? (
            <figure class="order-2 lg:order-1">
              <div class="aspect-[3/4] sm:aspect-[4/5] lg:aspect-[3/4] overflow-hidden rounded-[22px] bg-surface">
                <img
                  src={s.secondaryImageSrc}
                  srcset={heroSrcset(s.secondaryImageSrc)}
                  sizes="(max-width: 1024px) 100vw, 50vw"
                  alt={s.secondaryImageAlt ?? ''}
                  width="1920"
                  height="2400"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
              </div>
            </figure>
          ) : (
            <div class="hidden lg:block"></div>
          )}
          <div class="order-1 lg:order-2">
            <p class="text-xs tracking-[0.18em] uppercase text-accent-light font-medium">{s.outcomeHeading}</p>
            <h2 class="mt-4 font-display text-3xl sm:text-4xl font-semibold tracking-[-0.02em] leading-[1.1]">{bestForLabel}</h2>
            <p class="mt-6 text-inverted-text-muted leading-relaxed">{s.bestFor}</p>
            <ul class="mt-10 space-y-4 list-none p-0">
              {s.outcomeBullets.map((b) => (
                <li class="flex gap-4 text-inverted-text">
                  <span class="font-display text-accent-light text-2xl leading-none">●</span>
                  <span class="leading-relaxed">{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    {related.length > 0 && (
      <section class="section bg-surface">
        <div class="container-page">
          <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-[-0.02em] text-text mb-10">{pf.relatedCases}</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {related.map((entry) => (
              <a href={`${prefix}/portfolio/${entry.slug}`} class="group block rounded-[22px] overflow-hidden bg-surface-elev border border-border hover:border-text/30 transition-colors">
                <div class="aspect-[16/10] overflow-hidden bg-bg">
                  <img src={entry.imageSrc} alt={entry.imageAlt[locale]} loading="lazy" decoding="async" width="1600" height="1000" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-[var(--motion-warm)]" />
                </div>
                <div class="p-5">
                  <p class="text-[11px] tracking-[0.12em] uppercase text-text-muted font-medium">{entry.vertical}</p>
                  <p class="mt-2 font-display text-lg font-semibold text-text">{entry.name}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="bg-bg">
      <div class="container-page py-20 text-center">
        <a href={`${prefix}/contact`} class="inline-flex items-center justify-center px-7 py-3 min-h-[52px] rounded-full bg-text text-bg hover:bg-accent-deep transition-colors text-base font-medium">{startProject}</a>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
