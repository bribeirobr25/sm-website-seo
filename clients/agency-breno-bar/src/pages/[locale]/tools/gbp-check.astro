---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import GbpCheckTool from '@/components/sections/GbpCheckTool.astro';
import HeroAurora from '@/components/sections/HeroAurora.astro';
import ContactBar from '@/components/ui/ContactBar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { LOCALE_PREFIX, type Locale } from '@/lib/site';
import { TOOLS } from '@/lib/tools';

export async function getStaticPaths() {
  return [
    { params: { locale: 'de' }, props: { locale: 'de' as const } },
    { params: { locale: 'pt-br' }, props: { locale: 'pt-br' as const } },
  ];
}

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const prefix = LOCALE_PREFIX[locale];
const g = TOOLS[locale].gbp;
const pricingHref = `${prefix}/pricing`;
---

<BaseLayout title={g.metaTitle} description={g.metaDescription} locale={locale} localePath="/tools/gbp-check">
  <Header locale={locale} localePath="/tools/gbp-check" />
  <main id="main">
    <section class="hero-dark relative overflow-hidden">
      <div class="hero-dark__veil" aria-hidden="true"></div>
      <HeroAurora />
      <div class="relative container-page pt-24 pb-20 sm:pt-32 sm:pb-24 max-w-3xl">
        <p class="text-xs tracking-[0.18em] uppercase text-accent-light font-medium mb-6">{g.eyebrow}</p>
        <h1 class="font-display text-[clamp(2.5rem,6vw,5rem)] font-semibold text-white leading-[1.04] tracking-[-0.03em]">{g.title}</h1>
        <p class="mt-6 text-xl text-white/85 leading-[1.5]">{g.subtitle}</p>
      </div>
    </section>

    <GbpCheckTool locale={locale} />

    <section class="bg-inverted-bg text-inverted-text">
      <div class="container-page py-20 sm:py-28 text-center">
        <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-[-0.03em] leading-[1.06] max-w-2xl mx-auto">{g.ctaHeading}</h2>
        <p class="mt-5 text-lg text-inverted-text-muted leading-[1.5] max-w-xl mx-auto">{g.ctaBody}</p>
        <div class="mt-9">
          <a href={pricingHref} class="inline-flex items-center justify-center px-7 py-3 min-h-[52px] rounded-full bg-accent text-white hover:bg-accent-deep transition-colors text-base font-medium">{g.ctaButton}</a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
  <ContactBar locale={locale} />
</BaseLayout>
