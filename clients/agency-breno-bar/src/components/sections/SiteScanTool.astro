---
import type { Locale } from '@/lib/site';
/**
 * SiteScanTool (F3b), form + live results for /api/site-scan.
 * Shared by the EN + localized tool pages. Locale-driven via TOOLS[locale].scan.
 */
import { TOOLS } from '@/lib/tools';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const s = TOOLS[locale].scan;
const i18n = {
  running: s.running,
  errorBody: s.errorBody,
  resultHeading: s.resultHeading,
  disclaimer: s.disclaimer,
  labels: {
    performance: s.labelPerformance,
    seo: s.labelSeo,
    accessibility: s.labelAccessibility,
    bestPractices: s.labelBestPractices,
    security: s.labelSecurity,
    https: s.labelHttps,
  },
};
---

<section class="section bg-bg">
  <div class="container-page max-w-2xl">
    <form id="scan-form" class="flex flex-col sm:flex-row gap-3" novalidate>
      <label for="scan-url" class="sr-only">{s.urlLabel}</label>
      <input
        type="url"
        id="scan-url"
        name="url"
        required
        inputmode="url"
        placeholder={s.urlPlaceholder}
        class="flex-1 px-4 py-3 min-h-[52px] rounded-full border border-border bg-bg text-text placeholder:text-text-muted focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus:border-accent transition-colors"
      />
      <button
        type="submit"
        id="scan-submit"
        class="inline-flex items-center justify-center px-7 py-3 min-h-[52px] rounded-full bg-accent text-bg hover:bg-accent-deep transition-colors text-base font-medium disabled:opacity-60 disabled:cursor-wait"
      >
        <span id="scan-submit-label">{s.submit}</span>
      </button>
    </form>
    <p class="mt-3 text-xs text-text-muted">{s.privacyNote}</p>

    <div id="scan-status" role="status" aria-live="polite" class="mt-8"></div>

    <script type="application/json" id="scan-i18n" set:html={JSON.stringify(i18n)}></script>
  </div>
</section>

<script>
  type ScanLabels = {
    running: string;
    errorBody: string;
    resultHeading: string;
    disclaimer: string;
    labels: Record<string, string>;
  };
  type ScanResult = {
    scores?: Record<string, number | null>;
    https?: boolean;
    securityHeaders?: { present: number; total: number; missing: string[] };
    trackers?: string[];
  };

  const form = document.getElementById('scan-form') as HTMLFormElement | null;
  const input = document.getElementById('scan-url') as HTMLInputElement | null;
  const submit = document.getElementById('scan-submit') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('scan-submit-label');
  const statusEl = document.getElementById('scan-status');
  const i18nEl = document.getElementById('scan-i18n');
  const t: ScanLabels = i18nEl ? JSON.parse(i18nEl.textContent || '{}') : ({} as ScanLabels);
  const defaultLabel = submitLabel?.textContent ?? '';

  function scoreColor(v: number | null): string {
    if (v === null) return 'text-text-subtle';
    if (v >= 90) return 'text-success';
    if (v >= 50) return 'text-warning';
    return 'text-error';
  }
  function chip(label: string, v: number | null): string {
    const display = v === null ? ', ' : String(v);
    return `<div class="rounded-[18px] bg-surface border border-border p-5 text-center">
      <div class="font-display text-4xl font-semibold tabular ${scoreColor(v)}">${display}</div>
      <div class="mt-1 text-xs text-text-muted">${label}</div>
    </div>`;
  }
  function badge(ok: boolean, label: string): string {
    const tone = ok ? 'text-success' : 'text-error';
    const mark = ok ? '✓' : '✕';
    return `<span class="inline-flex items-center gap-1.5 text-sm ${tone}"><span aria-hidden="true">${mark}</span>${label}</span>`;
  }

  function render(data: ScanResult) {
    if (!statusEl) return;
    const sc: Record<string, number | null> = data.scores ?? {};
    const sh = data.securityHeaders ?? { present: 0, total: 6, missing: [] };
    const trackers: string[] = data.trackers ?? [];
    const html = `
      <h2 class="font-display text-2xl font-semibold text-text tracking-[-0.02em] mb-5">${t.resultHeading}</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        ${chip(t.labels.performance, sc.performance ?? null)}
        ${chip(t.labels.seo, sc.seo ?? null)}
        ${chip(t.labels.accessibility, sc.accessibility ?? null)}
        ${chip(t.labels.bestPractices, sc.bestPractices ?? null)}
      </div>
      <div class="mt-5 flex flex-wrap items-center gap-x-6 gap-y-2">
        ${badge(!!data.https, t.labels.https)}
        ${badge(sh.present === sh.total, `${t.labels.security}: ${sh.present}/${sh.total}`)}
      </div>
      ${trackers.length ? `<p class="mt-4 text-sm text-warning">⚠ ${trackers.join(', ')}</p>` : ''}
      <p class="mt-6 text-xs text-text-muted">${t.disclaimer}</p>
    `;
    statusEl.innerHTML = html;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!input || !submit || !statusEl) return;
    const url = input.value.trim();
    if (!url) return;
    submit.disabled = true;
    if (submitLabel) submitLabel.textContent = t.running;
    statusEl.innerHTML = `<p class="text-text-muted text-sm">${t.running}</p>`;
    try {
      const res = await fetch('/api/site-scan', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ url }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok && data.ok) {
        render(data);
      } else {
        statusEl.innerHTML = `<p class="text-error text-sm">${data.error || t.errorBody}</p>`;
      }
    } catch {
      statusEl.innerHTML = `<p class="text-error text-sm">${t.errorBody}</p>`;
    } finally {
      submit.disabled = false;
      if (submitLabel) submitLabel.textContent = defaultLabel;
    }
  });
</script>
