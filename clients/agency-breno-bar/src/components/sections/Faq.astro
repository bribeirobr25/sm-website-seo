---
/**
 * Faq (F6), accessible accordion using native <details>/<summary>.
 * Prop-driven. The FAQPage JSON-LD is emitted separately by the page via
 * BaseLayout `extraSchema` + `faqPageSchema(items)`, keep the two in sync by
 * passing the SAME items array to both.
 *
 * Native <details> = keyboard-operable + screen-reader-friendly with zero JS.
 */
import type { Faq } from '@/lib/funnel';

interface Props {
  eyebrow?: string;
  title?: string;
  items: readonly Faq[];
  /** bg variant, defaults to base bg; pass 'surface' to sit on a gray section. */
  surface?: boolean;
}
const { eyebrow, title, items, surface = false } = Astro.props;
---

<section class:list={['section', surface ? 'bg-surface' : 'bg-bg']} aria-labelledby="faq-heading">
  <div class="container-page max-w-3xl">
    {(eyebrow || title) && (
      <div class="mb-10">
        {eyebrow && <p class="text-xs tracking-[0.18em] uppercase text-accent-on-surface font-medium">{eyebrow}</p>}
        {title && <h2 id="faq-heading" class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl text-text font-semibold tracking-[-0.03em] leading-[1.06]">{title}</h2>}
      </div>
    )}
    <div class="divide-y divide-border border-y border-border">
      {items.map((it) => (
        <details class="group">
          <summary class="flex items-start justify-between gap-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden py-5 min-h-[44px] text-text font-medium text-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-sm">
            <span>{it.q}</span>
            <span class="shrink-0 mt-1 text-accent-on-surface transition-transform duration-[var(--motion-base)] group-open:rotate-45" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </span>
          </summary>
          <p class="pb-6 -mt-1 text-text-muted leading-[1.6] max-w-2xl">{it.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
