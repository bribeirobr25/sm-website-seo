---
/**
 * PromiseStrip (F5), measurable-commitment stat row.
 * Prop-driven, no hard-coded copy. Content from FUNNEL[locale].promises.
 * Light register; pairs after a dark hero in the Apple light/dark rhythm.
 */
import type { PromiseStat } from '@/lib/funnel';

interface Props {
  eyebrow: string;
  title: string;
  note?: string;
  items: readonly PromiseStat[];
}
const { eyebrow, title, note, items } = Astro.props;
---

<section class="section bg-surface" aria-labelledby="promises-heading">
  <div class="container-page">
    <div class="max-w-3xl mb-12">
      <p class="text-xs tracking-[0.18em] uppercase text-accent-deep font-medium">{eyebrow}</p>
      <h2 id="promises-heading" class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl text-text font-semibold tracking-[-0.03em] leading-[1.06]">{title}</h2>
    </div>
    <dl class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8">
      {items.map((it, i) => (
        <div class="reveal-rise rounded-[22px] bg-surface-elev border border-border p-6 sm:p-8" style={`animation-delay:${i * 50}ms`}>
          <dt class="font-display text-4xl sm:text-5xl text-text font-semibold tabular tracking-[-0.04em]">{it.stat}</dt>
          <dd class="mt-3 text-sm text-text-muted leading-relaxed">{it.label}</dd>
        </div>
      ))}
    </dl>
    {note && <p class="mt-6 text-xs text-text-muted">{note}</p>}
  </div>
</section>
