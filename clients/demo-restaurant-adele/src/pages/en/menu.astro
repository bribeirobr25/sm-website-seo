---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import LabelCountHeader from '@/components/sections/LabelCountHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

const locale = 'en' as const;
const t = SITE.i18n[locale];
---

<BaseLayout
  title={`Menu — ${SITE.name}`}
  description="Five courses, one season. Modern European tasting menu with ingredients from Brandenburg, Saxony-Anhalt, and one French bottle per card."
  locale={locale}
  alternateLocaleUrl="/karte"
>
  <Header locale={locale} />
  <main id="main">
    <section class="bg-bg">
      <div class="container-page py-16 sm:py-24">
        <div class="max-w-2xl">
          <p class="text-xs uppercase tracking-[0.2em] text-accent-secondary-deep font-semibold">{t.nav.menu}</p>
          <h1 class="mt-2 font-display text-4xl sm:text-5xl text-text">This week's menu.</h1>
          <p class="mt-6 text-lg text-text-muted leading-relaxed">
            Written Sunday, cooked first on Wednesday, in service for seven days. A vegetarian variation runs in parallel — please note on booking.
          </p>
        </div>
      </div>
    </section>

    {(['tasting', 'wine'] as const).map((key, idx) => {
      const section = SITE.menu[key];
      const bg = idx % 2 === 0 ? 'bg-surface-elev' : 'bg-bg';
      return (
        <section class={bg}>
          <div class="container-page py-16">
            <LabelCountHeader
              label={section.label[locale]}
              count={section.count}
              countLabel={`${section.count} courses`}
            />
            <p class="mt-4 max-w-2xl text-text-muted leading-relaxed">
              {section.intro[locale]}
            </p>
            <ol class="mt-10 space-y-6 list-none">
              {section.items.map((item: { de: { name: string; desc: string }; en: { name: string; desc: string } }) => (
                <li class="border-b border-border pb-5 pl-0">
                  <h3 class="font-display text-2xl text-text">{item[locale].name}</h3>
                  <p class="mt-2 text-text-muted leading-relaxed">{item[locale].desc}</p>
                </li>
              ))}
            </ol>
          </div>
        </section>
      );
    })}

    <section class="bg-surface-elev">
      <div class="container-page py-16">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div class="space-y-4">
            <LabelCountHeader label="PRICES" count={0} countLabel="per person" />
            <p class="text-text-muted leading-relaxed">
              Tasting menu, 5 courses: <span class="text-text font-medium">€ 145</span>
              <br />
              Wine pairing, 5 glasses: <span class="text-text font-medium">€ 95</span>
              <br />
              Non-alcoholic pairing: <span class="text-text font-medium">€ 55</span>
            </p>
            <p class="text-sm text-text-muted italic leading-relaxed">
              Prices incl. VAT. Tip not included and not expected — we pay our team a union-rate-plus wage.
            </p>
          </div>

          <div class="space-y-4">
            <LabelCountHeader label="RESERVATIONS" count={0} countLabel="22 seats per seating" />
            <p class="text-text-muted leading-relaxed">
              One seating per evening, Tue–Sat at 18:30. We recommend booking six to fourteen days ahead. For allergies or special occasions please call directly.
            </p>
            <div class="flex flex-wrap gap-3 pt-2">
              <a href="/en/reserve" class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-md bg-text text-bg hover:bg-accent-deep hover:text-bg transition-colors">
                Reserve a table.
              </a>
              <a href={`tel:${SITE.phone}`} class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-md bg-surface text-text border border-border hover:bg-surface-elev transition-colors tabular">
                {SITE.phoneDisplay}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
