---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import LabelCountHeader from '@/components/sections/LabelCountHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

const locale = 'de' as const;
const t = SITE.i18n[locale];
---

<BaseLayout
  title={`Karte — ${SITE.name}`}
  description="Fünf Gänge, eine Saison. Modernes europäisches Menü mit Zutaten aus Brandenburg, Sachsen-Anhalt und einer Flasche Frankreich pro Karte."
  locale={locale}
  alternateLocaleUrl="/en/menu"
>
  <Header locale={locale} />
  <main id="main">
    <section class="bg-bg">
      <div class="container-page py-16 sm:py-24">
        <div class="max-w-2xl">
          <p class="text-xs uppercase tracking-[0.2em] text-accent-secondary-deep font-semibold">{t.nav.menu}</p>
          <h1 class="mt-2 font-display text-4xl sm:text-5xl text-text">Die Karte dieser Woche.</h1>
          <p class="mt-6 text-lg text-text-muted leading-relaxed">
            Geschrieben am Sonntag, zum ersten Mal gekocht am Mittwoch, sieben Tage lang gültig. Eine vegetarische Variante steht parallel zur Verfügung — bitte bei der Reservierung notieren.
          </p>
        </div>
      </div>
    </section>

    {(['tasting', 'wine'] as const).map((key, idx) => {
      const section = SITE.menu[key];
      const bg = idx % 2 === 0 ? 'bg-surface-elev' : 'bg-bg';
      return (
        <section class={bg}>
          <div class="container-page py-16">
            <LabelCountHeader
              label={section.label[locale]}
              count={section.count}
              countLabel={`${section.count} ${locale === 'de' ? 'Gänge' : 'pours'}`}
            />
            <p class="mt-4 max-w-2xl text-text-muted leading-relaxed">
              {section.intro[locale]}
            </p>
            <ol class="mt-10 space-y-6 list-none">
              {section.items.map((item: { de: { name: string; desc: string }; en: { name: string; desc: string } }) => (
                <li class="border-b border-border pb-5 pl-0">
                  <h3 class="font-display text-2xl text-text">{item[locale].name}</h3>
                  <p class="mt-2 text-text-muted leading-relaxed">{item[locale].desc}</p>
                </li>
              ))}
            </ol>
          </div>
        </section>
      );
    })}

    <section class="bg-surface-elev">
      <div class="container-page py-16">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div class="space-y-4">
            <LabelCountHeader label="PREISE" count={0} countLabel="pro Person" />
            <p class="text-text-muted leading-relaxed">
              Tasting-Menü 5 Gänge: <span class="text-text font-medium">€ 145</span>
              <br />
              Weinbegleitung 5 Gläser: <span class="text-text font-medium">€ 95</span>
              <br />
              Alkoholfreie Begleitung: <span class="text-text font-medium">€ 55</span>
            </p>
            <p class="text-sm text-text-muted italic leading-relaxed">
              Preise inkl. MwSt. Trinkgeld nicht enthalten und nicht erwartet — wir zahlen unserem Team Tariflohn plus.
            </p>
          </div>

          <div class="space-y-4">
            <LabelCountHeader label="RESERVIERUNG" count={0} countLabel="22 Plätze pro Sitzung" />
            <p class="text-text-muted leading-relaxed">
              Eine Sitzung pro Abend, Di–Sa um 18:30. Wir empfehlen sechs bis vierzehn Tage Vorlauf. Für Allergien oder Anlässe bitte direkt anrufen.
            </p>
            <div class="flex flex-wrap gap-3 pt-2">
              <a href="/reservieren" class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-md bg-accent text-bg hover:bg-accent-deep transition-colors">
                Tisch reservieren.
              </a>
              <a href={`tel:${SITE.phone}`} class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-md bg-surface text-text border border-border hover:bg-surface-elev transition-colors tabular">
                {SITE.phoneDisplay}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
