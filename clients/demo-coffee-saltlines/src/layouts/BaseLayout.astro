---
import '@/styles/global.css';
import DemoBanner from '@/components/layout/DemoBanner.astro';
import CookieBanner from '@/components/ui/CookieBanner.astro';
import { restaurantSchema } from '@/lib/seo/schema';
import { type Locale, SITE } from '@/lib/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  locale?: Locale;
  alternateLocaleUrl?: string;
}

const {
  title = SITE.name,
  description,
  ogImage = `${SITE.url}/img/hero-surf-coffee.jpg`,
  // Demo: ALWAYS noindex. Per CLAUDE.md "Demo discipline" — never flip.
  noindex = true,
  locale = 'de',
  alternateLocaleUrl,
} = Astro.props;

const t = SITE.i18n[locale];
const localizedDescription = description ?? t.tagline;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const schema = JSON.stringify(restaurantSchema());
const htmlLang = locale === 'de' ? 'de-DE' : 'en-US';
const ogLocale = htmlLang.replace('-', '_');
const otherLocale: Locale = locale === 'de' ? 'en' : 'de';
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title === SITE.name ? title : `${title} · ${SITE.name}`}</title>
    <meta name="description" content={localizedDescription} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonical} />
    {alternateLocaleUrl && (
      <link rel="alternate" hreflang={otherLocale === 'en' ? 'en' : 'de'} href={alternateLocaleUrl} />
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={localizedDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE.name} — ${t.tagline}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={localizedDescription} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline type="application/ld+json" set:html={schema} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:bg-accent focus:text-bg focus:px-4 focus:py-2 focus:z-50"
    >
      {locale === 'de' ? 'Zum Inhalt springen' : 'Skip to content'}
    </a>

    <DemoBanner locale={locale} />

    <slot />

    <CookieBanner locale={locale} />
  </body>
</html>

<style is:global>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
