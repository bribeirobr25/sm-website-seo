---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
const locale = 'en' as const;
---

<BaseLayout
  title="Page not found"
  description="404 — We don't have that on the menu."
  locale={locale}
  noindex={true}
>
  <Header locale={locale} />
  <main id="main">
    <section class="bg-bg">
      <div class="container-page py-24 sm:py-32 max-w-xl mx-auto text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-text-muted">404</p>
        <h1 class="mt-4 font-display text-4xl sm:text-5xl text-text">
          We don't have that on the menu.
        </h1>
        <p class="mt-6 text-text-muted leading-relaxed">
          Maybe you meant the gelato menu? Or a visit? Here are a few ways back:
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/en/" class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-md bg-text text-bg hover:bg-accent-deep hover:text-bg transition-colors">
            Back to home.
          </a>
          <a href="/en/gelato" class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-md bg-surface text-text border border-border hover:bg-surface-elev transition-colors">
            See the menu.
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
