---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

const locale = 'en' as const;
const mapsUrl = `https://maps.google.com/?q=${encodeURIComponent(`${SITE.address.street}, ${SITE.address.postalCode} ${SITE.address.city}`)}`;
const dayLabelsEN = {
  Mon: 'Mon',
  Tue: 'Tue',
  Wed: 'Wed',
  Thu: 'Thu',
  Fri: 'Fri',
  Sat: 'Sat',
  Sun: 'Sun',
};
---

<BaseLayout
  title={`Visit — ${SITE.name}`}
  description="Holzmarktstraße 25, 10243 Berlin Friedrichshain. Mon–Thu 07–20, Fri/Sat 07–22, Sun 08–20."
  locale={locale}
  alternateLocaleUrl="/besuchen"
>
  <Header locale={locale} />
  <main id="main">
    <section class="bg-bg">
      <div class="container-page py-16 sm:py-24">
        <p class="text-xs uppercase tracking-[0.2em] text-text-muted">Visit</p>
        <h1 class="mt-2 font-display text-4xl sm:text-5xl text-text">Come by.</h1>
        <p class="mt-6 text-lg text-text-muted leading-relaxed max-w-2xl">
          Holzmarktstraße 25 — right on the Spree riverbank in Friedrichshain. Two minutes to Strandbar, five to Ostbahnhof.
        </p>
      </div>
    </section>

    <section class="bg-surface-elev">
      <div class="container-page py-16">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
          <div class="bg-surface rounded-lg p-8 border border-border space-y-2">
            <p class="font-display text-2xl text-text">{SITE.name}</p>
            <p class="text-text-muted">{SITE.address.street}</p>
            <p class="text-text-muted">{SITE.address.postalCode} {SITE.address.city} — {SITE.address.neighborhood}</p>
            <div class="pt-4 flex flex-wrap gap-3">
              <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-5 py-3 min-h-[44px] text-base font-medium rounded-md bg-text text-bg hover:bg-accent-deep hover:text-bg transition-colors">
                Open in Google Maps.
              </a>
            </div>
          </div>

          <div class="bg-surface rounded-lg p-8 border border-border space-y-5">
            <p class="text-xs uppercase tracking-[0.2em] text-text-muted">Opening hours</p>
            <div>
              <p class="font-display text-xl text-text">{SITE.hours.summer.label.en}</p>
              <dl class="mt-2 grid grid-cols-[auto_1fr] gap-x-6 gap-y-1 text-base tabular max-w-xs">
                {SITE.hours.summer.days.map((h) => (
                  <>
                    <dt class="text-text-muted">{dayLabelsEN[h.day as keyof typeof dayLabelsEN]}</dt>
                    <dd class="text-text">{h.open && h.close ? `${h.open} – ${h.close}` : 'Closed'}</dd>
                  </>
                ))}
              </dl>
            </div>
            <div>
              <p class="font-display text-xl text-text">{SITE.hours.winter.label.en}</p>
              <dl class="mt-2 grid grid-cols-[auto_1fr] gap-x-6 gap-y-1 text-base tabular max-w-xs">
                {SITE.hours.winter.days.map((h) => (
                  <>
                    <dt class="text-text-muted">{dayLabelsEN[h.day as keyof typeof dayLabelsEN]}</dt>
                    <dd class="text-text">{h.open && h.close ? `${h.open} – ${h.close}` : 'Closed'}</dd>
                  </>
                ))}
              </dl>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-bg">
      <div class="container-page py-16">
        <div class="max-w-2xl space-y-6">
          <h2 class="font-display text-3xl text-text">Finding us</h2>
          <ul class="space-y-2 text-text-muted leading-relaxed">
            <li><strong class="text-text">S/U Ostbahnhof</strong> — 5 minutes on foot through the Holzmarkt.</li>
            <li><strong class="text-text">U1 Schlesisches Tor</strong> — 10 minutes via the Oberbaumbrücke.</li>
            <li><strong class="text-text">Strandbar Spree</strong> — 200 metres as the crow flies. We see it from the window.</li>
            <li><strong class="text-text">Cycling</strong> — bike rack out front, Spree cycle path right past the door.</li>
            <li><strong class="text-text">Parking</strong> — tough, like everywhere in Berlin. Transit or bike recommended.</li>
          </ul>
        </div>

        <div class="mt-12 max-w-2xl space-y-6">
          <h2 class="font-display text-3xl text-text">Contact</h2>
          <p class="text-text-muted leading-relaxed">
            Call, email, or just come in. For bean orders or catering, give us two days' notice — we do not grind ahead.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={`tel:${SITE.phone}`} class="inline-flex items-center justify-center px-5 py-3 min-h-[44px] text-base font-medium rounded-md bg-text text-bg hover:bg-accent-deep hover:text-bg transition-colors tabular">
              {SITE.phoneDisplay}
            </a>
            <a href={`mailto:${SITE.email}`} class="inline-flex items-center justify-center px-5 py-3 min-h-[44px] text-base font-medium rounded-md bg-surface text-text border border-border hover:bg-surface-elev transition-colors">
              {SITE.email}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
