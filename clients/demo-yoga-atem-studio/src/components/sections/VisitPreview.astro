---
/**
 * MarqueeCTA-style "Probestunde" footer — Atem Studio V2 (2026-05-23).
 *
 * Per `studio.md` §13 swap-in: MarqueeCTA "Probestunde buchen" scrolling
 * text — yoga conversion lever IS the free first class.
 *
 * Single horizontal scrolling marquee with "Probestunde gratis · Erste
 * Stunde geschenkt · Komm einmal vorbei" repeated. Click anywhere on the
 * marquee opens the mail link.
 */
import { type Locale, SITE } from '@/lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = SITE.i18n[locale];

const marqueeText =
  locale === 'de'
    ? '✦ Probestunde gratis ✦ Erste Stunde geschenkt ✦ Ohne Karte ✦ Ohne Vertrag ✦ Komm einmal vorbei'
    : '✦ First class free ✦ No card needed ✦ No commitment ✦ Just come once ✦ See if it fits';

// Repeat the text 6× for seamless marquee scroll
const marqueeRepeats = Array.from({ length: 6 });
---

<section class="bg-[var(--color-inverted-bg)] text-[var(--color-inverted-text)] overflow-hidden border-y border-[var(--color-inverted-surface)]" aria-labelledby="probestunde-heading">
  <a href={`mailto:${SITE.email}?subject=${encodeURIComponent(locale === 'de' ? 'Probestunde buchen' : 'Book first class')}`} class="block group">
    <div class="marquee-track flex whitespace-nowrap py-12 sm:py-16 font-display text-4xl sm:text-6xl lg:text-7xl italic">
      {marqueeRepeats.map(() => (
        <span class="px-8 text-[var(--color-inverted-text)] group-hover:text-accent transition-colors">
          {marqueeText}
        </span>
      ))}
    </div>
  </a>

  <div class="container-page pb-20 sm:pb-24 -mt-2 grid sm:grid-cols-[1fr_auto] gap-6 items-center">
    <div>
      <p id="probestunde-heading" class="text-[11px] tracking-[0.28em] uppercase text-accent font-semibold">
        {locale === 'de' ? 'Erste Stunde geschenkt' : 'First class on us'}
      </p>
      <p class="mt-3 text-lg text-[var(--color-inverted-text-muted)] leading-relaxed max-w-2xl">
        {locale === 'de'
          ? 'Schreibe uns kurz, welcher Termin passt, und wir reservieren eine Matte. Kein Vertrag, keine Karte, kein Verkaufsgespräch danach.'
          : 'Send us an email with a time that fits and we will hold a mat. No contract, no card, no sales conversation after.'}
      </p>
    </div>

    <div class="flex flex-wrap gap-3 shrink-0">
      <a
        href={`mailto:${SITE.email}`}
        class="inline-flex items-center justify-center px-6 py-3 min-h-[52px] text-base font-medium rounded-full bg-accent text-[var(--color-inverted-bg)] hover:bg-accent-deep transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        {t.cta.bookTable}
      </a>
      <a
        href={`tel:${SITE.phone}`}
        class="inline-flex items-center justify-center px-6 py-3 min-h-[52px] text-base font-medium rounded-full border border-[var(--color-inverted-text-muted)] text-[var(--color-inverted-text)] hover:border-accent hover:text-accent transition-colors tabular focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        {SITE.phoneDisplay}
      </a>
    </div>
  </div>
</section>

<style>
  .marquee-track {
    animation: marquee 60s linear infinite;
    will-change: transform;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      transform: none;
      overflow-x: auto;
    }
  }
</style>
