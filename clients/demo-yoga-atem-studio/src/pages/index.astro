---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import About from '@/components/sections/About.astro';
import FAQ from '@/components/sections/FAQ.astro';
import Hero from '@/components/sections/Hero.astro';
import MenuPreview from '@/components/sections/MenuPreview.astro';
import VisitPreview from '@/components/sections/VisitPreview.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

const locale = 'de' as const;
const t = SITE.i18n[locale];

const pricing = [
  {
    name: 'Probestunde',
    price: '€ 0',
    cadence: 'einmalig',
    highlight: true,
    body: 'Eine Klasse deiner Wahl, ohne Vertrag, ohne Karte.',
  },
  {
    name: 'Drop-in',
    price: '€ 20',
    cadence: 'pro Klasse',
    highlight: false,
    body: 'Spontan, ohne Bindung. Auch für Workshops gültig.',
  },
  {
    name: '10er Karte',
    price: '€ 180',
    cadence: '3 Monate gültig',
    highlight: false,
    body: 'Übertragbar an Freund:innen, ca. € 18 pro Klasse.',
  },
  {
    name: 'Monatskarte',
    price: '€ 95',
    cadence: 'pro Monat',
    highlight: false,
    body: 'Alle Klassen, alle Stile, monatlich kündbar.',
  },
];

const instructors = [
  { initials: 'LB', name: 'Lara Brückner', styles: 'Vinyasa · Meditation' },
  { initials: 'FH', name: 'Felix Holm', styles: 'Yin · Prenatal' },
  { initials: 'EK', name: 'Esra Kaplan', styles: 'Hatha · Restorative' },
  { initials: 'JM', name: 'Jonas Möller', styles: 'Power Vinyasa' },
];

const galleryTiles = [
  {
    image: '/img/photo/hero.webp',
    label: 'Raum I — Hauptpraxis',
    alt: 'Yogamatten auf hellem Holzboden im Hauptraum',
  },
  {
    image: '/img/photo/studio.webp',
    label: 'Raum II — Restorative',
    alt: 'Weiter Blick in den Restorative-Raum mit hohen Fenstern',
  },
  {
    image: '/img/photo/props.webp',
    label: 'Mattenkorb + Pflanzen',
    alt: 'Aufgerollte Yogamatten in einem geflochtenen Korb mit Pflanzen',
  },
  {
    image: '/img/photo/mood.webp',
    label: 'Atem + Geste',
    alt: 'Geöffnete Hände — Geste der Hingabe',
  },
];

const faqItems = [
  {
    question: 'Ich war noch nie Yoga — kann ich kommen?',
    answer:
      'Ja, ausdrücklich. Slow Flow am Samstag morgen und Hatha am Mittwoch sind explizit für Einsteigerinnen aufgebaut. Komm fünfzehn Minuten früher, dann erklären wir dir Matte, Block, Bolster und was die Sequenz für dich bedeutet.',
  },
  {
    question: 'Was muss ich mitbringen?',
    answer:
      'Bequeme Kleidung. Matte, Blöcke, Decken und Bolster sind bei uns. Eigene Matte gern. Wasserflasche. Sonst nichts.',
  },
  {
    question: 'Bin ich flexibel genug?',
    answer:
      'Yoga macht nicht Flexibilität voraus, Yoga schafft sie. Wenn du sitzen, stehen und atmen kannst, kannst du Yoga machen.',
  },
  {
    question: 'Wie funktioniert die Probestunde?',
    answer:
      'Schreibe uns eine E-Mail mit dem Termin, der dir passt. Wir reservieren eine Matte und schicken eine Bestätigung. Komm fünfzehn Minuten früher. Kein Vertrag, keine Karte, kein Verkaufsgespräch danach.',
  },
  {
    question: 'Übernimmt die Krankenkasse die Kosten?',
    answer:
      'Viele gesetzliche Krankenkassen erstatten 80–100% von Präventionskursen nach § 20 SGB V. Wir haben drei zertifizierte Präventionskurse (Hatha, Yin, Prenatal). Liste der teilnehmenden Kassen am Empfang.',
  },
];
---

<BaseLayout
  title={`${SITE.name} — Boutique-Yoga im Bergmannkiez`}
  description={t.tagline}
  locale={locale}
  alternateLocaleUrl="/en/"
>
  <Header locale={locale} />
  <main id="main">
    <Hero locale={locale} />
    <MenuPreview locale={locale} />

    <!-- PricingTable slim row — 4 tiers per studio.md §13 -->
    <section class="bg-bg" aria-labelledby="pricing-heading">
      <div class="container-page py-16 sm:py-20">
        <div class="max-w-2xl space-y-3 mb-10">
          <p class="text-[11px] tracking-[0.28em] uppercase text-accent-secondary-deep font-semibold">Mitgliedschaft</p>
          <h2 id="pricing-heading" class="font-display text-3xl sm:text-4xl text-text leading-[1.15] italic">Vier Wege, anzukommen.</h2>
        </div>
        <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 list-none p-0">
          {pricing.map((tier) => (
            <li class={`bg-surface border rounded-2xl p-6 flex flex-col ${tier.highlight ? 'border-accent shadow-elev' : 'border-border'}`}>
              {tier.highlight && (
                <p class="text-[10px] tracking-[0.28em] uppercase text-accent-deep font-semibold mb-2">Empfohlen</p>
              )}
              <h3 class="font-display text-lg text-text italic">{tier.name}</h3>
              <p class="mt-3 font-display text-3xl text-text tabular leading-none">{tier.price}</p>
              <p class="mt-1 text-xs text-text-muted uppercase tracking-wider">{tier.cadence}</p>
              <p class="mt-4 text-sm text-text-muted leading-relaxed flex-1">{tier.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Mock VideoFacade card — single class teaser placeholder -->
    <section class="bg-surface-elev" aria-labelledby="video-heading">
      <div class="container-page py-20 sm:py-24">
        <div class="max-w-3xl mx-auto text-center mb-10 space-y-3">
          <p class="text-[11px] tracking-[0.28em] uppercase text-accent-secondary-deep font-semibold">Atmosphäre</p>
          <h2 id="video-heading" class="font-display text-3xl sm:text-4xl text-text leading-[1.15] italic">Einen Moment ansehen.</h2>
          <p class="text-text-muted leading-relaxed">Ein Ausschnitt aus einer Vinyasa-Klasse — 45 Sekunden, ohne Worte.</p>
        </div>
        <div class="max-w-4xl mx-auto">
          <div class="aspect-video rounded-3xl bg-[var(--color-inverted-bg)] relative flex items-center justify-center group cursor-pointer overflow-hidden" role="button" tabindex="0" aria-label="Video starten (Mock)">
            <div class="absolute inset-0 bg-gradient-to-br from-accent-secondary/30 via-transparent to-accent/20"></div>
            <div class="relative z-10 flex flex-col items-center gap-4">
              <div class="w-20 h-20 rounded-full bg-accent flex items-center justify-center group-hover:scale-110 transition-transform shadow-elev">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-[var(--color-inverted-bg)] ml-1.5" aria-hidden="true">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <p class="text-[var(--color-inverted-text)] text-sm font-medium tracking-wider uppercase">Video starten — 0:45</p>
            </div>
            <p class="absolute bottom-4 left-0 right-0 text-center text-xs text-[var(--color-inverted-text-muted)] italic">⚠ Mockup — kein echter Video-Player. Demo nur.</p>
          </div>
        </div>
      </div>
    </section>

    <About locale={locale} />

    <!-- Studio gallery — 4-tile bento with real Unsplash photos -->
    <section class="bg-bg border-t border-border" aria-labelledby="gallery-heading">
      <div class="container-page py-20 sm:py-24">
        <div class="max-w-2xl space-y-3 mb-12">
          <p class="text-[11px] tracking-[0.28em] uppercase text-accent-secondary-deep font-semibold">{t.sections.gallery.eyebrow}</p>
          <h2 id="gallery-heading" class="font-display text-3xl sm:text-4xl text-text leading-[1.15] italic">{t.sections.gallery.heading}</h2>
          <p class="text-text-muted leading-relaxed">{t.sections.gallery.intro}</p>
        </div>
        <ul class="grid grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0">
          {galleryTiles.map((tile, i) => (
            <li class={`relative overflow-hidden ${i === 0 ? 'lg:col-span-2 lg:row-span-2 aspect-square lg:aspect-auto' : 'aspect-square'} rounded-2xl border border-border`}>
              <img src={tile.image} alt={tile.alt} loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover" />
              <div class="absolute inset-x-0 bottom-0 p-5 bg-gradient-to-t from-black/55 via-black/15 to-transparent">
                <p class="text-xs text-white font-medium tracking-wider">{tile.label}</p>
              </div>
            </li>
          ))}
        </ul>
        <p class="mt-6 text-xs text-text-muted/70 italic text-center">⚠ Stockfotografie (Unsplash CC0) — echte Studio-Bilder folgen mit Brand-Material.</p>
      </div>
    </section>

    <!-- TeamGrid 4-col small chips (different from V1's 4-card boxes) -->
    <section class="bg-surface-elev" aria-labelledby="instructors-heading">
      <div class="container-page py-20 sm:py-24">
        <div class="max-w-2xl space-y-3 mb-12">
          <p class="text-[11px] tracking-[0.28em] uppercase text-accent-secondary-deep font-semibold">Lehrer:innen</p>
          <h2 id="instructors-heading" class="font-display text-3xl sm:text-4xl text-text leading-[1.15] italic">Vier Lehrer:innen — jede:r mit eigener Handschrift.</h2>
        </div>
        <ul class="flex flex-wrap gap-3 list-none p-0">
          {instructors.map((i) => (
            <li class="flex items-center gap-4 bg-bg border border-border rounded-full pl-2 pr-6 py-2">
              <span class="w-12 h-12 rounded-full bg-accent-secondary text-bg flex items-center justify-center font-display text-base italic" aria-hidden="true">
                {i.initials}
              </span>
              <span>
                <span class="block font-display text-base text-text leading-tight">{i.name}</span>
                <span class="block text-xs text-text-muted">{i.styles}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- NewsletterMock inline -->
    <section class="bg-bg border-t border-border" aria-labelledby="newsletter-heading">
      <div class="container-page py-16 sm:py-20">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center max-w-5xl mx-auto">
          <div>
            <p class="text-[11px] tracking-[0.28em] uppercase text-accent-secondary-deep font-semibold mb-4">Newsletter</p>
            <h2 id="newsletter-heading" class="font-display text-3xl sm:text-4xl text-text leading-[1.15] italic">Stundenplan-Updates per E-Mail.</h2>
            <p class="mt-5 text-lg text-text-muted leading-relaxed">
              Einmal pro Woche eine kurze E-Mail: Kursplan-Änderungen, Workshop-Termine, Empfehlungen aus der Bibliothek. Kein Marketing, jederzeit abbestellbar.
            </p>
          </div>
          <form class="space-y-4" onsubmit="event.preventDefault(); this.querySelector('[data-thanks]').classList.remove('hidden'); this.querySelector('[data-form-row]').classList.add('hidden');">
            <div class="flex flex-col sm:flex-row gap-3" data-form-row>
              <input
                type="email"
                required
                placeholder="du@example.com"
                aria-label="E-Mail-Adresse"
                class="flex-1 px-5 py-3 min-h-[52px] rounded-full bg-surface border border-border text-text placeholder:text-text-muted/50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent"
              />
              <button
                type="submit"
                class="inline-flex items-center justify-center px-6 py-3 min-h-[52px] text-base font-medium rounded-full bg-accent-deep text-bg hover:bg-text hover:text-bg transition-colors"
              >
                Abonnieren
              </button>
            </div>
            <p data-thanks class="hidden text-sm text-accent-secondary-deep italic">
              ✦ Danke. Bitte den Bestätigungs-Link in deinem Posteingang anklicken.
            </p>
            <p class="text-xs text-text-muted/70 italic">⚠ Mockup — kein echter Versand. Diese Demo speichert nichts.</p>
          </form>
        </div>
      </div>
    </section>

    <FAQ
      eyebrow={t.sections.faq.eyebrow}
      heading={t.sections.faq.heading}
      items={faqItems}
      singleOpen={true}
      variant="flush"
    />

    <VisitPreview locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
