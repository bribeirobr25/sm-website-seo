---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import MapEmbed from '@/components/sections/MapEmbed.astro';
import VisitPreview from '@/components/sections/VisitPreview.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

const locale = 'en' as const;
const mapsUrl = `https://maps.google.com/?q=${encodeURIComponent(`${SITE.address.street}, ${SITE.address.postalCode} ${SITE.address.city}`)}`;
const dayLabelsEN = {
  Mon: 'Mon',
  Tue: 'Tue',
  Wed: 'Wed',
  Thu: 'Thu',
  Fri: 'Fri',
  Sat: 'Sat',
  Sun: 'Sun',
};
---

<BaseLayout
  title={`Studio — ${SITE.name}`}
  description="Atem Studio at Bergmannstraße 67. Weekdays 07:00–21:00, weekends 08:30–18:00."
  locale={locale}
  alternateLocaleUrl="/studio"
>
  <Header locale={locale} />
  <main id="main">
    <section class="bg-bg">
      <div class="container-page py-16 sm:py-24">
        <div class="max-w-3xl">
          <p class="text-xs uppercase tracking-[0.28em] text-accent-secondary-deep font-semibold">About the studio</p>
          <h1 class="mt-3 font-display text-4xl sm:text-5xl lg:text-6xl text-text leading-[1.1] italic">
            Two rooms, tea, stillness.
          </h1>
          <div class="mt-8 space-y-5 text-lg text-text-muted leading-[1.75]">
            <p>
              Atem Studio sits on the first floor of a turn-of-the-century building on Bergmannstraße — three minutes from Marheineke market, five from U-Gneisenaustraße. Two rooms: one with wooden floorboards, high ceilings, library sounds from the street. The second one quieter, with linoleum for restorative and prenatal.
            </p>
            <p>
              There is a changing room, two showers, a tea corner with three options (chamomile, rooibos, genmaicha), and a small library of yoga classics (Iyengar, Desikachar, Donna Farhi). Come fifteen minutes early — the time being there is part of the practice.
            </p>
            <p>
              We opened in 2018 with Lara and Felix; today there are four of us. We are deliberately staying small — otherwise classes turn impersonal. We are sometimes asked whether we will open a second location. The answer: no, we stay small.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-surface-elev">
      <div class="container-page py-16 sm:py-20">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
          <div class="bg-surface rounded-2xl p-8 border border-border space-y-2">
            <p class="font-display text-2xl text-text italic">{SITE.name}</p>
            <p class="text-text-muted">{SITE.address.street}</p>
            <p class="text-text-muted">{SITE.address.postalCode} {SITE.address.city} — {SITE.address.neighborhood}</p>
            <p class="text-text-muted pt-2">
              <a href={`tel:${SITE.phone}`} class="text-accent-deep hover:text-text underline tabular">{SITE.phoneDisplay}</a>
            </p>
            <p class="text-text-muted">
              <a href={`mailto:${SITE.email}`} class="text-accent-deep hover:text-text underline">{SITE.email}</a>
            </p>
            <div class="pt-4 flex flex-wrap gap-3">
              <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-5 py-3 min-h-[44px] text-base font-medium rounded-full bg-text text-bg hover:bg-accent-secondary-deep transition-colors">
                Open in Google Maps
              </a>
            </div>
          </div>

          <div class="bg-surface rounded-2xl p-8 border border-border space-y-5">
            <p class="text-xs uppercase tracking-[0.28em] text-accent-secondary-deep font-semibold">Opening hours</p>
            <div>
              <p class="font-display text-xl text-text italic">{SITE.hours.summer.label.en}</p>
              <dl class="mt-3 grid grid-cols-[auto_1fr] gap-x-6 gap-y-1 text-base tabular max-w-xs">
                {SITE.hours.summer.days.map((h) => (
                  <>
                    <dt class="text-text-muted">{dayLabelsEN[h.day as keyof typeof dayLabelsEN]}</dt>
                    <dd class="text-text">{h.open && h.close ? `${h.open} – ${h.close}` : 'closed'}</dd>
                  </>
                ))}
              </dl>
            </div>
            <div class="pt-3 border-t border-border">
              <p class="font-display text-xl text-text italic">{SITE.hours.winter.label.en}</p>
              <dl class="mt-3 grid grid-cols-[auto_1fr] gap-x-6 gap-y-1 text-base tabular max-w-xs">
                {SITE.hours.winter.days.map((h) => (
                  <>
                    <dt class="text-text-muted">{dayLabelsEN[h.day as keyof typeof dayLabelsEN]}</dt>
                    <dd class="text-text">{h.open && h.close ? `${h.open} – ${h.close}` : 'closed'}</dd>
                  </>
                ))}
              </dl>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-bg">
      <div class="container-page py-16 sm:py-20">
        <div class="max-w-2xl mb-8 space-y-3">
          <p class="text-[11px] tracking-[0.28em] uppercase text-accent-secondary-deep font-semibold">Getting there</p>
          <h2 class="font-display text-3xl sm:text-4xl text-text leading-[1.15] italic">By BVG or on foot.</h2>
          <p class="text-text-muted leading-relaxed">
            U7 Gneisenaustraße (5 min), U6 Mehringdamm (8 min), S-Bahn Yorckstraße (12 min). Few parking spots on Bergmannstraße — we recommend the bus, your bike, or simply walking.
          </p>
        </div>
        <MapEmbed
          lat={SITE.geo.lat}
          lng={SITE.geo.lng}
          zoom={16}
          markerLabel="Atem Studio · Bergmannstraße 67"
          title="Map: Atem Studio, Bergmannstraße 67, 10961 Berlin"
          provider="openstreetmap"
          aspect="16/9"
        />
      </div>
    </section>

    <VisitPreview locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
