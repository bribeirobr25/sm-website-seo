---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import LabelCountHeader from '@/components/sections/LabelCountHeader.astro';
import VisitPreview from '@/components/sections/VisitPreview.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

const locale = 'de' as const;
const t = SITE.i18n[locale];

const categories = [
  { key: 'creme' as const, lead: 'Wärme aufbauen, Aufmerksamkeit sammeln.' },
  { key: 'sorbetti' as const, lead: 'Loslassen, lange halten, langsam beobachten.' },
  {
    key: 'spezialitaeten' as const,
    lead: 'Längere Formate für Schwangerschaft, Coaching und Workshops.',
  },
];
---

<BaseLayout
  title={`Kursplan — ${SITE.name}`}
  description="Hatha, Vinyasa, Yin, Prenatal, Meditation. Sieben Tage die Woche im Boutique-Studio am Bergmannkiez."
  locale={locale}
  alternateLocaleUrl="/en/classes"
>
  <Header locale={locale} />
  <main id="main">
    <section class="bg-bg">
      <div class="container-page py-16 sm:py-24">
        <div class="max-w-3xl">
          <p class="text-xs uppercase tracking-[0.28em] text-accent-secondary-deep font-semibold">{t.nav.menu}</p>
          <h1 class="mt-3 font-display text-4xl sm:text-5xl lg:text-6xl text-text leading-[1.1] italic">Unser Kursplan.</h1>
          <p class="mt-8 text-lg sm:text-xl text-text-muted leading-[1.75]">
            Vier Klassen am Tag im Wechsel — morgens, mittags, früher Abend, später Abend. Hier sind die Stilrichtungen; den genauen Wochenplan schicken wir dir per E-Mail (er ändert sich saisonal).
          </p>
          <p class="mt-6 text-base text-text-muted leading-relaxed">
            Preise: Probestunde gratis · Drop-in 20 € · 10er Karte 180 € · Monatskarte 95 €. Alle Stile mit allen Mitgliedschaften zugänglich.
          </p>
        </div>
      </div>
    </section>

    {categories.map((cat, idx) => {
      const section = SITE.menu[cat.key];
      const bg = idx % 2 === 0 ? 'bg-surface-elev' : 'bg-bg';
      return (
        <section class={bg}>
          <div class="container-page py-16 sm:py-20">
            <div class="max-w-3xl mb-10">
              <LabelCountHeader
                label={section.label.de}
                count={section.count}
                countLabel={`${section.count} Klassentypen`}
              />
              <p class="mt-4 text-lg text-text-muted leading-relaxed italic">{cat.lead}</p>
              <p class="mt-3 text-base text-text-muted leading-relaxed">{section.intro.de}</p>
            </div>

            <ul class="grid sm:grid-cols-2 gap-x-10 gap-y-8 list-none p-0">
              {section.items.map((item) => (
                <li class="border-l-2 border-accent pl-5 py-1">
                  <p class="font-display text-xl text-text leading-tight italic">{item.de.name}</p>
                  <p class="mt-2 text-text-muted leading-relaxed">{item.de.desc}</p>
                </li>
              ))}
            </ul>
          </div>
        </section>
      );
    })}

    <VisitPreview locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
