---
import '@fontsource-variable/fraunces/wght.css';
import '@fontsource-variable/fraunces/wght-italic.css';
import '@fontsource-variable/manrope';
import '../styles/global.css';
import { getImage } from 'astro:assets';
import heroPicanha from '../assets/images/picanha.png';
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import StickyWhatsApp from '../components/ui/StickyWhatsApp.astro';
import type { ResolvedMetadata } from '../lib/metadata.ts';
import { buildRestaurantSchema } from '../lib/seo/schema.ts';
import { LOCALE_HTML_LANG, type Locale, SITE, useTranslations } from '../lib/site.ts';

type Props = {
  metadata: ResolvedMetadata;
};

const { metadata } = Astro.props;
const locale: Locale = metadata.locale;
const t = useTranslations(locale);

const ogImage = await getImage({
  src: heroPicanha,
  format: 'jpg',
  width: 1200,
  quality: 80,
});
const ogImageUrl = `${SITE.url}${ogImage.src}`;

const schema = buildRestaurantSchema(metadata.canonical, ogImageUrl);
---

<!doctype html>
<html lang={LOCALE_HTML_LANG[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <link rel="canonical" href={metadata.canonical} />

    <!-- DEMO PHASE — remove the two lines below before production -->
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />

    {
      metadata.alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }

    <meta property="og:type" content="restaurant.restaurant" />
    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta property="og:url" content={metadata.canonical} />
    <meta property="og:locale" content={metadata.ogLocale} />
    <meta property="og:site_name" content="Porto dos Ribeiros" />
    <meta property="og:image" content={ogImageUrl} />

    <link rel="icon" type="image/png" href="/images/logo.png" />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded-md focus:bg-[var(--color-accent)] focus:px-4 focus:py-2 focus:text-white"
    >
      {t('nav.skip')}
    </a>
    <Header locale={locale} currentPath={metadata.path} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <StickyWhatsApp locale={locale} />
  </body>
</html>
