---
import Hero from '../components/sections/Hero.astro';
import Hours from '../components/sections/Hours.astro';
import MenuPreview from '../components/sections/MenuPreview.astro';
import Reviews from '../components/sections/Reviews.astro';
import Visit from '../components/sections/Visit.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { resolveMetadata } from '../lib/metadata.ts';
import { useTranslations } from '../lib/site.ts';

const locale = 'pt' as const;
const t = useTranslations(locale);
const metadata = resolveMetadata({
  title: t('home.meta_title'),
  description: t('home.meta_description'),
  locale,
  path: '/',
});
---

<BaseLayout metadata={metadata}>
  <Hero locale={locale} />
  <Hours locale={locale} />
  <MenuPreview locale={locale} />
  <Reviews locale={locale} />
  <Visit locale={locale} />
</BaseLayout>
