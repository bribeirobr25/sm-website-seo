---
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section
  aria-labelledby="hours-heading"
  class="border-y border-[var(--color-border)] bg-[var(--color-surface)]"
>
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6 sm:py-14">
    <p class="text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-text-muted)]">
      {t('home.hours.kicker')}
    </p>
    <h2
      id="hours-heading"
      class="mt-2 font-display text-3xl leading-[1.1] sm:text-4xl"
      style="font-family: var(--font-display); font-weight: 600"
    >
      {t('home.hours.title')}
    </h2>
    <p class="mt-3 max-w-xl text-base text-[var(--color-text-muted)]">
      {t('home.hours.sub')}
    </p>

    <dl
      class="mt-7 grid max-w-2xl grid-cols-1 gap-x-10 gap-y-1 text-base sm:grid-cols-2"
    >
      {
        SITE.hours.map((window) => (
          <div class="flex items-baseline justify-between border-b border-[var(--color-border)] py-3">
            <dt class="font-medium">{t(`days.${window.key}`)}</dt>
            <dd class="tabular text-[var(--color-text-muted)]">
              <time>{window.open}</time>
              {' – '}
              <time>{window.close === '24:00' ? '00:00' : window.close}</time>
            </dd>
          </div>
        ))
      }
    </dl>

    <p class="mt-4 text-xs italic text-[var(--color-text-muted)]">
      {t('home.hours.footnote')}
    </p>
  </div>
</section>
