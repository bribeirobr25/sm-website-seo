---
import { Image } from 'astro:assets';
import heroPicanha from '../../assets/images/picanha.png';
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';
import Button from '../ui/Button.astro';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative overflow-hidden">
  <div class="mx-auto max-w-5xl px-4 pt-10 pb-16 sm:px-6 sm:pt-20 sm:pb-24">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div>
        <p
          class="inline-flex items-center gap-2 rounded-full bg-[var(--color-open)]/12 px-3 py-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[var(--color-open)]"
        >
          <span
            class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-open)]"
            aria-hidden="true"></span>
          {t('home.hero.ribbon')}
        </p>

        <p
          class="mt-6 text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-text-muted)]"
        >
          {t('home.hero.eyebrow')}
        </p>

        <h1
          class="mt-3 font-display text-4xl leading-[1.05] sm:text-5xl lg:text-6xl"
          style="font-family: var(--font-display); font-weight: 600"
        >
          {t('home.hero.headline')}
        </h1>

        <p
          class="mt-6 max-w-xl text-base leading-relaxed text-[var(--color-text-muted)] sm:text-lg"
        >
          {t('home.hero.sub')}
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={SITE.whatsappUrl} variant="primary" external ariaLabel={t('cta.whatsapp')}>
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="currentColor"
            >
              <path
                d="M19.05 4.91A10 10 0 0 0 12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.83-1.27A10 10 0 0 0 22 12a10 10 0 0 0-2.95-7.09Zm-7.05 15.4a8.3 8.3 0 0 1-4.23-1.16l-.3-.18-2.86.75.76-2.79-.2-.32A8.31 8.31 0 1 1 12 20.31Zm4.55-6.22c-.25-.13-1.47-.72-1.7-.81-.23-.08-.4-.13-.56.13-.16.25-.65.81-.79.97-.15.16-.29.18-.54.05-.25-.13-1.06-.39-2.02-1.25a7.6 7.6 0 0 1-1.4-1.74c-.15-.25 0-.39.11-.51.11-.11.25-.29.37-.43.13-.15.16-.25.25-.41.08-.16 0-.32-.04-.45-.05-.13-.55-1.33-.75-1.82-.2-.48-.4-.42-.55-.42h-.46c-.16 0-.41.06-.62.31-.21.25-.81.79-.81 1.94 0 1.15.83 2.25.94 2.41.11.15 1.63 2.49 3.95 3.49.55.24.98.38 1.32.49.55.18 1.06.16 1.46.1.45-.07 1.47-.6 1.68-1.18.21-.59.21-1.08.15-1.18-.07-.11-.23-.18-.48-.31Z"
              />
            </svg>
            {t('cta.whatsapp')}
          </Button>
          <Button href={SITE.mapsUrl} variant="secondary" external>
            {t('cta.directions')}
          </Button>
        </div>

        <p class="mt-6 text-sm text-[var(--color-text-muted)]">
          <a href={`tel:${SITE.phone}`} class="tabular hover:text-[var(--color-text)]">
            {SITE.phoneDisplay}
          </a>
        </p>
      </div>

      <div class="relative">
        <div
          aria-hidden="true"
          class="absolute -top-3 -left-3 -z-10 hidden h-full w-full rounded-2xl border border-[var(--color-border)] sm:block"
        ></div>
        <div class="relative aspect-[4/5] overflow-hidden rounded-2xl shadow-[var(--shadow-card)]">
          <Image
            src={heroPicanha}
            alt="Picanha brasileira no Porto dos Ribeiros"
            widths={[400, 640, 800, 1024]}
            sizes="(max-width: 1024px) 100vw, 480px"
            format="webp"
            quality={75}
            loading="eager"
            fetchpriority="high"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
