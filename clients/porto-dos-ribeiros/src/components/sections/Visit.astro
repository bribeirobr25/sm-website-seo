---
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';
import Azulejo from '../ui/Azulejo.astro';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section
  aria-labelledby="visit-heading"
  class="border-t border-[var(--color-border)] bg-[var(--color-surface)]"
>
  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-24">
    <div class="max-w-2xl">
      <p
        class="text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-text-muted)]"
      >
        {t('home.visit.kicker')}
      </p>
      <h2
        id="visit-heading"
        class="mt-2 font-display text-3xl leading-[1.1] sm:text-4xl"
        style="font-family: var(--font-display); font-weight: 600"
      >
        {t('home.visit.title')}
      </h2>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 md:gap-8">
      <article
        class="relative overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6 sm:p-8"
      >
        <Azulejo
          size={64}
          class="absolute -top-3 -right-3 opacity-90"
        />
        <address class="relative not-italic">
          <p class="font-display text-xl sm:text-2xl" style="font-family: var(--font-display); font-weight: 600">
            {t('home.visit.address_line_1')}
          </p>
          <p class="mt-1 text-base text-[var(--color-text-muted)]">
            {t('home.visit.address_line_2')}
          </p>
        </address>

        <dl class="mt-5 space-y-2.5 text-sm">
          <div class="flex items-baseline gap-3">
            <dt class="w-20 shrink-0 text-xs uppercase tracking-[0.12em] text-[var(--color-text-muted)]">
              {t('home.visit.kicker')}
            </dt>
            <dd>{t('home.visit.district')}</dd>
          </div>
          <div class="flex items-baseline gap-3">
            <dt class="w-20 shrink-0 text-xs uppercase tracking-[0.12em] text-[var(--color-text-muted)]">
              Metro
            </dt>
            <dd>{t('home.visit.transit')}</dd>
          </div>
          <div class="flex items-baseline gap-3">
            <dt class="w-20 shrink-0 text-xs uppercase tracking-[0.12em] text-[var(--color-text-muted)]">
              {t('labels.phone')}
            </dt>
            <dd>
              <a
                href={`tel:${SITE.phone}`}
                class="tabular hover:text-[var(--color-accent-deep)]"
              >
                {SITE.phoneDisplay}
              </a>
            </dd>
          </div>
        </dl>

        <a
          href={SITE.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-7 inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-text)] underline decoration-[var(--color-accent)]/40 underline-offset-4 hover:decoration-[var(--color-accent)]"
        >
          {t('home.visit.open_in_maps')}
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M7 17 17 7" />
            <path d="M7 7h10v10" />
          </svg>
        </a>
      </article>

      <article
        class="rounded-2xl border border-[var(--color-border)] p-6 sm:p-8"
      >
        <p
          class="text-xs font-medium uppercase tracking-[0.12em] text-[var(--color-text-muted)]"
        >
          {t('home.visit.delivery_kicker')}
        </p>
        <h3
          class="mt-2 font-display text-xl sm:text-2xl"
          style="font-family: var(--font-display); font-weight: 600"
        >
          {t('home.visit.delivery_title')}
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-muted)]">
          {t('home.visit.delivery_text')}
        </p>
      </article>
    </div>
  </div>
</section>
