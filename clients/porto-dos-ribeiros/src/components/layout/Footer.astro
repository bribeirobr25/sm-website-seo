---
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<footer class="mt-24 border-t border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 sm:grid-cols-3">
      <div>
        <p
          class="font-display text-lg font-semibold"
          style="font-family: var(--font-display)"
        >
          {t('footer.legal_name')}
        </p>
        <address
          class="mt-2 not-italic text-sm leading-relaxed text-[var(--color-text-muted)]"
        >
          {SITE.address.street}<br />
          {SITE.address.postal}
          {SITE.address.city}, Portugal
        </address>
        <p class="mt-3 text-xs italic text-[var(--color-text-muted)]">
          {t('footer.legal_note')}
        </p>
      </div>

      <div class="text-sm">
        <p class="text-xs font-medium uppercase tracking-[0.12em] text-[var(--color-text-muted)]">
          {t('labels.phone')}
        </p>
        <a
          href={`tel:${SITE.phone}`}
          class="tabular mt-1 block hover:text-[var(--color-accent-deep)]"
        >
          {SITE.phoneDisplay}
        </a>
        <p class="mt-4 text-xs font-medium uppercase tracking-[0.12em] text-[var(--color-text-muted)]">
          {t('labels.whatsapp')}
        </p>
        <a
          href={SITE.whatsappUrl}
          target="_blank"
          rel="noopener"
          class="tabular mt-1 block hover:text-[var(--color-accent-deep)]"
        >
          {SITE.phoneDisplay}
        </a>
        <div class="mt-4 flex gap-3 text-sm text-[var(--color-text-muted)]">
          <a
            href={SITE.socials.instagram}
            target="_blank"
            rel="noopener"
            class="hover:text-[var(--color-text)]"
          >
            Instagram
          </a>
          <a
            href={SITE.socials.facebook}
            target="_blank"
            rel="noopener"
            class="hover:text-[var(--color-text)]"
          >
            Facebook
          </a>
        </div>
      </div>

      <div class="text-sm">
        <ul class="space-y-2">
          <li>
            <a
              href={SITE.complaintsUrl}
              target="_blank"
              rel="noopener"
              class="text-[var(--color-text-muted)] hover:text-[var(--color-text)]"
            >
              {t('footer.complaints_link')}
            </a>
          </li>
          <li>
            <a
              href={locale === 'pt'
                ? '/politica-de-privacidade'
                : '/en/privacy-policy'}
              class="text-[var(--color-text-muted)] hover:text-[var(--color-text)]"
            >
              {t('footer.privacy')}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <p class="mt-10 text-xs text-[var(--color-text-muted)]">
      {t('footer.made_with')}
    </p>
  </div>
</footer>
