---
import { type Locale, localizePath, useTranslations } from '../../lib/site.ts';
import LangSwitcher from './LangSwitcher.astro';

type Props = {
  locale: Locale;
  currentPath: string;
};

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);

// Nav entries for production must not link to stub pages
// (per DESIGN-BEST-PRACTICES.md). /menu and /visitar currently
// resolve to StubBody pages, so they're omitted from chrome.
// The home page already surfaces both as scrollable sections
// (MenuPreview and Visit). Re-add nav entries once those routes
// carry real content.
const navItems = [{ key: 'home', path: '/' }];
---

<header
  class="sticky top-0 z-30 border-b border-[var(--color-border)] bg-[var(--color-bg)]/85 backdrop-blur supports-[backdrop-filter]:bg-[var(--color-bg)]/70"
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="flex items-center justify-between py-3">
      <a
        href={localizePath('/', locale)}
        class="font-display text-lg font-semibold tracking-tight sm:text-xl"
        aria-label="Porto dos Ribeiros"
        style="font-family: var(--font-display)"
      >
        Porto dos Ribeiros
      </a>

      <div class="flex items-center gap-1 sm:gap-5">
        {
          // Desktop nav row only renders when there are multiple destinations.
          // With a single item (just home), the logo itself is the home link,
          // so an explicit "Home" pill is redundant.
          navItems.length > 1 && (
            <ul class="hidden items-center gap-1 sm:flex">
              {navItems.map((item) => {
                const href = localizePath(item.path, locale);
                const isActive = currentPath === item.path;
                return (
                  <li>
                    <a
                      href={href}
                      aria-current={isActive ? 'page' : undefined}
                      class:list={[
                        'rounded-md px-3 py-1.5 text-sm transition-colors',
                        isActive
                          ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent-deep)]'
                          : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)]',
                      ]}
                    >
                      {t(`nav.${item.key}`)}
                    </a>
                  </li>
                );
              })}
            </ul>
          )
        }
        <LangSwitcher locale={locale} currentPath={currentPath} />
      </div>
    </div>

    {
      // Mobile sub-nav row only renders when there are multiple destinations.
      // With a single item (just home), the row is visual noise.
      navItems.length > 1 && (
        <nav
          aria-label={t('nav.home')}
          class="-mx-4 overflow-x-auto border-t border-[var(--color-border)]/60 sm:hidden"
        >
          <ul class="flex min-w-max gap-1 px-4 py-2 text-sm">
            {navItems.map((item) => {
              const href = localizePath(item.path, locale);
              const isActive = currentPath === item.path;
              return (
                <li>
                  <a
                    href={href}
                    aria-current={isActive ? 'page' : undefined}
                    class:list={[
                      'inline-block rounded-md px-3 py-1.5 transition-colors',
                      isActive
                        ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent-deep)] font-medium'
                        : 'text-[var(--color-text-muted)]',
                    ]}
                  >
                    {t(`nav.${item.key}`)}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      )
    }
  </div>
</header>
