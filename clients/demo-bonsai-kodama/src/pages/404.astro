---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const locale = 'de' as const;
---

<BaseLayout title="Seite nicht gefunden" locale={locale}>
  <Header locale={locale} />
  <main id="main" class="container-page py-24 text-center max-w-xl mx-auto">
    <p class="text-sm uppercase tracking-[0.18em] text-text-muted">404</p>
    <h1 class="mt-3 font-display text-4xl sm:text-5xl text-text italic">Diese Seite existiert nicht.</h1>
    <p class="mt-6 text-text-muted leading-relaxed">
      Vielleicht suchst du einen bestimmten Baum, einen Stil oder eine Technik? Probier die Suche oder kehre zur Sammlung zurück.
    </p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a href="/" class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-md bg-accent-deep text-bg hover:bg-text hover:text-bg transition-colors">
        Zur Startseite
      </a>
      <a href="/search" class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-md border border-text text-text hover:bg-text hover:text-bg transition-colors">
        Baum suchen
      </a>
    </div>
  </main>
  <Footer locale={locale} />
</BaseLayout>
