---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type Locale, SITE } from '@/lib/site';
import { EN_PRIVACY } from '@/lib/translations/en';
import { ES_PRIVACY } from '@/lib/translations/es';
import { PTBR_PRIVACY } from '@/lib/translations/pt-br';

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' }, props: { locale: 'en' as const } },
    { params: { locale: 'es' }, props: { locale: 'es' as const } },
    { params: { locale: 'pt-br' }, props: { locale: 'pt-br' as const } },
  ];
}

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const META: Record<Locale, { title: string; description: string }> = {
  de: {
    title: 'Datenschutzerklärung',
    description: 'Datenschutzerklärung nach DSGVO für Kodama Bonsai.',
  },
  en: {
    title: 'Privacy policy',
    description: 'GDPR/DSGVO privacy policy for Kodama Bonsai, operated from the EU.',
  },
  es: {
    title: 'Política de privacidad',
    description:
      'Política de privacidad conforme al RGPD/DSGVO de Kodama Bonsai, con sede en la UE.',
  },
  'pt-br': {
    title: 'Política de privacidade',
    description: 'Política de privacidade conforme o DSGVO/RGPD da Kodama Bonsai, operado na UE.',
  },
};

const BODIES: Record<Exclude<Locale, 'de'>, string> = {
  en: EN_PRIVACY,
  es: ES_PRIVACY,
  'pt-br': PTBR_PRIVACY,
};

const meta = META[locale];
const body = BODIES[locale as Exclude<Locale, 'de'>];

// Agents emitted SITE refs in two shapes:
//   1. Bare Astro expression: {SITE.legal.legalEntity}
//   2. Astro expression wrapping a JS template literal: {`mailto:${SITE.legal.dataControllerEmail}`}
// Plus a processors loop expression that we resolve to an inline list.
const locationLabel =
  locale === 'en' ? 'Location:' : locale === 'es' ? 'Ubicación:' : 'Localização:';

const processorsList = SITE.legal.processors
  .map(
    (p) =>
      `<li><strong class="text-text">${p.name}</strong> — ${p.purpose} (${locationLabel} ${p.location})</li>`,
  )
  .join('');

const resolved = body
  // Pattern 2 first (more specific) — href={`mailto:${SITE.X}`} → mailto:<value>
  .replace(
    /\{`mailto:\$\{SITE\.legal\.dataControllerEmail\}`\}/g,
    `"mailto:${SITE.legal.dataControllerEmail}"`,
  )
  .replace(/\{`mailto:\$\{SITE\.email\}`\}/g, `"mailto:${SITE.email}"`)
  .replace(/\{`tel:\$\{SITE\.phone\}`\}/g, `"tel:${SITE.phone}"`)
  // Loop expression (privacy section 5 processors list) — replace the whole .map(...) JSX block with a pre-rendered list.
  // Pattern ends with `))}` — two parens + closing brace of the Astro expression.
  .replace(/\{SITE\.legal\.processors\.map[\s\S]*?\)\s*\)\s*\}/g, processorsList)
  // Pattern 1 — bare {SITE.X.Y}
  .replace(/\{SITE\.legal\.legalEntity\}/g, SITE.legal.legalEntity)
  .replace(/\{SITE\.legal\.legalRepresentatives\}/g, SITE.legal.legalRepresentatives)
  .replace(/\{SITE\.legal\.taxId\}/g, SITE.legal.taxId)
  .replace(/\{SITE\.legal\.dataControllerEmail\}/g, SITE.legal.dataControllerEmail)
  .replace(/\{SITE\.legal\.dataControllerPhone\}/g, SITE.legal.dataControllerPhone)
  .replace(/\{SITE\.address\.street\}/g, SITE.address.street)
  .replace(/\{SITE\.address\.postalCode\}/g, SITE.address.postalCode)
  .replace(/\{SITE\.address\.city\}/g, SITE.address.city)
  .replace(/\{SITE\.address\.country\}/g, SITE.address.country)
  .replace(/\{SITE\.phoneDisplay\}/g, SITE.phoneDisplay)
  .replace(/\{SITE\.phone\}/g, SITE.phone)
  .replace(/\{SITE\.email\}/g, SITE.email)
  .replace(/\{SITE\.name\}/g, SITE.name);
---

<BaseLayout title={meta.title} description={meta.description} locale={locale} localePath="/privacy">
  <Header locale={locale} localePath="/privacy" />
  <main id="main">
    <article class="container-page py-16 sm:py-24 max-w-3xl space-y-10" set:html={resolved} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
