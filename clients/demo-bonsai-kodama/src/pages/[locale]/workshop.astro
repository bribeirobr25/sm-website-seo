---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import NewsletterMock from '@/components/sections/NewsletterMock.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PAGE_STRINGS } from '@/lib/page-strings';
import { type Locale, SITE } from '@/lib/site';

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' }, props: { locale: 'en' as const } },
    { params: { locale: 'es' }, props: { locale: 'es' as const } },
    { params: { locale: 'pt-br' }, props: { locale: 'pt-br' as const } },
  ];
}

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const p = PAGE_STRINGS[locale].workshop;
const dayLabels = PAGE_STRINGS[locale].day;
const mapsUrl = `https://maps.google.com/?q=${encodeURIComponent(`${SITE.address.street}, ${SITE.address.postalCode} ${SITE.address.city}`)}`;
---

<BaseLayout title={p.title} description={p.description} locale={locale} localePath="/workshop">
  <Header locale={locale} localePath="/workshop" />
  <main id="main">
    <section class="bg-bg">
      <div class="container-page py-16 sm:py-24">
        <div class="max-w-3xl">
          <p class="text-[11px] tracking-[0.32em] uppercase text-accent-secondary-deep font-semibold mb-6">{p.heroEyebrow}</p>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl text-text leading-[1.05] italic">{p.heroTitle}</h1>
          <div class="mt-8 space-y-5 text-lg text-text-muted leading-relaxed">
            {p.heroBody.map((para) => <p>{para}</p>)}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-surface-elev border-y border-border">
      <div class="container-page py-16 sm:py-20">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
          <div class="bg-surface rounded-md p-8 border border-border space-y-2">
            <p class="font-display text-2xl text-text italic">{SITE.name}</p>
            <p class="text-text">{SITE.address.street}</p>
            <p class="text-text-muted">{SITE.address.postalCode} {SITE.address.city} — {SITE.address.neighborhood}</p>
            <p class="text-text-muted pt-2">
              <a href={`tel:${SITE.phone}`} class="text-accent-deep hover:text-text underline tabular">{SITE.phoneDisplay}</a>
            </p>
            <p class="text-text-muted">
              <a href={`mailto:${SITE.email}`} class="text-accent-deep hover:text-text underline">{SITE.email}</a>
            </p>
            <div class="pt-4 flex flex-wrap gap-3">
              <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-5 py-3 min-h-[44px] text-sm font-semibold uppercase tracking-wider rounded-md bg-accent-deep text-bg hover:bg-text hover:text-bg transition-colors">
                {p.mapsCta}
              </a>
            </div>
          </div>

          <div class="bg-surface rounded-md p-8 border border-border space-y-5">
            <p class="text-xs uppercase tracking-[0.18em] text-accent-secondary-deep font-semibold">{p.hoursLabel}</p>
            <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-1 text-base tabular max-w-xs">
              {SITE.hours.workshop.map((h) => (
                <>
                  <dt class="text-text-muted">{dayLabels[h.day as keyof typeof dayLabels]}</dt>
                  <dd class="text-text">{h.open && h.close ? `${h.open} – ${h.close}` : p.closedLabel}</dd>
                </>
              ))}
            </dl>
            <p class="text-xs text-text-muted italic pt-4">{p.hoursNote}</p>
          </div>
        </div>
      </div>
    </section>

    <NewsletterMock locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
