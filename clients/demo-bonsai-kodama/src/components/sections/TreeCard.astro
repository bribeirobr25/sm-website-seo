---
import { LOCALE_PREFIX, type Locale, SITE } from '@/lib/site';
import { type Tree, tr } from '@/lib/trees';

interface Props {
  tree: Tree;
  locale: Locale;
  href?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { tree, locale, href, size = 'md' } = Astro.props;
const t = SITE.i18n[locale];

const treeUrl = href ?? `${LOCALE_PREFIX[locale]}/trees/${tree.slug}`;
const cardClass = size === 'sm' ? 'aspect-square' : size === 'lg' ? 'aspect-[4/3]' : 'aspect-[5/4]';
const catLabel =
  tree.category === 'indoor'
    ? t.labels.indoor
    : tree.category === 'outdoor'
      ? t.labels.outdoor
      : t.labels.both;
---

<a href={treeUrl} class="group block bg-surface rounded-md overflow-hidden border border-border hover:border-accent-secondary-deep transition-colors">
  <div class={`relative ${cardClass} overflow-hidden bg-surface-elev`}>
    <img
      src={tree.photos[0].src}
      alt={tr(tree.photos[0].alt, locale)}
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-[var(--motion-warm)]"
    />
    {tree.beginnerFriendly && (
      <span class="absolute top-3 left-3 bg-accent-secondary-deep text-bg text-[10px] uppercase tracking-[0.12em] font-semibold px-2 py-1 rounded-sm">
        {t.labels.beginnerBadge}
      </span>
    )}
    <span class="absolute top-3 right-3 bg-bg/90 text-text text-[10px] uppercase tracking-[0.12em] font-semibold px-2 py-1 rounded-sm backdrop-blur-sm">
      {catLabel}
    </span>
  </div>
  <div class="p-5">
    <p class="font-display text-xl text-text leading-tight">{tr(tree.popularName, locale)}</p>
    <p class="mt-1 text-xs italic text-text-muted tracking-wide">{tree.scientificName}</p>
    <p class="mt-3 text-xs uppercase tracking-[0.15em] text-accent-secondary-deep font-semibold">{tree.family}</p>
  </div>
</a>
