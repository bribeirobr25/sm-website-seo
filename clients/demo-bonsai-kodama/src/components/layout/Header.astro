---
import { type Locale, SITE } from '@/lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = SITE.i18n[locale];
const otherLocale: Locale = locale === 'de' ? 'en' : 'de';

// EN routes are not built in v1 — see docs/clients/demo-bonsai-kodama/CLAUDE.md "What was NOT built".
// All nav points to DE routes regardless of locale to avoid 404s.
const nav = [
  { href: '/trees', label: t.nav.trees },
  { href: '/einsteiger', label: t.nav.beginners },
  { href: '/indoor', label: t.nav.indoor },
  { href: '/outdoor', label: t.nav.outdoor },
  { href: '/werkstatt', label: t.nav.about },
];

const home = '/';
const searchHref = '/suche';
---

<header class="border-b border-border bg-bg/95 sticky top-0 z-30 backdrop-blur-sm">
  <div class="container-page flex items-center justify-between gap-4 py-4">
    <a
      href={home}
      class="flex items-center gap-2 group shrink-0"
      aria-label={`${SITE.name} — ${locale === 'de' ? 'Startseite' : 'home'}`}
    >
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <circle cx="14" cy="14" r="13" stroke="currentColor" stroke-width="1" class="text-accent-secondary-deep" opacity="0.4" />
        <path d="M14 4 C 14 4, 11 10, 11 14 C 11 18, 14 24, 14 24 M 14 14 C 14 14, 9 12, 7 15 M 14 14 C 14 14, 19 11, 21 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-accent-secondary-deep" fill="none" />
        <circle cx="14" cy="25" r="1.5" fill="currentColor" class="text-accent-deep" />
      </svg>
      <span class="font-display text-xl sm:text-2xl text-text group-hover:text-accent-deep transition-colors leading-none">
        {SITE.name}
      </span>
    </a>

    <nav aria-label="Primary" class="hidden lg:block">
      <ul class="flex items-center gap-6 text-sm list-none p-0">
        {nav.map((item) => (
          <li><a href={item.href} class="text-text hover:text-accent-deep transition-colors">{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <a
        href={searchHref}
        class="inline-flex items-center gap-2 text-sm text-text hover:text-accent-deep transition-colors px-3 py-2 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        aria-label={t.cta.search}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <span class="hidden md:inline">{t.cta.search}</span>
      </a>

      <button
        id="hamburger-toggle"
        type="button"
        class="lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-md text-text hover:text-accent-deep transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        aria-controls="mobile-nav"
        aria-expanded="false"
        aria-label={locale === 'de' ? 'Menü öffnen' : 'Open menu'}
        data-close-label={locale === 'de' ? 'Menü schließen' : 'Close menu'}
      >
        <svg id="hamburger-icon-open" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg id="hamburger-icon-close" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" aria-label="Mobile primary" class="lg:hidden hidden border-t border-border bg-bg">
    <ul class="container-page flex flex-col py-4 gap-1 text-base list-none">
      {nav.map((item) => (
        <li><a href={item.href} class="block py-3 text-text hover:text-accent-deep transition-colors">{item.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('hamburger-toggle') as HTMLButtonElement | null;
  const nav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('hamburger-icon-open');
  const iconClose = document.getElementById('hamburger-icon-close');
  const closeLabelAttr = toggle?.dataset.closeLabel;

  if (toggle && nav && iconOpen && iconClose) {
    const openLabel = toggle.getAttribute('aria-label') ?? 'Open menu';
    toggle.addEventListener('click', () => {
      const next = toggle.getAttribute('aria-expanded') !== 'true';
      toggle.setAttribute('aria-expanded', String(next));
      nav.classList.toggle('hidden', !next);
      iconOpen.classList.toggle('hidden', next);
      iconClose.classList.toggle('hidden', !next);
      toggle.setAttribute('aria-label', next ? (closeLabelAttr ?? 'Close menu') : openLabel);
    });
  }
</script>
