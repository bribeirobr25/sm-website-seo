---
import { LOCALE_PREFIX, type Locale, SITE } from '@/lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentYear = new Date().getFullYear();
const t = SITE.i18n[locale];
const prefix = LOCALE_PREFIX[locale];

const links = [
  { href: `${prefix}/trees`, label: t.nav.trees },
  { href: `${prefix}/beginners`, label: t.nav.beginners },
  { href: `${prefix}/indoor`, label: t.chrome.indoorBonsai },
  { href: `${prefix}/outdoor`, label: t.chrome.outdoorBonsai },
  { href: `${prefix}/search`, label: t.nav.search },
  { href: `${prefix}/workshop`, label: t.nav.about },
];

const legalLinks = [
  { href: `${prefix}/imprint`, label: t.chrome.imprintLabel },
  { href: `${prefix}/privacy`, label: t.chrome.privacyLabel },
];
---

<footer class="border-t border-border bg-surface-elev mt-24">
  <div class="container-page py-14">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <div class="space-y-3 lg:col-span-1">
        <p class="font-display text-2xl text-text">{SITE.name}</p>
        <p class="text-sm text-text-muted leading-relaxed italic">{t.tagline}</p>
      </div>

      <div class="space-y-3 text-sm">
        <p class="uppercase tracking-[0.15em] text-text-muted text-xs font-semibold">{t.nav.about}</p>
        <p class="text-text">{SITE.address.street}<br />{SITE.address.postalCode} {SITE.address.city}</p>
        <p>
          <a href={`tel:${SITE.phone}`} class="text-accent-deep hover:text-text underline tabular">{SITE.phoneDisplay}</a>
        </p>
        <p>
          <a href={`mailto:${SITE.email}`} class="text-accent-deep hover:text-text underline">{SITE.email}</a>
        </p>
      </div>

      <div class="space-y-3 text-sm">
        <p class="uppercase tracking-[0.15em] text-text-muted text-xs font-semibold">{t.chrome.navHeading}</p>
        <ul class="space-y-2 list-none p-0">
          {links.map((l) => (
            <li><a href={l.href} class="text-text hover:text-accent-deep transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="space-y-3 text-sm">
        <p class="uppercase tracking-[0.15em] text-text-muted text-xs font-semibold">{t.chrome.legalHeading}</p>
        <ul class="space-y-2 list-none p-0">
          {legalLinks.map((l) => (
            <li><a href={l.href} class="text-text hover:text-accent-deep transition-colors">{l.label}</a></li>
          ))}
          <li>
            <button
              type="button"
              id="footer-manage-cookies"
              class="text-text hover:text-accent-deep transition-colors text-left focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-sm"
            >
              {t.consent.manage}
            </button>
          </li>
        </ul>
        <p class="text-text-muted text-xs pt-3 italic">{t.chrome.photoNote}</p>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-border flex flex-wrap items-center justify-between gap-4 text-xs text-text-muted">
      <p>© {currentYear} {SITE.legal.legalEntity} · {SITE.address.city}</p>
      <p>{t.chrome.closingNote}</p>
    </div>
  </div>
</footer>

<script>
  // Footer "Manage cookie preferences" → reopen banner
  document.getElementById('footer-manage-cookies')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('consent:reopen'));
  });
</script>
