# Sentry — error tracking (populate before production traffic)
SENTRY_DSN=
SENTRY_PROJECT=
SENTRY_ORG=
SENTRY_AUTH_TOKEN=

# Public site URL — used for canonical + OG tags
PUBLIC_SITE_URL=https://bar-agency.vercel.app

# Resend — transactional email for the contact form
# Create a free account at resend.com, verify a domain (or use their sandbox until then),
# then drop the API key here. Without this set, the contact endpoint returns 503
# with a structured "service temporarily unavailable" — the form still renders
# but submission is gated.
RESEND_API_KEY=
RESEND_FROM=hello@bar-agency.com
NOTIFICATION_EMAIL=breno.ribeirobr@gmail.com

# Google PageSpeed Insights — used by the free /tools/website-scan tool (F3b).
# OPTIONAL: the PSI API works without a key at a low quota; set a key for headroom.
# Get one free at https://developers.google.com/speed/docs/insights/v5/get-started
# The GBP tool (F3a) intentionally uses NO paid Places API — it is a guided
# self-check + lead capture, so there is no key to set for it.
PAGESPEED_API_KEY=
