---
/**
 * Social-media explainer, rendered on /pricing below the tier cards.
 * The per-plan PRICES + post counts now live in the plan cards (the in-card
 * "Add social media" toggle, see PricingTiers). This section is the qualitative
 * explainer the cards' "details" link points at: what we post, on which
 * channels, the extra-channel price, and the honest fine print. Anchor id
 * `social-media`. Content from FUNNEL[locale].pricing.socialAddon.
 */
interface Props {
  data: {
    eyebrow: string;
    heading: string;
    subtitle: string;
    channels: string[];
    additionalNote: string;
    fineprint: string;
  };
}
const { data } = Astro.props;
---

<div id="social-media" class="mt-16 scroll-mt-24">
  <div class="max-w-2xl">
    <p class="text-xs tracking-[0.18em] uppercase text-accent-on-surface font-medium">{data.eyebrow}</p>
    <h2 class="mt-3 font-display text-2xl sm:text-3xl text-text font-semibold tracking-[-0.02em] leading-[1.1]">{data.heading}</h2>
    <p class="mt-3 text-text-muted leading-relaxed">{data.subtitle}</p>
  </div>

  <ul class="mt-6 flex flex-wrap gap-2.5 list-none p-0 m-0 max-w-2xl">
    {data.channels.map((channel) => (
      <li class="inline-flex items-center rounded-full border border-border bg-surface px-4 py-1.5 text-sm text-text">{channel}</li>
    ))}
  </ul>

  <p class="mt-7 max-w-2xl text-sm text-text">
    <span class="text-accent-on-surface font-medium">{data.additionalNote}</span>
  </p>
  <p class="mt-3 max-w-2xl text-xs text-text-muted leading-relaxed">{data.fineprint}</p>
</div>
