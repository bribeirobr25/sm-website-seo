---
/**
 * Social-media add-on block, rendered on /pricing directly below the tier cards.
 * Content is the `socialAddon` block from FUNNEL[locale].pricing (single source of
 * truth). Presentation only — token-driven, no logic. See HANDOVER-SOCIAL-MEDIA-PRICING.
 */
interface Props {
  data: {
    eyebrow: string;
    heading: string;
    subtitle: string;
    rows: { plan: string; price: string; posts: string }[];
    additionalNote: string;
    fineprint: string;
  };
}
const { data } = Astro.props;
---

<div class="mt-16">
  <div class="max-w-2xl">
    <p class="text-xs tracking-[0.18em] uppercase text-accent-on-surface font-medium">{data.eyebrow}</p>
    <h2 class="mt-3 font-display text-2xl sm:text-3xl text-text font-semibold tracking-[-0.02em] leading-[1.1]">{data.heading}</h2>
    <p class="mt-3 text-text-muted leading-relaxed">{data.subtitle}</p>
  </div>

  <div class="mt-8 rounded-[22px] bg-surface border border-border overflow-hidden max-w-2xl">
    <ul class="list-none p-0 m-0 divide-y divide-border">
      {data.rows.map((row) => (
        <li class="flex items-baseline justify-between gap-4 px-5 sm:px-7 py-5">
          <div class="min-w-0">
            <p class="font-display font-semibold text-text">{row.plan}</p>
            <p class="mt-0.5 text-sm text-text-muted">{row.posts}</p>
          </div>
          <p class="shrink-0 font-display font-semibold text-accent-on-surface tabular-nums">{row.price}</p>
        </li>
      ))}
    </ul>
    <p class="px-5 sm:px-7 py-4 text-sm text-text-muted bg-surface-elev border-t border-border">{data.additionalNote}</p>
  </div>

  <p class="mt-5 max-w-2xl text-xs text-text-muted leading-relaxed">{data.fineprint}</p>
</div>
