---
/**
 * PricingTiers (F2), monthly-subscription package cards ("Website-Abo").
 * Prop-driven. Content from FUNNEL[locale].pricing.tiers + .ui. The "popular"
 * tier gets the accent treatment + badge. CTA points at the contact page
 * (ctaHref), no payment is taken on-site. Pure monthly, no setup fee.
 *
 * In-card social-media simulator: each Start/Growth card has an "Add social
 * media" toggle that reveals the combined monthly total (plan + add-on);
 * Complete shows a static "included" line. The total is computed at build time
 * by swapping the number inside the locale-formatted price string, so currency
 * formatting stays locale-correct. Progressive enhancement: no-JS still shows
 * the base price + the add-on figure; the toggle just reveals the total line.
 */
import type { PackageTier } from '@/lib/funnel';

interface SocialRow {
  plan: string;
  price: string;
  posts: string;
}
interface Props {
  tiers: readonly PackageTier[];
  ui: { popular: string };
  ctaHref: string;
  socialAddon: {
    rows: SocialRow[];
    toggleLabel: string;
    totalLabel: string;
    includedLabel: string;
    additionalNote: string;
    detailsLink: string;
  };
}
const { tiers, ui, ctaHref, socialAddon } = Astro.props;
const check = 'M20 6 9 17l-5-5';
const onlyDigits = (s: string): number => Number(s.replace(/[^\d]/g, '')) || 0;
const socialByPlan = new Map(socialAddon.rows.map((r) => [r.plan, r] as const));
---

<div class="grid lg:grid-cols-3 gap-6 items-start">
  {tiers.map((tier) => {
    const socialRow = socialByPlan.get(tier.name);
    const addonAmount = socialRow ? onlyDigits(socialRow.price) : 0;
    const socialIncluded = !!socialRow && addonAmount === 0;
    const totalPrice =
      socialRow && addonAmount > 0
        ? tier.price.replace(/[\d][\d.,]*/, String(onlyDigits(tier.price) + addonAmount))
        : null;
    return (
    <div
      class:list={[
        'reveal-rise relative rounded-[22px] p-8 flex flex-col h-full border',
        tier.popular
          ? 'bg-surface-elev border-accent shadow-elev lg:-mt-2'
          : 'bg-surface-elev border-border',
      ]}
    >
      {tier.popular && (
        <span class="absolute -top-3 left-8 inline-flex items-center rounded-full bg-accent text-white text-xs font-medium px-3 py-1">
          {ui.popular}
        </span>
      )}
      <div>
        <h2 class="font-display text-2xl font-semibold text-text tracking-[-0.02em]">{tier.name}</h2>
        <p class="mt-2 text-sm text-text-muted">{tier.tagline}</p>
      </div>
      <div class="mt-6">
        <p class="flex items-baseline gap-1">
          <span class="font-display text-4xl font-semibold text-text tracking-[-0.03em] tabular">{tier.price}</span>
          <span class="text-base text-text-muted">{tier.priceSuffix}</span>
        </p>
        <p class="mt-1 text-xs text-text-muted">{tier.priceNote}</p>
      </div>

      {socialIncluded ? (
        <p class="social-sim social-sim--included mt-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-on-surface shrink-0" aria-hidden="true"><path d={check}></path></svg>
          <span>{socialAddon.includedLabel}</span>
        </p>
      ) : socialRow ? (
        <div class="social-sim mt-5">
          <label class="social-sim__row">
            <span class="social-sim__lead">
              <input type="checkbox" class="social-sim__toggle" />
              <span>{socialAddon.toggleLabel}</span>
            </span>
            <span class="social-sim__addon tabular">{socialRow.price}</span>
          </label>
          <div class="social-sim__reveal" hidden>
            <p class="social-sim__total" aria-live="polite">
              <span class="social-sim__total-label">{socialAddon.totalLabel}</span>
              <span class="social-sim__total-price tabular">{totalPrice}{tier.priceSuffix}</span>
            </p>
            <p class="social-sim__posts">
              <span>{socialRow.posts}</span>
              <button type="button" class="info-tip" aria-label={socialAddon.additionalNote} aria-expanded="false">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
                <span class="info-tip__bubble" role="tooltip">{socialAddon.additionalNote}</span>
              </button>
            </p>
            <a href="#social-media" class="social-sim__link">{socialAddon.detailsLink}</a>
          </div>
        </div>
      ) : null}

      <ul class="mt-7 space-y-3 list-none p-0 flex-1">
        {tier.features.map((f) => {
          const label = typeof f === 'string' ? f : f.label;
          const note = typeof f === 'string' ? null : f.note;
          return (
            <li class="flex items-start gap-2.5 text-sm text-text leading-relaxed">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-on-surface shrink-0 mt-0.5" aria-hidden="true"><path d={check}></path></svg>
              <span>
                {label}
                {note && (
                  <button type="button" class="info-tip" aria-label={note} aria-expanded="false">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
                    <span class="info-tip__bubble" role="tooltip">{note}</span>
                  </button>
                )}
              </span>
            </li>
          );
        })}
      </ul>
      <a
        href={ctaHref}
        class:list={[
          'mt-8 inline-flex items-center justify-center w-full px-6 py-3 min-h-[48px] rounded-full text-base font-medium transition-colors',
          tier.popular
            ? 'bg-accent text-white hover:bg-accent-deep'
            : 'border border-text-muted/60 text-text hover:border-text-muted hover:bg-surface',
        ]}
      >
        {tier.cta}
      </a>
    </div>
    );
  })}
</div>

<style>
  .info-tip {
    position: relative;
    display: inline-flex;
    vertical-align: -2px;
    margin-left: 4px;
    color: var(--color-text-subtle);
    cursor: help;
    background: none;
    border: 0;
    padding: 2px;
  }
  .info-tip:hover,
  .info-tip:focus-visible {
    color: var(--color-accent-deep);
  }
  .info-tip__bubble {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: max-content;
    max-width: 220px;
    background: var(--color-text);
    color: var(--color-bg);
    font-size: 12px;
    font-weight: 400;
    line-height: 1.45;
    text-align: left;
    padding: 8px 10px;
    border-radius: 10px;
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.18);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s ease;
    z-index: 30;
    pointer-events: none;
  }
  .info-tip:hover .info-tip__bubble,
  .info-tip:focus-within .info-tip__bubble,
  .info-tip[aria-expanded='true'] .info-tip__bubble {
    opacity: 1;
    visibility: visible;
  }

  /* In-card social-media simulator */
  .social-sim {
    border-top: 1px solid var(--color-border);
    padding-top: 16px;
  }
  .social-sim--included {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--color-text-muted);
  }
  .social-sim__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    cursor: pointer;
    font-size: 14px;
    color: var(--color-text);
    user-select: none;
  }
  .social-sim__lead {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .social-sim__addon {
    color: var(--color-accent-on-surface);
    font-weight: 500;
    white-space: nowrap;
  }
  .social-sim__toggle {
    appearance: none;
    -webkit-appearance: none;
    width: 38px;
    height: 22px;
    flex-shrink: 0;
    border-radius: 999px;
    background: var(--color-border);
    position: relative;
    cursor: pointer;
    transition: background 0.18s ease;
  }
  .social-sim__toggle::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.25);
    transition: transform 0.18s ease;
  }
  .social-sim__toggle:checked {
    background: var(--color-accent);
  }
  .social-sim__toggle:checked::after {
    transform: translateX(16px);
  }
  .social-sim__toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .social-sim__total {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-top: 12px;
    font-size: 14px;
    color: var(--color-text-muted);
  }
  .social-sim__reveal[hidden] {
    display: none;
  }
  .social-sim__posts {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 8px;
    font-size: 13px;
    color: var(--color-text-muted);
  }
  .social-sim__posts .info-tip {
    color: var(--color-text-subtle);
    cursor: help;
  }
  .social-sim__link {
    display: inline-block;
    margin-top: 10px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-accent-on-surface);
    text-decoration: none;
  }
  .social-sim__link::after {
    content: ' ↓';
  }
  .social-sim__link:hover {
    text-decoration: underline;
  }
  .social-sim__total-price {
    font-family: var(--font-display, inherit);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .info-tip__bubble,
    .social-sim__toggle,
    .social-sim__toggle::after {
      transition: none;
    }
  }
</style>

<script>
  // ⓘ tooltips: hover/focus via CSS; click/tap toggles for touch devices.
  const tips = document.querySelectorAll('.info-tip');
  tips.forEach((tip) => {
    tip.addEventListener('click', (e) => {
      e.preventDefault();
      const open = tip.getAttribute('aria-expanded') === 'true';
      tips.forEach((t) => t.setAttribute('aria-expanded', 'false'));
      tip.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
  });
  document.addEventListener('click', (e) => {
    if (!(e.target as Element)?.closest?.('.info-tip')) {
      tips.forEach((t) => t.setAttribute('aria-expanded', 'false'));
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') tips.forEach((t) => t.setAttribute('aria-expanded', 'false'));
  });

  // Social-media simulator: toggle reveals the combined-total line.
  document.querySelectorAll<HTMLInputElement>('.social-sim__toggle').forEach((toggle) => {
    toggle.addEventListener('change', () => {
      const reveal = toggle.closest('.social-sim')?.querySelector('.social-sim__reveal');
      reveal?.toggleAttribute('hidden', !toggle.checked);
    });
  });
</script>
