---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import Faq from '@/components/sections/Faq.astro';
import HeroAurora from '@/components/sections/HeroAurora.astro';
import PromiseStrip from '@/components/sections/PromiseStrip.astro';
import ReviewsWall from '@/components/sections/ReviewsWall.astro';
import TrustBadgeRow from '@/components/sections/TrustBadgeRow.astro';
import ContactBar from '@/components/ui/ContactBar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { FUNNEL } from '@/lib/funnel';
import { PAGE_STRINGS } from '@/lib/page-strings';
import { getFeaturedPortfolio } from '@/lib/portfolio';
import { faqPageSchema } from '@/lib/seo/schema';
import { LOCALE_PREFIX, type Locale } from '@/lib/site';
import { heroSrcset } from '@/lib/srcset';

export async function getStaticPaths() {
  return [
    { params: { locale: 'de' }, props: { locale: 'de' as const } },
    { params: { locale: 'pt-br' }, props: { locale: 'pt-br' as const } },
  ];
}

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const p = PAGE_STRINGS[locale].home;
const cat = PAGE_STRINGS[locale].services.catalog;
const t = PAGE_STRINGS[locale];
const prefix = LOCALE_PREFIX[locale];
const featured = getFeaturedPortfolio();
const f = FUNNEL[locale];
const faqSchema = faqPageSchema(f.homeFaq.items);
---

<BaseLayout title={p.title} description={p.description} locale={locale} localePath="/" extraSchema={faqSchema}>
  <Header locale={locale} localePath="/" />
  <main id="main">
    <section class="hero-dark relative overflow-hidden">
      {p.heroImageSrc && (
        <img
          src={p.heroImageSrc}
          srcset={heroSrcset(p.heroImageSrc)}
          sizes="100vw"
          alt={p.heroImageAlt ?? ''}
          width="1920"
          height="823"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="hero-dark__img"
        />
      )}
      <div class="hero-dark__veil" aria-hidden="true"></div>
      <HeroAurora />
      <div class="relative container-page pt-28 pb-24 sm:pt-36 sm:pb-32 lg:pt-44 lg:pb-40 text-center">
        <p class="text-xs sm:text-sm tracking-[0.18em] uppercase text-accent-light font-medium mb-8">{p.heroEyebrow}</p>
        <h1 class="font-display text-[clamp(3rem,8vw,7rem)] font-semibold text-white leading-[1.02] tracking-[-0.04em] max-w-4xl mx-auto">
          {p.heroTitleLines.map((line, i) => <span class="block reveal-rise" style={`animation-delay:${i * 50}ms`}>{line}</span>)}
        </h1>
        <p class="mt-8 max-w-xl mx-auto text-lg sm:text-xl text-white/85 leading-[1.5]">{p.heroSubtitle}</p>
        <div class="mt-12 flex flex-wrap gap-3 justify-center">
          <a href={`${prefix}/contact`} data-magnetic class="inline-flex items-center justify-center px-7 py-3 min-h-[52px] rounded-full bg-accent text-white hover:bg-accent-deep transition-colors text-base font-medium">{t.contact.heroTitle.split(/[.,]/)[0]}</a>
          <a href={`${prefix}/portfolio`} data-magnetic class="inline-flex items-center justify-center px-7 py-3 min-h-[52px] rounded-full border border-white/30 text-white hover:border-white/70 transition-colors text-base font-medium">{p.portfolioAllLink.replace('→', '').trim()} →</a>
        </div>
      </div>
    </section>

    <section class="bg-inverted-surface">
      <div class="container-page py-16 sm:py-20">
        <p class="text-center text-xs tracking-[0.18em] uppercase text-accent-light font-medium mb-10">{p.statTitle}</p>
        <dl class="grid grid-cols-3 gap-6 max-w-3xl mx-auto text-center">
          <div>
            <dt class="font-display text-5xl sm:text-6xl text-inverted-text font-semibold tabular tracking-[-0.04em]">{p.statLine1}</dt>
            <dd class="mt-2 text-sm text-inverted-text-muted">{p.statLabel1}</dd>
          </div>
          <div>
            <dt class="font-display text-5xl sm:text-6xl text-inverted-text font-semibold tabular tracking-[-0.04em]">{p.statLine2}</dt>
            <dd class="mt-2 text-sm text-inverted-text-muted">{p.statLabel2}</dd>
          </div>
          <div>
            <dt class="font-display text-5xl sm:text-6xl text-inverted-text font-semibold tabular tracking-[-0.04em]">{p.statLine3}</dt>
            <dd class="mt-2 text-sm text-inverted-text-muted">{p.statLabel3}</dd>
          </div>
        </dl>
      </div>
    </section>

    <PromiseStrip eyebrow={f.promises.eyebrow} title={f.promises.title} note={f.promises.note} items={f.promises.items} />

    <section class="section bg-bg" aria-labelledby="services-heading">
      <div class="container-page">
        <div class="max-w-3xl mb-14">
          <p class="text-xs tracking-[0.18em] uppercase text-accent-on-surface font-medium">{p.servicesEyebrow}</p>
          <h2 id="services-heading" class="mt-4 font-display text-3xl sm:text-5xl lg:text-6xl text-text font-semibold tracking-[-0.03em] leading-[1.05]">{p.servicesHeading}</h2>
          <p class="mt-6 text-lg text-text-muted leading-[1.5] max-w-2xl">{p.servicesBody}</p>
        </div>
        <div class="grid sm:grid-cols-2 gap-5">
          {cat.map((c, i) => {
            const Card = c.href ? 'a' : 'div';
            return (
              <Card href={c.href ? `${prefix}${c.href}` : undefined} class="svc-card-photo group reveal-rise relative overflow-hidden rounded-[22px] min-h-[340px] sm:min-h-[380px] flex flex-col justify-between p-8 sm:p-10" style={`animation-delay:${i * 50}ms`}>
                <img
                  src={c.imgSrc}
                  srcset={heroSrcset(c.imgSrc)}
                  sizes="(max-width: 640px) 100vw, 50vw"
                  alt=""
                  aria-hidden="true"
                  width="1600"
                  height="900"
                  loading="lazy"
                  decoding="async"
                  class="svc-card-photo__img"
                />
                <div class="svc-card-photo__veil" aria-hidden="true"></div>
                <div class="svc-card-photo__glow" aria-hidden="true"></div>
                <div class="relative">
                  <h3 class="font-display text-2xl sm:text-3xl font-semibold tracking-[-0.02em] text-white">{c.name}</h3>
                  <p class="mt-3 text-sm leading-relaxed max-w-md text-white/85">{c.tagline}</p>
                </div>
                {c.linkLabel && (
                  <p class="relative mt-8 text-sm font-medium text-white group-hover:translate-x-1 transition-transform">{c.linkLabel}</p>
                )}
              </Card>
            );
          })}
        </div>
      </div>
    </section>

    <section class="section bg-surface" aria-labelledby="portfolio-heading">
      <div class="container-page">
        <div class="flex flex-wrap items-end justify-between gap-6 mb-12">
          <div class="max-w-xl min-w-0">
            <p class="text-xs tracking-[0.18em] uppercase text-accent-on-surface font-medium">{p.portfolioEyebrow}</p>
            <h2 id="portfolio-heading" class="mt-4 font-display text-3xl sm:text-5xl lg:text-6xl text-text font-semibold tracking-[-0.03em] leading-[1.05]">{p.portfolioHeading}</h2>
          </div>
          <a href={`${prefix}/portfolio`} class="text-sm text-text-muted hover:text-text transition-colors underline underline-offset-4">{p.portfolioAllLink}</a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featured.map((entry, i) => (
            <a href={`${prefix}/portfolio/${entry.slug}`} class="group reveal-rise block rounded-[22px] overflow-hidden bg-surface-elev border border-border hover:border-text/30 transition-colors" style={`animation-delay:${i * 50}ms`}>
              <div class="aspect-[16/10] overflow-hidden bg-surface">
                <img src={entry.imageSrc} alt={entry.imageAlt[locale]} loading="lazy" decoding="async" width="1600" height="1000" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-[var(--motion-warm)]" />
              </div>
              <div class="p-6">
                <p class="text-[11px] tracking-[0.12em] uppercase text-text-muted font-medium">{entry.vertical}</p>
                <p class="mt-2 font-display text-xl font-semibold text-text tracking-[-0.01em]">{entry.name}</p>
                <p class="mt-2 text-sm text-text-muted line-clamp-2">{entry.shortDescription[locale]}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <ReviewsWall eyebrow={f.reviews.eyebrow} title={f.reviews.title} body={f.reviews.body} draftNote={f.reviews.draftNote} items={f.reviews.items} />
    <TrustBadgeRow eyebrow={f.trustBadges.eyebrow} items={f.trustBadges.items} />

    <section class="section bg-bg" aria-labelledby="about-heading">
      <div class="container-page">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          {p.aboutImageSrc ? (
            <figure class="order-2 lg:order-1">
              <div class="aspect-[4/5] sm:aspect-[3/4] lg:aspect-[4/5] overflow-hidden rounded-[22px] bg-surface">
                <img
                  src={p.aboutImageSrc}
                  srcset={heroSrcset(p.aboutImageSrc)}
                  sizes="(max-width: 1024px) 100vw, 50vw"
                  alt={p.aboutImageAlt ?? ''}
                  width="1920"
                  height="2400"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
              </div>
            </figure>
          ) : (
            <div class="hidden lg:block"></div>
          )}
          <div class="order-1 lg:order-2">
            <p class="text-xs tracking-[0.18em] uppercase text-accent-on-surface font-medium">{p.aboutEyebrow}</p>
            <h2 id="about-heading" class="mt-4 font-display text-3xl sm:text-5xl text-text font-semibold tracking-[-0.03em] leading-[1.05]">{p.aboutHeading}</h2>
            <div class="mt-8 space-y-6 text-lg text-text-muted leading-[1.6]">
              {p.aboutBody.map((para) => <p>{para}</p>)}
              <p class="pt-2"><a href={`${prefix}/about`} class="text-text font-medium underline underline-offset-4 hover:text-accent-on-surface transition-colors">{p.aboutReadMore}</a></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Faq eyebrow={f.homeFaq.eyebrow} title={f.homeFaq.title} items={f.homeFaq.items} surface={true} />

    <section class="bg-inverted-bg text-inverted-text">
      <div class="container-page py-24 sm:py-32 text-center">
        <p class="text-xs tracking-[0.18em] uppercase text-accent-light font-medium mb-6">{p.ctaEyebrow}</p>
        <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl font-semibold tracking-[-0.03em] leading-[1.05] max-w-2xl mx-auto">{p.ctaHeading}</h2>
        <p class="mt-6 text-lg text-inverted-text-muted leading-[1.5] max-w-xl mx-auto">{p.ctaBody}</p>
        <div class="mt-10">
          <a href={`${prefix}/contact`} class="inline-flex items-center justify-center px-7 py-3 min-h-[52px] rounded-full bg-accent text-white hover:bg-accent-deep transition-colors text-base font-medium">{t.contact.heroTitle.split(/[.,]/)[0]}</a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
  <ContactBar locale={locale} />
</BaseLayout>
