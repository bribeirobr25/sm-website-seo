---
/**
 * Hidden contract form, fill in browser, then Cmd/Ctrl+P → save as PDF or print A4.
 *
 * Not linked anywhere public. `Disallow: /contract` in robots.txt + `noindex`
 * via BaseLayout default. EN root version; DE at /de/contract.
 *
 * Design follows agency Apple-clean register:
 *   - Sticky toolbar (print button always reachable)
 *   - 44 px+ touch targets on every input (ACCESSIBILITY.md §6)
 *   - 15 px body floor on rendered contract (legal-readability baseline)
 *   - localStorage auto-save (form survives page refresh during a meeting)
 *   - Print CSS hides form chrome + agency header/footer; renders contract only
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CONTRACT_STRINGS } from '@/lib/contract-strings';
import { FUNNEL } from '@/lib/funnel';
import { SIGNATURE_SVG } from '@/lib/signature';
import { SITE } from '@/lib/site';

const locale = 'en' as const;
const c = CONTRACT_STRINGS[locale];

// The /pricing tiers are the SINGLE SOURCE OF TRUTH for what each plan includes.
// §2 mirrors the selected plan's /pricing feature list exactly (incl. its
// "Everything in X, plus:" line), so the contract can never drift from pricing.
const BUYOUT_MONTHS = 18;
const featText = (f: string | { label: string; note: string }): string =>
  typeof f === 'string' ? f : f.label;
const plans = FUNNEL[locale].pricing.tiers.map((t) => ({
  id: t.id,
  code: t.id.charAt(0).toUpperCase(),
  name: t.name,
  priceLabel: `${t.price}${t.priceSuffix ?? ''}`,
  priceNum: Number(t.price.replace(/[^0-9.]/g, '')),
  features: t.features.map(featText),
}));
const addons = FUNNEL[locale].pricing.addons;
const billing = FUNNEL[locale].pricing.billing;

const agencyAddressLine = [
  SITE.address.street,
  [SITE.address.postalCode, SITE.address.city].filter(Boolean).join(' '),
  SITE.address.neighborhood,
]
  .filter(Boolean)
  .join(', ');
const taxId: string = SITE.legal.taxId;
const taxIdDisplay = SITE.legal.kleinunternehmer
  ? 'USt-IdNr: Kleinunternehmer § 19 UStG'
  : !taxId || taxId.startsWith('TODO')
    ? 'USt-IdNr: pending'
    : `USt-IdNr: ${taxId}`;
---

<BaseLayout
  title="Website Subscription Agreement, internal"
  description="Hidden contract template. Not for public consumption."
  locale={locale}
  noindex={true}
>
  <main id="main" class="bg-bg min-h-screen">
    {/* STICKY TOOLBAR, visible on screen, hidden in print */}
    <div class="no-print sticky top-0 z-20 bg-bg/90 backdrop-blur-xl border-b border-border">
      <div class="container-page py-3 sm:py-4 flex items-center justify-between gap-3">
        <div class="min-w-0 flex-1">
          <p class="text-[10px] sm:text-xs tracking-[0.18em] uppercase text-text-muted font-medium">Internal</p>
          <p class="font-display text-base sm:text-xl font-semibold text-text leading-tight truncate">Website Subscription Agreement</p>
        </div>
        <div class="flex items-center gap-2 sm:gap-3 shrink-0">
          <span id="save-pill" class="hidden md:inline-flex items-center gap-1.5 text-xs text-text-muted px-3 py-1.5 rounded-full bg-surface border border-border" aria-live="polite">
            <span id="save-indicator" style="color: var(--color-success);" aria-hidden="true">●</span>
            <span id="save-text">Saved</span>
          </span>
          <button
            type="button"
            id="toggle-form-btn"
            class="inline-flex items-center justify-center px-3 sm:px-4 py-2 min-h-[44px] rounded-full border border-border text-text hover:border-text transition-colors text-sm font-medium"
            aria-pressed="false"
            aria-controls="form-panel"
          >
            <span data-show-text>Hide form</span>
          </button>
          <button
            type="button"
            id="print-btn"
            class="inline-flex items-center justify-center px-3 sm:px-5 py-2 min-h-[44px] rounded-full bg-text text-bg hover:bg-accent-deep transition-colors text-sm font-medium"
            aria-label={c.printButton}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="sm:mr-2" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
            <span class="hidden sm:inline">{c.printButton}</span>
          </button>
        </div>
      </div>
    </div>

    {/* FORM PANEL */}
    <section id="form-panel" class="no-print bg-surface border-b border-border">
      <div class="container-page py-10 sm:py-14 max-w-4xl">
        <p class="text-sm text-text-muted leading-relaxed">{c.formIntro}</p>

        <form id="contract-form" class="mt-8 sm:mt-10">
          {/* STEP 1, CLIENT */}
          <fieldset class="form-step">
            <legend class="form-step__legend">
              <span class="form-step__num" aria-hidden="true">1</span>
              <span class="form-step__title">{c.partiesLabel}</span>
            </legend>
            <div class="form-step__body space-y-5">
              <div class="grid sm:grid-cols-[1fr_2fr] gap-4">
                <label class="block">
                  <span class="form-label">{c.clientLegalForm}</span>
                  <select name="client_legal_form" class="ag-input">
                    <option value="GbR">GbR</option>
                    <option value="UG (haftungsbeschränkt)">UG (haftungsbeschränkt)</option>
                    <option value="GmbH">GmbH</option>
                    <option value="e.K.">e.K.</option>
                    <option value="Einzelunternehmer">Einzelunternehmer</option>
                    <option value="Freiberufler">Freiberufler</option>
                    <option value="other">other</option>
                  </select>
                </label>
                <label class="block">
                  <span class="form-label">{c.clientBusinessName}</span>
                  <input type="text" name="client_business_name" class="ag-input" autocomplete="organization" />
                </label>
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <label class="block">
                  <span class="form-label">{c.clientRepresentative}</span>
                  <input type="text" name="client_representative" class="ag-input" autocomplete="name" />
                </label>
                <label class="block">
                  <span class="form-label">{c.clientRepresentativeRole}</span>
                  <input type="text" name="client_representative_role" placeholder="Geschäftsführer / Inhaber / …" class="ag-input" />
                </label>
              </div>

              <div>
                <label class="block">
                  <span class="form-label">{c.clientStreet}</span>
                  <input type="text" name="client_street" class="ag-input" autocomplete="street-address" />
                </label>
                <div class="grid grid-cols-[1fr_2fr] gap-4 mt-4">
                  <label class="block">
                    <span class="form-label">{c.clientPostalCode}</span>
                    <input type="text" name="client_postal_code" class="ag-input tabular" autocomplete="postal-code" inputmode="numeric" />
                  </label>
                  <label class="block">
                    <span class="form-label">{c.clientCity}</span>
                    <input type="text" name="client_city" placeholder="Berlin" class="ag-input" autocomplete="address-level2" />
                  </label>
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <label class="block">
                  <span class="form-label">{c.clientEmail}</span>
                  <input type="email" name="client_email" class="ag-input" autocomplete="email" />
                </label>
                <label class="block">
                  <span class="form-label">{c.clientPhone}</span>
                  <input type="tel" name="client_phone" class="ag-input tabular" autocomplete="tel" />
                </label>
              </div>

              <label class="block">
                <span class="form-label">{c.clientUstId} <span class="form-label__hint">(optional)</span></span>
                <input type="text" name="client_ust_idnr" placeholder="DE…" class="ag-input tabular" />
                <span class="form-hint">{c.clientUstHint}</span>
              </label>
            </div>
          </fieldset>

          {/* STEP 2, PLAN */}
          <fieldset class="form-step">
            <legend class="form-step__legend">
              <span class="form-step__num" aria-hidden="true">2</span>
              <span class="form-step__title">{c.planLabel}</span>
            </legend>
            <div class="form-step__body space-y-4">
              <p class="text-sm text-text-muted leading-relaxed">{c.planHint}</p>
              <div role="radiogroup" aria-label={c.planLabel} class="grid sm:grid-cols-3 gap-3">
                {plans.map((p) => (
                  <label class="vat-card">
                    <input type="radio" name="plan" value={p.id} class="vat-card__input" />
                    <span class="vat-card__label"><strong>{p.name}</strong> · {p.priceLabel}</span>
                  </label>
                ))}
              </div>
            </div>
          </fieldset>

          {/* STEP 3, PRICING */}
          <fieldset class="form-step">
            <legend class="form-step__legend">
              <span class="form-step__num" aria-hidden="true">3</span>
              <span class="form-step__title">{c.pricingLabel}</span>
            </legend>
            <div class="form-step__body space-y-5">
              <div>
                <span class="form-label" id="billing-label">{c.billingLabel}</span>
                <div role="radiogroup" aria-labelledby="billing-label" class="grid sm:grid-cols-2 gap-3">
                  <label class="vat-card">
                    <input type="radio" name="billing_cycle" value="monthly" checked class="vat-card__input" />
                    <span class="vat-card__label">{c.billingMonthly}</span>
                  </label>
                  <label class="vat-card">
                    <input type="radio" name="billing_cycle" value="yearly" class="vat-card__input" />
                    <span class="vat-card__label">{c.billingYearly}</span>
                  </label>
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <label class="block">
                  <span class="form-label">{c.addonLanguages}</span>
                  <input type="number" name="addon_languages" min="0" step="1" value="0" class="ag-input tabular" inputmode="numeric" />
                </label>
                <label class="block">
                  <span class="form-label">{c.addonMailboxes}</span>
                  <input type="number" name="addon_mailboxes" min="0" step="1" value="0" class="ag-input tabular" inputmode="numeric" />
                </label>
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <label class="vat-card" style="align-items:center;">
                  <input type="checkbox" name="addon_social_enabled" class="vat-card__input" />
                  <span class="vat-card__label">{c.addonSocial}</span>
                </label>
                <label class="block">
                  <span class="form-label">{c.addonSocialChannels}</span>
                  <input type="number" name="addon_social_extra_channels" min="0" step="1" value="0" class="ag-input tabular" inputmode="numeric" />
                </label>
              </div>

              <label class="block sm:max-w-xs">
                <span class="form-label">{c.retainerFee}</span>
                <div class="ag-input-currency">
                  <span class="ag-input-currency__symbol" aria-hidden="true">€</span>
                  <input type="number" name="price_retainer" readonly class="ag-input ag-input--currency tabular" />
                </div>
                <span class="form-hint out-retainer-hint">{c.retainerFeeHint}</span>
              </label>

              <div>
                <span class="form-label" id="vat-label">{c.vatLabel}</span>
                <div role="radiogroup" aria-labelledby="vat-label" class="grid sm:grid-cols-2 gap-3">
                  <label class="vat-card">
                    <input type="radio" name="vat_status" value="kleinunternehmer" checked class="vat-card__input" />
                    <span class="vat-card__label">{c.vatKleinunternehmer}</span>
                  </label>
                  <label class="vat-card">
                    <input type="radio" name="vat_status" value="regular" class="vat-card__input" />
                    <span class="vat-card__label">{c.vatRegular}</span>
                  </label>
                </div>
              </div>
            </div>
          </fieldset>

          {/* STEP 4, DATES */}
          <fieldset class="form-step">
            <legend class="form-step__legend">
              <span class="form-step__num" aria-hidden="true">4</span>
              <span class="form-step__title">{c.datesLabel}</span>
            </legend>
            <div class="form-step__body">
              <div class="grid sm:grid-cols-2 gap-4">
                <label class="block">
                  <span class="form-label">{c.signatureDate}</span>
                  <input type="date" name="date_signature" class="ag-input tabular" />
                </label>
                <label class="block">
                  <span class="form-label">{c.startDate}</span>
                  <input type="date" name="date_start" class="ag-input tabular" />
                  <span class="form-hint">{c.s4StartNote}</span>
                </label>
              </div>
            </div>
          </fieldset>
        </form>
      </div>
    </section>

    {/* PREVIEW DIVIDER */}
    <div class="no-print bg-bg border-y border-border">
      <div class="container-page py-6 max-w-3xl flex items-center gap-4">
        <div class="h-px flex-1 bg-border"></div>
        <p class="text-xs tracking-[0.18em] uppercase text-text-muted font-medium shrink-0">Contract preview</p>
        <div class="h-px flex-1 bg-border"></div>
      </div>
    </div>

    {/* RENDERED CONTRACT, the only thing that prints */}
    <section class="contract-doc bg-bg">
      <article class="container-page py-12 sm:py-16 max-w-3xl text-text">
        <header class="mb-14 border-b border-border pb-10">
          <p class="text-xs tracking-[0.18em] uppercase text-text-muted font-medium">{c.contractSubtitle}</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl font-semibold tracking-[-0.025em] leading-[1.05]">{c.contractTitleH1}</h1>
          <p class="mt-3 text-[13px] text-text-muted tabular">{c.contractNoLabel}: <span class="out-contract-no" style="font-weight:600;">…</span></p>

          <div class="mt-12 grid sm:grid-cols-2 gap-10 sm:gap-12">
            <div class="space-y-1.5">
              <p class="text-[11px] uppercase tracking-[0.15em] text-text-muted font-semibold pb-2">{c.agencyHeading}</p>
              <p class="text-[15px] font-semibold text-text">{SITE.legal.legalEntity}</p>
              <p class="text-[14px] text-text-muted leading-relaxed">{agencyAddressLine}</p>
              <p class="text-[14px] text-text-muted">{SITE.email}</p>
              <p class="text-[14px] text-text-muted tabular">{taxIdDisplay}</p>
              <p class="text-xs text-text-muted pt-2">{c.representedBy}: {SITE.founder}</p>
            </div>
            <div class="space-y-1.5">
              <p class="text-[11px] uppercase tracking-[0.15em] text-text-muted font-semibold pb-2">{c.clientHeading}</p>
              <p class="text-[15px] font-semibold text-text"><span class="out-client-business-name">…</span> <span class="text-text-muted font-normal">(<span class="out-client-legal-form">, </span>)</span></p>
              <p class="text-[14px] text-text-muted"><span class="out-client-street">…</span></p>
              <p class="text-[14px] text-text-muted"><span class="out-client-postal-code">…</span> <span class="out-client-city">Berlin</span></p>
              <p class="text-[14px] text-text-muted out-client-email">…</p>
              <p class="text-[14px] text-text-muted tabular out-client-phone-row">{c.clientPhone}: <span class="out-client-phone">…</span></p>
              <p class="text-[14px] text-text-muted tabular">USt-IdNr: <span class="out-client-ust-idnr">, </span></p>
              <p class="text-xs text-text-muted pt-2">{c.representedBy}: <span class="out-client-representative">…</span> (<span class="out-client-representative-role">…</span>)</p>
            </div>
          </div>
        </header>

        <div class="contract-summary mb-12 rounded-[14px] border border-border bg-surface p-6 sm:p-8">
          <p class="text-[11px] uppercase tracking-[0.15em] text-text-muted font-semibold mb-3">{c.plainSummaryLabel}</p>
          <p class="contract-p">{c.plainSummary}</p>
        </div>

        <div class="space-y-10 contract-body">
          <section class="contract-clause">
            <h2 class="contract-h2">{c.s1Heading}</h2>
            <p class="contract-p">{c.s1Body}</p>
          </section>

          <section class="contract-clause">
            <h2 class="contract-h2">{c.s2Heading}</h2>
            <p class="contract-p mb-3">{c.s2Intro}</p>
            <p class="out-plan-line contract-p mb-3" style="font-weight:600;display:none;"></p>
            <ul id="services-rendered" class="contract-list">
              <li class="out-no-services contract-p italic text-text-muted">{c.s2NoServicesSelected}</li>
            </ul>
          </section>

          <section class="contract-clause">
            <h2 class="contract-h2">{c.s3Heading}</h2>
            <ul class="contract-list">
              <li class="out-build-line">, </li>
              <li class="out-retainer-line">, </li>
              <li class="out-yearly-line" style="display:none;">, </li>
              <li>{c.s3PaymentTerms}</li>
              <li class="out-vat-line">, </li>
            </ul>
            <div class="contract-payment" style="margin-top:10px;">
              <p class="contract-p" style="font-weight:600;margin:0 0 2px 0;">{c.s3PaymentHeading}</p>
              <p class="contract-p" style="margin:0;">{c.s3PaymentReceiver}: {SITE.payment.receiver}</p>
              <p class="contract-p" style="font-weight:600;margin:8px 0 2px 0;">{c.s3PayChooseOne}</p>
              <p class="contract-p" style="margin:0;"><strong>{c.s3PaymentBank}:</strong> IBAN {SITE.payment.iban}<br />BIC {SITE.payment.bic} · {SITE.payment.bankName},<br />{SITE.payment.bankAddressStreet},<br />{SITE.payment.bankAddressCity}</p>
              <p class="contract-p" style="margin:1px 0;color:var(--color-text-subtle);font-weight:600;">{c.s3PayOr}</p>
              <p class="contract-p" style="margin:0;"><strong>PayPal:</strong> {SITE.payment.paypal}</p>
              <p class="contract-p" style="margin:8px 0 0 0;"><strong>{c.s3PaymentReference}:</strong> <span class="out-contract-no tabular" style="font-weight:600;">…</span></p>
              <p class="contract-p" style="margin:0;"><strong>{c.s3PaymentSender}:</strong> <span class="out-client-business-name">…</span></p>
              <p class="contract-p out-reference-note" style="margin:4px 0 0 0;font-size:13px;color:var(--color-text-subtle);">, </p>
            </div>
          </section>

          <section class="contract-clause">
            <h2 class="contract-h2">{c.s4Heading}</h2>
            <ul class="contract-list">
              <li class="out-start-line">, </li>
              <li class="out-term-line">{c.s4MinimumTerm}</li>
              <li>{c.s4Notice}</li>
              <li>{c.s4ImmediateTermination}</li>
              <li>{c.s4HandoverObligation}</li>
            </ul>
          </section>

          <section class="contract-clause">
            <h2 class="contract-h2">{c.s5Heading}</h2>
            <p class="contract-p">{c.s5ClientOwns}</p>
            <p class="contract-p mt-3">{c.s5AgencyKeeps}</p>
          </section>

          <section class="contract-clause">
            <h2 class="contract-h2">{c.s6Heading}</h2>
            <ul class="contract-list">
              <li>{c.s6LiabilityCap}</li>
              <li>{c.s6LiabilityExclusions}</li>
              <li>{c.s6Indemnification}</li>
            </ul>
          </section>

          <section class="contract-clause">
            <h2 class="contract-h2">{c.s7Heading}</h2>
            <p class="contract-p">{c.s7DataAvv}</p>
            <p class="contract-p mt-3">{c.s7Confidentiality}</p>
          </section>

          <section class="contract-clause">
            <h2 class="contract-h2">{c.s8Heading}</h2>
            <ul class="contract-list">
              <li>{c.s8Jurisdiction}</li>
              <li>{c.s8WrittenForm}</li>
              <li>{c.s8Severability}</li>
              <li>{c.s8LanguageBindingEn}</li>
            </ul>
          </section>
        </div>

        <section class="mt-20 pt-10 border-t-2 border-text contract-signatures">
          <h2 class="font-display text-xl font-semibold mb-10 tracking-[-0.01em]">{c.signaturesHeading}</h2>
          <div class="grid sm:grid-cols-2 gap-12 sm:gap-16">
            <div>
              <p class="text-[11px] uppercase tracking-[0.15em] text-text-muted font-semibold mb-3">{c.agencyHeading}</p>
              <p class="text-[14px] font-medium text-text leading-relaxed">{SITE.founder}</p>
              <p class="text-[13px] text-text-muted leading-relaxed">{SITE.legal.legalEntity}</p>
              <div class="sig-fill"><span>Berlin, <span class="out-sig-date">…</span></span></div>
              <div class="sig-line" style="margin-top:0;"><span class="sig-label">{c.signaturePlace}, {c.signatureDateLabel}</span></div>
              <div class="sig-fill" set:html={SIGNATURE_SVG}></div>
              <div class="sig-line" style="margin-top:0;"><span class="sig-label">{c.signatureLineLabel}</span></div>
              <p class="sig-specimen">{c.signatureSpecimenNote}</p>
            </div>
            <div>
              <p class="text-[11px] uppercase tracking-[0.15em] text-text-muted font-semibold mb-3">{c.clientHeading}</p>
              <p class="text-[14px] font-medium text-text leading-relaxed"><span class="out-client-representative">…</span></p>
              <p class="text-[13px] text-text-muted leading-relaxed"><span class="out-client-business-name">…</span></p>
              <div class="sig-line"><span class="sig-label">{c.signaturePlace}, {c.signatureDateLabel}</span></div>
              <div class="sig-line"><span class="sig-label">{c.signatureLineLabel}</span></div>
            </div>
          </div>
        </section>

        <footer class="mt-16 pt-6 border-t border-border text-xs text-text-muted text-center">
          {c.footerNote}
        </footer>
      </article>
    </section>
  </main>

  <style is:global>
    /* Form step containers, numbered cards with separator */
    .form-step { margin: 0; padding: 0; border: 0; min-width: 0; }
    .form-step + .form-step { margin-top: 2.5rem; padding-top: 2.5rem; border-top: 1px solid var(--color-border); }
    .form-step__legend { display: flex; align-items: center; gap: 0.75rem; margin: 0 0 1.5rem 0; padding: 0; }
    .form-step__num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 28px; height: 28px; border-radius: 9999px;
      background: var(--color-text); color: var(--color-bg);
      font-size: 13px; font-weight: 600;
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
    }
    .form-step__title {
      font-family: var(--font-display);
      font-size: 1.25rem; /* 20px */
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--color-text);
      line-height: 1.2;
    }
    .form-step__body { min-width: 0; }

    /* Form labels, small uppercase eyebrows */
    .form-label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-text-subtle);
      margin-bottom: 0.5rem;
    }
    .form-label--mini { font-size: 10px; margin-bottom: 0.375rem; }
    .form-label__hint {
      font-weight: 500;
      text-transform: none;
      letter-spacing: 0;
      color: var(--color-text-subtle);
      font-size: 11px;
    }
    .form-hint {
      display: block;
      font-size: 12px;
      line-height: 1.45;
      color: var(--color-text-subtle);
      margin-top: 0.5rem;
    }

    /* Inputs */
    .ag-input {
      display: block;
      width: 100%;
      min-height: 44px;
      padding: 10px 14px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      background-color: var(--color-bg);
      color: var(--color-text);
      font-size: 15px;
      line-height: 1.45;
      transition: border-color var(--motion-fast) var(--ease-apple-smooth),
                  box-shadow var(--motion-fast) var(--ease-apple-smooth);
    }
    .ag-input:hover { border-color: color-mix(in oklab, var(--color-text), transparent 60%); }
    .ag-input:focus-visible {
      outline: none;
      border-color: var(--color-accent);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-accent), transparent 80%);
    }
    textarea.ag-input { min-height: 96px; font-family: var(--font-body); }

    /* Currency-prefix input wrapper */
    .ag-input-currency { position: relative; }
    .ag-input-currency__symbol {
      position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
      color: var(--color-text-subtle); font-size: 15px;
      pointer-events: none;
    }
    .ag-input--currency { padding-left: 30px; }

    /* Service cards, compact, scope hidden until checked */
    .svc-card {
      border: 1px solid var(--color-border);
      border-radius: 14px;
      background: var(--color-bg);
      overflow: hidden;
      transition: border-color var(--motion-fast) var(--ease-apple-smooth),
                  box-shadow var(--motion-fast) var(--ease-apple-smooth);
    }
    .svc-card:has(input[type="checkbox"]:checked) {
      border-color: color-mix(in oklab, var(--color-accent), transparent 50%);
      box-shadow: 0 0 0 1px color-mix(in oklab, var(--color-accent), transparent 60%);
    }
    .svc-card__head {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 12px 16px;
      min-height: 56px;
      cursor: pointer;
      transition: background var(--motion-fast) var(--ease-apple-smooth);
    }
    .svc-card__head:hover { background: var(--color-surface); }
    .svc-card__name {
      font-size: 14px; font-weight: 500;
      color: var(--color-text);
      line-height: 1.35;
    }
    .svc-card__scope {
      display: none;
      border-top: 1px solid var(--color-border);
      background: var(--color-surface);
      padding: 12px 16px 14px;
    }
    .svc-card:has(input[type="checkbox"]:checked) .svc-card__scope { display: block; }

    /* VAT radio cards, compact 2-up */
    .vat-card {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 12px 16px;
      min-height: 56px;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      background: var(--color-bg);
      cursor: pointer;
      transition: border-color var(--motion-fast) var(--ease-apple-smooth),
                  background var(--motion-fast) var(--ease-apple-smooth);
    }
    .vat-card:hover { background: var(--color-surface); }
    .vat-card:has(input:checked) {
      border-color: var(--color-text);
      background: var(--color-bg);
    }
    .vat-card:focus-within {
      outline: 2px solid var(--color-accent);
      outline-offset: 2px;
    }
    .vat-card__input {
      width: 18px; height: 18px;
      accent-color: var(--color-accent);
      flex-shrink: 0;
    }
    .vat-card__label {
      font-size: 14px;
      color: var(--color-text);
      line-height: 1.4;
    }

    .contract-body { color: var(--color-text); }
    .contract-h2 {
      font-family: var(--font-display);
      font-size: 1.125rem;
      font-weight: 600;
      letter-spacing: -0.005em;
      margin: 0 0 0.75rem 0;
    }
    .contract-p { font-size: 15px; line-height: 1.65; color: var(--color-text); }
    .contract-list { list-style: disc; padding-left: 1.25rem; margin: 0; }
    .contract-list > li {
      font-size: 15px;
      line-height: 1.65;
      color: var(--color-text);
      margin-bottom: 0.625rem;
    }
    .contract-list > li:last-child { margin-bottom: 0; }

    .sig-line {
      margin-top: 3rem;
      padding-top: 0.25rem;
      border-top: 1px solid var(--color-text);
    }
    .sig-label {
      font-size: 11px;
      color: var(--color-text-subtle);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .sig-fill {
      display: flex;
      align-items: flex-end;
      min-height: 2.6rem;
      padding-bottom: 0.25rem;
      color: var(--color-text);
      font-size: 14px;
    }
    .sig-fill svg { width: 132px; height: auto; }
    .sig-specimen {
      margin-top: 0.5rem;
      font-size: 10px;
      font-style: italic;
      color: var(--color-text-subtle);
      line-height: 1.4;
    }
    .tabular { font-variant-numeric: tabular-nums; }

    @media print {
      .no-print { display: none !important; }
      #cookie-banner { display: none !important; }
      body { background: white; }
      body > header, body > footer { display: none !important; }
      .contract-doc { padding-top: 0 !important; }
      .container-page { max-width: none !important; padding-inline: 0 !important; }
      article {
        font-size: 11pt;
        line-height: 1.5;
        color: black !important;
      }
      .contract-h2 { font-size: 12pt; margin-top: 14pt; }
      .contract-p, .contract-list > li { font-size: 10.5pt; line-height: 1.55; }
      h1 { font-size: 22pt; }
      .contract-clause { break-inside: avoid; page-break-inside: avoid; }
      .contract-signatures { break-inside: avoid; page-break-inside: avoid; }
    }
    @page { size: A4; margin: 1.8cm 1.6cm; }

    .contract-doc { background: white; }
    .contract-doc article { background: white; }
  </style>

  <script is:inline define:vars={{ locale, strings: CONTRACT_STRINGS[locale], plans, buyoutMonths: BUYOUT_MONTHS, addons, billing }}>
    const form = document.getElementById('contract-form');
    const formPanel = document.getElementById('form-panel');
    const toggleBtn = document.getElementById('toggle-form-btn');
    const printBtn = document.getElementById('print-btn');
    const saveIndicator = document.getElementById('save-indicator');

    const STORAGE_KEY = `contract-form-${locale}`;
    // Local-date YYYY-MM-DD (avoids the UTC off-by-one that toISOString causes in +HH zones).
    function ymd(d) {
      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    }
    const today = ymd(new Date());

    let saved = {};
    try { saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch {}

    Array.from(form.elements).forEach((el) => {
      if (!el.name) return;
      if (el.type === 'radio') {
        if (saved[el.name] !== undefined) el.checked = (el.value === saved[el.name]);
      } else if (el.type === 'checkbox') {
        if (saved[el.name] !== undefined) el.checked = !!saved[el.name];
      } else if (saved[el.name] !== undefined && saved[el.name] !== '') {
        el.value = saved[el.name];
      }
    });
    function addDays(dateStr, n) {
      const d = new Date((dateStr || today) + 'T00:00:00');
      if (isNaN(d.getTime())) return '';
      d.setDate(d.getDate() + n);
      return ymd(d);
    }
    const sigEl = form.querySelector('[name=date_signature]');
    const startEl = form.querySelector('[name=date_start]');
    if (!saved.date_signature) sigEl.value = today;
    // Project start defaults to 5 days after the signature date.
    if (!saved.date_start) startEl.value = addDays(sigEl.value, 5);

    function persist() {
      const data = {};
      Array.from(form.elements).forEach((el) => {
        if (!el.name) return;
        if (el.type === 'checkbox') data[el.name] = el.checked;
        else if (el.type === 'radio') { if (el.checked) data[el.name] = el.value; }
        else data[el.name] = el.value;
      });
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch {}
      flashSave();
    }
    let saveTimer;
    function flashSave() {
      if (!saveIndicator) return;
      saveIndicator.style.color = 'var(--color-accent)';
      clearTimeout(saveTimer);
      saveTimer = setTimeout(() => { saveIndicator.style.color = 'var(--color-success)'; }, 600);
    }

    function eur(n) {
      if (!Number.isFinite(n)) return '€, ';
      return new Intl.NumberFormat('en-DE', { style: 'currency', currency: 'EUR' }).format(n);
    }
    function eurInt(n) {
      if (!Number.isFinite(n)) return '€, ';
      return new Intl.NumberFormat('en-DE', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n);
    }
    function dateNice(s) {
      if (!s) return ', ';
      const d = new Date(s + 'T00:00:00');
      if (isNaN(d.getTime())) return ', ';
      return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
    }
    function setText(sel, value) {
      document.querySelectorAll(sel).forEach((el) => { el.textContent = value || ', '; });
    }

    // Contract ID, e.g. BAR-G390-CAFE-260612 — agency · plan+price · client · signature date.
    // Deterministic from the form (no backend); also quoted as the payment reference.
    function clientSlug(name) {
      const s = (name || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^A-Za-z0-9]/g, '').toUpperCase().slice(0, 4);
      return s || '____';
    }
    function yymmdd6(s) {
      const d = new Date((s || today) + 'T00:00:00');
      if (isNaN(d.getTime())) return '______';
      return `${String(d.getFullYear()).slice(2)}${String(d.getMonth() + 1).padStart(2, '0')}${String(d.getDate()).padStart(2, '0')}`;
    }
    function contractId(plan, monthlyTotal, businessName, sigDate) {
      const planSeg = plan && monthlyTotal > 0 ? `${plan.code}${monthlyTotal}` : '____';
      return `BAR-${planSeg}-${clientSlug(businessName)}-${yymmdd6(sigDate)}`;
    }

    function render() {
      const fd = new FormData(form);

      setText('.out-client-business-name', fd.get('client_business_name'));
      setText('.out-client-legal-form', fd.get('client_legal_form'));
      setText('.out-client-representative', fd.get('client_representative'));
      setText('.out-client-representative-role', fd.get('client_representative_role'));
      setText('.out-client-street', fd.get('client_street'));
      setText('.out-client-postal-code', fd.get('client_postal_code'));
      setText('.out-client-city', fd.get('client_city') || 'Berlin');
      setText('.out-client-email', fd.get('client_email'));
      const phone = (fd.get('client_phone') || '').toString().trim();
      document.querySelectorAll('.out-client-phone').forEach((el) => { el.textContent = phone || ', '; });
      document.querySelectorAll('.out-client-phone-row').forEach((el) => { el.style.display = phone ? '' : 'none'; });
      setText('.out-client-ust-idnr', fd.get('client_ust_idnr') || ', (Kleinunternehmer § 19 UStG)');

      const planId = fd.get('plan');
      const plan = plans.find((p) => p.id === planId);

      // ---- Add-ons + billing: ONE canonical monthlyTotal feeds ID, buy-out, VAT, yearly (audit A2) ----
      const nLang = Math.max(0, parseInt(fd.get('addon_languages') || '0', 10) || 0);
      const nMail = Math.max(0, parseInt(fd.get('addon_mailboxes') || '0', 10) || 0);
      const nExtraCh = Math.max(0, parseInt(fd.get('addon_social_extra_channels') || '0', 10) || 0);
      const socialIncluded = !!plan && plan.id === 'complete';
      const socialEnabled = socialIncluded || fd.get('addon_social_enabled') === 'on';
      const planBase = plan ? plan.priceNum : 0;
      const socialFirst = plan && socialEnabled && !socialIncluded ? (addons.socialFirstChannel[plan.id] || 0) : 0;
      const monthlyTotal = planBase + nLang * addons.language + nMail * addons.mailbox + socialFirst + nExtraCh * addons.socialAdditionalChannel;

      // read-only retainer field mirrors the computed total (single source of truth)
      const retEl = form.querySelector('[name=price_retainer]');
      if (retEl) retEl.value = monthlyTotal > 0 ? String(monthlyTotal) : '';

      const isYearly = (fd.get('billing_cycle') || 'monthly') === 'yearly';
      const yearlyTotal = Math.round(monthlyTotal * 12 * (1 - billing.yearlyDiscount));
      const billedAmount = isYearly ? yearlyTotal : monthlyTotal;
      const buyout = monthlyTotal * buyoutMonths;

      setText('.out-contract-no', contractId(plan, monthlyTotal, fd.get('client_business_name'), fd.get('date_signature')));

      const planLineEl = document.querySelector('.out-plan-line');
      const container = document.getElementById('services-rendered');
      const noServicesEl = container.querySelector('.out-no-services');
      container.querySelectorAll('.feat-item').forEach((el) => el.remove());
      if (plan) {
        planLineEl.style.display = '';
        planLineEl.textContent = strings.s2PlanLine.replace('{plan}', plan.name).replace('{price}', plan.priceLabel);
        noServicesEl.style.display = 'none';
        // §2: plan feature list (source of truth) + the selected add-ons as line items.
        const lines = plan.features.slice();
        if (nLang > 0) lines.push(strings.s2AddonLanguage.replace('{count}', String(nLang)).replace('{price}', eurInt(addons.language)));
        if (nMail > 0) lines.push(strings.s2AddonMailbox.replace('{count}', String(nMail)).replace('{price}', eurInt(addons.mailbox)));
        // Complete already lists included social in its plan features; only Start/Growth add a line.
        if (!socialIncluded && socialEnabled) lines.push(strings.s2AddonSocialFirst.replace('{price}', eurInt(addons.socialFirstChannel[plan.id] || 0)));
        if (nExtraCh > 0) lines.push(strings.s2AddonSocialExtra.replace('{count}', String(nExtraCh)).replace('{price}', eurInt(addons.socialAdditionalChannel)));
        lines.forEach((feat) => {
          const li = document.createElement('li');
          li.className = 'feat-item';
          li.textContent = feat;
          container.appendChild(li);
        });
      } else {
        planLineEl.style.display = 'none';
        noServicesEl.style.display = '';
      }

      const vatStatus = fd.get('vat_status') || 'kleinunternehmer';
      document.querySelector('.out-build-line').textContent =
        strings.s3BuildFeeLine.replace('{eur}', buyout > 0 ? eur(buyout) : '€, (no buy-out)');
      document.querySelector('.out-retainer-line').textContent = isYearly
        ? strings.s3RetainerLineYearly.replace('{eur}', billedAmount > 0 ? eur(billedAmount) : '€, ')
        : strings.s3RetainerLine.replace('{eur}', billedAmount > 0 ? eur(billedAmount) : '€, (no monthly fee entered)');
      document.querySelector('.out-retainer-hint').textContent =
        strings.retainerFeeHint.replace('{eur}', buyout > 0 ? eur(buyout) : '—');

      const yearlyLineEl = document.querySelector('.out-yearly-line');
      if (isYearly && billedAmount > 0) {
        yearlyLineEl.style.display = '';
        yearlyLineEl.textContent = strings.s3YearlyDiscountLine.replace('{eur}', eur(billedAmount));
      } else {
        yearlyLineEl.style.display = 'none';
      }

      if (vatStatus === 'kleinunternehmer') {
        document.querySelector('.out-vat-line').textContent = strings.s3VatKleinLine;
      } else {
        const net = billedAmount; // billed amount (monthly or yearly); any one-time buy-out is invoiced separately
        const vat = net * 0.19;
        const gross = net + vat;
        document.querySelector('.out-vat-line').textContent = strings.s3VatRegularLine.replace('{net}', eur(net)).replace('{vat}', eur(vat)).replace('{gross}', eur(gross));
      }

      setText('.out-reference-note', strings.s3ReferenceNote);
      setText('.out-sig-date', dateNice(fd.get('date_signature')));

      const termEl = document.querySelector('.out-term-line');
      if (termEl) termEl.textContent = isYearly ? strings.s4MinimumTermYearly : strings.s4MinimumTerm;

      const startDate = fd.get('date_start');
      document.querySelector('.out-start-line').textContent =
        strings.s4Start.replace('{date}', dateNice(startDate)) + ' ' + strings.s4StartNote;
    }

    // Selecting a plan fills the monthly fee + buy-out; §2 mirrors the plan's
    // /pricing feature list (rendered in render()).
    function applyPlan(planId) {
      const plan = plans.find((p) => p.id === planId);
      const cb = form.querySelector('[name=addon_social_enabled]');
      if (!cb) return;
      if (plan && plan.id === 'complete') {
        cb.checked = true;
        cb.disabled = true; // social is included in Complete
      } else {
        if (cb.disabled) cb.checked = false; // leaving Complete clears the forced state
        cb.disabled = false;
      }
    }

    form.addEventListener('input', () => { render(); persist(); });
    form.addEventListener('change', (e) => {
      if (e.target && e.target.name === 'plan') applyPlan(e.target.value);
      if (e.target && e.target.name === 'date_signature') startEl.value = addDays(e.target.value, 5);
      render();
      persist();
    });
    applyPlan(form.querySelector('[name=plan]:checked')?.value);
    render();

    printBtn.addEventListener('click', () => window.print());

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const isHidden = formPanel.style.display === 'none';
        formPanel.style.display = isHidden ? '' : 'none';
        toggleBtn.setAttribute('aria-pressed', String(!isHidden));
        toggleBtn.querySelector('[data-show-text]').textContent = isHidden ? 'Hide form' : 'Show form';
      });
    }
  </script>
</BaseLayout>
