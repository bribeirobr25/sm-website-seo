---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import Faq from '@/components/sections/Faq.astro';
import HeroAurora from '@/components/sections/HeroAurora.astro';
import PricingTiers from '@/components/sections/PricingTiers.astro';
import ContactBar from '@/components/ui/ContactBar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { FUNNEL } from '@/lib/funnel';
import { faqPageSchema } from '@/lib/seo/schema';
import { LOCALE_PREFIX } from '@/lib/site';

const locale = 'en' as const;
const prefix = LOCALE_PREFIX[locale];
const pr = FUNNEL[locale].pricing;
const ui = FUNNEL[locale].ui;
const contactHref = `${prefix}/contact`;
const faqSchema = faqPageSchema(pr.faq);
---

<BaseLayout title={pr.metaTitle} description={pr.metaDescription} locale={locale} localePath="/pricing" extraSchema={faqSchema}>
  <Header locale={locale} localePath="/pricing" />
  <main id="main">
    <section class="hero-dark relative overflow-hidden">
      <div class="hero-dark__veil" aria-hidden="true"></div>
      <HeroAurora />
      <div class="relative container-page pt-24 pb-20 sm:pt-32 sm:pb-24 max-w-3xl">
        <p class="text-xs tracking-[0.18em] uppercase text-accent-light font-medium mb-6">{pr.heroEyebrow}</p>
        <h1 class="font-display text-[clamp(2.5rem,6vw,5rem)] font-semibold text-white leading-[1.04] tracking-[-0.03em]">{pr.heroTitle}</h1>
        <p class="mt-6 text-xl text-white/85 leading-[1.5]">{pr.heroSubtitle}</p>
      </div>
    </section>

    <section class="section bg-bg">
      <div class="container-page">
        <PricingTiers tiers={pr.tiers} ui={ui} ctaHref={contactHref} />
        <p class="mt-10 text-sm text-text-muted max-w-2xl">{pr.outroNote}</p>
        <p class="mt-3 text-xs text-text-muted">{pr.draftNote}</p>

        <div class="mt-12 rounded-[22px] bg-surface border border-border p-8 sm:p-10 flex flex-col sm:flex-row sm:items-center justify-between gap-6">
          <div class="max-w-xl">
            <h2 class="font-display text-2xl font-semibold text-text tracking-[-0.02em]">{pr.customHeading}</h2>
            <p class="mt-3 text-text-muted leading-relaxed">{pr.customBody}</p>
          </div>
          <a href={contactHref} class="shrink-0 inline-flex items-center justify-center px-7 py-3 min-h-[52px] rounded-full bg-accent text-white hover:bg-accent-deep transition-colors text-base font-medium">{pr.ctaButton}</a>
        </div>
      </div>
    </section>

    <section class="section bg-surface" aria-labelledby="includes-heading">
      <div class="container-page">
        <div class="max-w-3xl mb-12">
          <p class="text-xs tracking-[0.18em] uppercase text-accent-on-surface font-medium">{pr.includesEyebrow}</p>
          <h2 id="includes-heading" class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl text-text font-semibold tracking-[-0.03em] leading-[1.06]">{pr.includesHeading}</h2>
          <p class="mt-5 text-lg text-text-muted leading-[1.5]">{pr.includesBody}</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {pr.includes.map((it, i) => (
            <div class="reveal-rise rounded-[22px] bg-surface-elev border border-border p-7" style={`animation-delay:${i * 50}ms`}>
              <h3 class="font-display text-lg font-semibold text-text tracking-[-0.01em]">{it.title}</h3>
              <p class="mt-3 text-sm text-text-muted leading-relaxed">{it.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-bg" aria-labelledby="terms-heading">
      <div class="container-page max-w-3xl">
        <p class="text-xs tracking-[0.18em] uppercase text-accent-on-surface font-medium">{pr.termsEyebrow}</p>
        <h2 id="terms-heading" class="mt-4 font-display text-3xl sm:text-4xl text-text font-semibold tracking-[-0.03em] leading-[1.06]">{pr.termsHeading}</h2>
        <ul class="mt-8 space-y-4 list-none p-0">
          {pr.terms.map((term) => (
            <li class="flex items-start gap-3 text-text leading-relaxed">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-on-surface shrink-0 mt-1" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>{term}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <Faq eyebrow={pr.heroEyebrow} title={pr.faqHeading} items={pr.faq} surface={true} />

    <section class="bg-inverted-bg text-inverted-text">
      <div class="container-page py-24 sm:py-32 text-center">
        <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-[-0.03em] leading-[1.05] max-w-2xl mx-auto">{pr.ctaHeading}</h2>
        <p class="mt-6 text-lg text-inverted-text-muted leading-[1.5] max-w-xl mx-auto">{pr.ctaBody}</p>
        <div class="mt-10">
          <a href={contactHref} class="inline-flex items-center justify-center px-7 py-3 min-h-[52px] rounded-full bg-accent text-white hover:bg-accent-deep transition-colors text-base font-medium">{pr.ctaButton}</a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
  <ContactBar locale={locale} />
</BaseLayout>
