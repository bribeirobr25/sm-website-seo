---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import HeroAurora from '@/components/sections/HeroAurora.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PAGE_STRINGS } from '@/lib/page-strings';
import { heroSrcset } from '@/lib/srcset';

const locale = 'en' as const;
const p = PAGE_STRINGS[locale].services;
const cat = p.catalog;
---

<BaseLayout title={p.title} description={p.description} locale={locale} localePath="/services">
  <Header locale={locale} localePath="/services" />
  <main id="main">
    <section class="hero-dark relative overflow-hidden">
      <div class="hero-dark__veil" aria-hidden="true"></div>
      <HeroAurora />
      <div class="relative container-page pt-28 pb-24 sm:pt-36 sm:pb-32 text-center max-w-3xl mx-auto">
        <p class="text-xs tracking-[0.18em] uppercase text-accent-light font-medium mb-6">{p.heroEyebrow}</p>
        <h1 class="font-display text-[clamp(2.5rem,6vw,5rem)] font-semibold text-white leading-[1.04] tracking-[-0.03em]">{p.heroTitle}</h1>
        <p class="mt-6 text-lg text-white/85 leading-[1.5]">{p.heroSubtitle}</p>
      </div>
    </section>

    <section class="section bg-bg">
      <div class="container-page space-y-5">
        {cat.map((c, i) => {
          const Card = c.href ? 'a' : 'div';
          return (
            <Card
              href={c.href ?? undefined}
              class="svc-card-photo group reveal-rise relative block rounded-[22px] overflow-hidden p-10 sm:p-14 min-h-[320px] sm:min-h-[360px]"
              style={`animation-delay:${i * 60}ms`}
            >
              <img
                src={c.imgSrc}
                srcset={heroSrcset(c.imgSrc)}
                sizes="100vw"
                alt=""
                aria-hidden="true"
                width="1600"
                height="900"
                loading={i < 2 ? 'eager' : 'lazy'}
                decoding="async"
                class="svc-card-photo__img"
              />
              <div class="svc-card-photo__veil" aria-hidden="true"></div>
              <div class="svc-card-photo__glow" aria-hidden="true"></div>
              <div class="relative grid sm:grid-cols-[1fr_2fr] gap-8 items-start">
                <div>
                  <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-[-0.02em] leading-[1.1] text-white">{c.name}</h2>
                </div>
                <div>
                  <p class="text-lg leading-[1.5] text-white/85">{c.tagline}</p>
                  {c.linkLabel && (
                    <p class="mt-8 text-sm font-medium text-white group-hover:translate-x-1 transition-transform inline-block">{c.linkLabel}</p>
                  )}
                </div>
              </div>
            </Card>
          );
        })}
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
