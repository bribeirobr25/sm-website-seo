---
/**
 * CookieBanner — universal consent banner.
 * Per LEGAL.md §Cookie consent banner — universal spec (DSGVO / LGPD / RGPD / CCPA).
 *
 * Renders on first visit if no consent record exists. The banner offers:
 *   - Accept all (functional + analytics + marketing)
 *   - Reject all (essential only) — equal prominence per parity rule
 *   - Cookie policy link → /privacy-policy by default
 *
 * **Per-jurisdiction setup at scaffold time:**
 *   - DE/AT: replace `/privacy-policy` href with `/datenschutz`; update body text + button labels to German
 *   - BR: replace href with `/politica-de-privacidade`; update text + buttons to Portuguese
 *   - PT: replace href with `/politica-de-privacidade`; update for PT-PT
 *
 * The footer "Manage cookie preferences" link re-opens the banner via the
 * `consent:reopen` custom event.
 */
---

<div
  id="cookie-banner"
  class="hidden fixed inset-x-0 bottom-0 z-40 bg-surface border-t border-border shadow-elev"
  role="dialog"
  aria-modal="false"
  aria-labelledby="cookie-banner-title"
>
  <div class="container-page py-5 md:py-6">
    <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-6">
      <div class="flex-1 min-w-0">
        <h2
          id="cookie-banner-title"
          class="font-display text-lg text-text"
        >
          Cookies — wie hättet Ihr es gern?
        </h2>
        <p class="text-sm text-text-muted mt-1 leading-relaxed">
          Wir verwenden essentielle Cookies, um die Seite überhaupt anzuzeigen. Mit eurer Zustimmung
          auch Analyse-Cookies (anonymisiert), damit wir wissen, was funktioniert. Mehr in unserer{' '}
          <a
            href="/datenschutz"
            class="underline hover:text-accent transition-colors"
          >
            Datenschutzerklärung
          </a>.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-2 shrink-0">
        <button
          type="button"
          id="cookie-reject"
          class="inline-flex items-center justify-center px-5 py-3 min-h-[44px] text-sm font-medium rounded-md bg-surface-elev text-text border border-border hover:bg-bg transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          Alle ablehnen
        </button>
        <button
          type="button"
          id="cookie-accept"
          class="inline-flex items-center justify-center px-5 py-3 min-h-[44px] text-sm font-medium rounded-md bg-accent text-bg hover:bg-accent-deep transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          Alle akzeptieren
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import {
    readConsent,
    writeConsent,
    applyConsent,
    ACCEPT_ALL,
    ESSENTIAL_ONLY,
    type ConsentCategories,
  } from '@/lib/consent';
  import { trackEssential, EVENTS } from '@/lib/analytics';

  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');

  function showBanner() {
    banner?.classList.remove('hidden');
  }

  function hideBanner() {
    banner?.classList.add('hidden');
  }

  function decide(categories: ConsentCategories, accepted: boolean) {
    writeConsent(categories);
    applyConsent(categories);
    hideBanner();
    trackEssential(accepted ? EVENTS.CONSENT_GIVEN : EVENTS.CONSENT_REJECTED);
  }

  acceptBtn?.addEventListener('click', () => decide(ACCEPT_ALL, true));
  rejectBtn?.addEventListener('click', () => decide(ESSENTIAL_ONLY, false));

  // Footer "Manage preferences" link dispatches consent:reopen
  window.addEventListener('consent:reopen', showBanner);

  // On initial load: if no consent record (or expired), show banner.
  // If consent was previously stored, re-apply it (upgrades any type="text/plain" scripts).
  const stored = readConsent();
  if (stored) {
    applyConsent(stored.categories);
  } else {
    showBanner();
  }
</script>
