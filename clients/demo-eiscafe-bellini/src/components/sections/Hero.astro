---
/**
 * Hero — Eiscafé Bellini.
 * Clean variant per 2026-05-22 feedback: kicker (address) dropped + subhead
 * tightened. Address lives in Footer + Visit page only.
 */
import { type Locale, SITE } from '@/lib/site';
import FullBleedHero from './FullBleedHero.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = SITE.i18n[locale];

const heroH1 =
  locale === 'de'
    ? ['Bronte-Pistazie.', 'Modica-Schokolade.']
    : ['Bronte pistachio.', 'Modica chocolate.'];

const body =
  locale === 'de'
    ? 'Familieneis nach den Rezepten von 1987 — mit Zutaten von benannten Produzenten aus Sizilien, Piemont und Brandenburg.'
    : 'Family gelato from the 1987 recipes — with ingredients from named producers in Sicily, Piemonte, and Brandenburg.';

const menuHref = locale === 'de' ? '/gelato' : '/en/gelato';
const callLabel = locale === 'de' ? 'Anrufen' : 'Call us';

const imageAlt =
  locale === 'de'
    ? 'Eiscafé Bellini — Vitrine mit handgemachtem italienischen Gelato'
    : 'Eiscafé Bellini — Display case of handmade Italian gelato';
---

<FullBleedHero
  imageSrc="/img/hero-gelato-counter.jpg"
  imageAlt={imageAlt}
  titleLines={heroH1}
  body={body}
  ctaPrimary={{ href: menuHref, label: t.cta.viewMenu }}
  ctaSecondary={{ href: `tel:${SITE.phone}`, label: callLabel }}
  height="tall"
  overlay="dual"
/>
