---
/**
 * Big-number stat callouts — service-business social proof.
 * Spec: docs/design/components/stat-callouts.md
 *
 * 2-4 callouts in a row. Pre-launch rule (DESIGN-BEST-PRACTICES.md §11):
 * never invent the number. If client is unsure, omit the callout.
 * Avoid for businesses < 1 year or < 50 clients — `1+ Year` actively
 * undermines trust.
 *
 * Visual identity (this scaffold): dark + amber
 *   numbers use --color-accent (amber on dark bg) — high-contrast accent
 *   labels use --color-text — calm secondary
 *
 * Per-vertical token swaps:
 *   trades (navy):              --color-accent: #042940 navy on cream
 *   professional-services:      same as trades or muted accent
 *   beauty (cream + peach):     numbers use --color-text-warm (NOT peach,
 *                                which would fail AA at this size)
 *   agency-self:                --color-accent: brand primary
 */

interface Stat {
  number: string;
  label: string;
  ariaLabel: string;
}

interface Props {
  stats: Stat[];
  ariaLabel?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { stats, ariaLabel = 'Statistics', align = 'left', class: extraClass = '' } = Astro.props;
---

<section class:list={['sco-section', extraClass]} aria-label={ariaLabel}>
  <div class="container-page">
    <ul class:list={['sco-list', `sco-list--${align}`]}>
      {
        stats.map((stat) => (
          <li class="sco-item">
            <span class="sco-number" aria-label={stat.ariaLabel}>
              {stat.number}
            </span>
            <span class="sco-label">{stat.label}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .sco-section {
    padding-block: clamp(4rem, 8vw, 8rem);
  }

  .sco-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: clamp(2rem, 5vw, 4rem);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sco-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sco-list--left .sco-item {
    text-align: left;
    align-items: flex-start;
  }

  .sco-list--center .sco-item {
    text-align: center;
    align-items: center;
  }

  .sco-number {
    font-family: var(--font-display);
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 600;
    line-height: 0.95;
    letter-spacing: var(--tracking-display-sans);
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  .sco-label {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.5vw, 16px);
    font-weight: 400;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text);
  }
</style>
