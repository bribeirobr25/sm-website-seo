---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import LabelCountHeader from '@/components/sections/LabelCountHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

const locale = 'de' as const;
const t = SITE.i18n[locale];

const categories = [
  {
    key: 'creme' as const,
    image: '/img/category-creme.jpg',
    alt: 'Cremiges italienisches Gelato in der Auslage — milchige Pastelltöne',
  },
  {
    key: 'sorbetti' as const,
    image: '/img/category-sorbetti.jpg',
    alt: 'Fruchtige Sorbetti mit leuchtenden Farben — Erdbeere, Mango, Zitrone',
  },
  {
    key: 'spezialitaeten' as const,
    image: '/img/category-spezialitaeten.jpg',
    alt: 'Affogato — Vanilleeis mit Espresso übergossen',
  },
];
---

<BaseLayout
  title={`Karte — ${SITE.name}`}
  description="Le Creme, Sorbetti, Spezialitäten. Frisch täglich, mit Bronte-Pistazien und Piemonteser Haselnüssen."
  locale={locale}
  alternateLocaleUrl="/en/gelato"
>
  <Header locale={locale} />
  <main id="main">
    <section class="bg-bg">
      <div class="container-page py-16 sm:py-24">
        <div class="max-w-2xl">
          <p class="text-xs uppercase tracking-[0.2em] text-accent font-semibold">{t.nav.menu}</p>
          <h1 class="mt-2 font-display text-4xl sm:text-5xl text-text leading-[1.05]">Unsere Karte.</h1>
          <p class="mt-6 text-lg text-text-muted leading-relaxed">
            Frisch täglich, mit Zutaten von kleinen italienischen Produzenten. Manche Sorten wechseln saisonal — die Tafel im Laden ist immer aktuell.
          </p>
        </div>
      </div>
    </section>

    {categories.map((cat, idx) => {
      const section = SITE.menu[cat.key];
      const bg = idx % 2 === 0 ? 'bg-surface-elev' : 'bg-bg';
      return (
        <section class={bg}>
          <div class="container-page py-16">
            <div class="grid lg:grid-cols-[1fr_1.4fr] gap-10 lg:gap-16 items-start">
              <div class="space-y-5">
                <div class="relative aspect-[4/3] rounded-lg overflow-hidden border border-border shadow-card">
                  <img
                    src={cat.image}
                    alt={cat.alt}
                    width="800"
                    height="600"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover"
                  />
                </div>
                <LabelCountHeader
                  label={section.label[locale]}
                  count={section.count}
                  countLabel={`${section.count} ${locale === 'de' ? 'Sorten' : 'flavors'}`}
                />
                <p class="text-text-muted leading-relaxed">
                  {section.intro[locale]}
                </p>
              </div>

              <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-5">
                {section.items.map((item: { de: { name: string; desc: string }; en: { name: string; desc: string } }) => (
                  <li class="border-b border-border pb-3">
                    <h3 class="font-display text-xl text-text leading-tight">{item[locale].name}</h3>
                    <p class="mt-1 text-text-muted text-sm leading-relaxed">{item[locale].desc}</p>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      );
    })}

    <section class="bg-surface-elev">
      <div class="container-page py-16">
        <div class="grid lg:grid-cols-[1fr_1.4fr] gap-10 lg:gap-16 items-start">
          <div class="space-y-5">
            <div class="relative aspect-[4/3] rounded-lg overflow-hidden border border-border shadow-card">
              <img
                src="/img/category-eistorten.jpg"
                alt="Eistorte mit Frucht und Sahne — auf Bestellung"
                width="800"
                height="600"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
            <LabelCountHeader label="EISTORTEN AUF BESTELLUNG" count={0} countLabel="auf Bestellung" />
            <p class="text-text-muted leading-relaxed">
              Wir machen Eistorten für Geburtstage, Hochzeiten, und alles dazwischen. Mindestens 5 Tage vorher anrufen oder mailen. Geschmack, Größe, und Anzahl der Geschmäcker sind frei.
            </p>
          </div>

          <div class="space-y-4 lg:pt-16">
            <p class="text-text-muted leading-relaxed">
              Ein paar Klassiker zur Orientierung — die genaue Komposition besprechen wir am Telefon:
            </p>
            <ul class="space-y-3 text-text-muted">
              <li><strong class="text-text">Cassata Siciliana</strong> — Ricotta, kandierte Früchte, Marzipan-Mantel.</li>
              <li><strong class="text-text">Semifreddo Pistazie</strong> — halbgefroren, Bronte-Pistazienpaste, Baiser.</li>
              <li><strong class="text-text">Bombe Stracciatella</strong> — Schichten aus Sahne und dunkler Schokolade.</li>
              <li><strong class="text-text">Kinder-Geburtstagstorte</strong> — Bunt, mit Streuseln, gerne mit Foto-Aufleger.</li>
            </ul>
            <div class="pt-3 flex flex-wrap gap-3">
              <a href={`tel:${SITE.phone}`} class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-md bg-accent text-bg hover:bg-accent-deep transition-colors">
                Anrufen — {SITE.phoneDisplay}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-bg">
      <div class="container-page py-12 text-center">
        <p class="text-sm text-text-muted italic max-w-2xl mx-auto leading-relaxed">
          Die Karte wechselt saisonal. Frische Erdbeeren ab Mai, Feigen ab August, Cassis im Sommer. Im Winter machen wir Pause bei Sorten, deren Frucht es nicht mehr gibt — kein Erdbeer-Eis aus dem Tiefkühler.
        </p>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
