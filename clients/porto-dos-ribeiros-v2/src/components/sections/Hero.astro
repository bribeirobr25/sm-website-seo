---
import { Image } from 'astro:assets';
import heroPicanha from '../../assets/images/picanha.png';
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative overflow-hidden bg-[var(--color-bg)]">
  <div class="relative">
    <div class="relative aspect-[4/5] sm:aspect-[16/9] lg:aspect-[2/1] w-full overflow-hidden">
      <Image
        src={heroPicanha}
        alt={t('home.hero.image_alt')}
        widths={[640, 960, 1280, 1920]}
        sizes="100vw"
        format="webp"
        quality={75}
        loading="eager"
        fetchpriority="high"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div
        aria-hidden="true"
        class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/55 to-black/20 sm:bg-gradient-to-r sm:from-black/85 sm:via-black/60 sm:to-black/15"
      ></div>
      <div class="relative z-10 flex h-full items-end sm:items-center">
        <div class="mx-auto w-full max-w-5xl px-4 pb-8 sm:px-6 sm:pb-0">
          <div class="max-w-xl text-white">
            <p
              class="inline-flex items-center gap-2 rounded-full bg-white/12 px-3 py-1.5 text-[11px] font-medium uppercase tracking-[0.18em] backdrop-blur"
            >
              <span
                class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"
                aria-hidden="true"></span>
              {t('home.hero.eyebrow')}
            </p>
            <h1
              class="mt-4 font-display text-4xl leading-[1.05] text-white sm:text-5xl lg:text-6xl"
              style="font-family: var(--font-display); font-weight: 600; color: #ffffff"
            >
              {t('home.hero.headline')}
            </h1>
            <p class="mt-4 max-w-md text-base text-white/90 sm:text-lg">
              {t('home.hero.sub')}
            </p>
            <div class="mt-6 flex flex-wrap items-center gap-3">
              <a
                href={SITE.whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={t('cta.whatsapp')}
                class="inline-flex items-center gap-2 rounded-[var(--radius-pill)] bg-[var(--color-accent)] px-6 py-3.5 text-[15px] font-semibold text-[var(--color-text)] shadow-[var(--shadow-card)] transition-transform duration-150 hover:scale-[1.02] active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-black"
              >
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  width="20"
                  height="20"
                  fill="currentColor"
                >
                  <path
                    d="M19.05 4.91A10 10 0 0 0 12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.83-1.27A10 10 0 0 0 22 12a10 10 0 0 0-2.95-7.09Zm-7.05 15.4a8.3 8.3 0 0 1-4.23-1.16l-.3-.18-2.86.75.76-2.79-.2-.32A8.31 8.31 0 1 1 12 20.31Zm4.55-6.22c-.25-.13-1.47-.72-1.7-.81-.23-.08-.4-.13-.56.13-.16.25-.65.81-.79.97-.15.16-.29.18-.54.05-.25-.13-1.06-.39-2.02-1.25a7.6 7.6 0 0 1-1.4-1.74c-.15-.25 0-.39.11-.51.11-.11.25-.29.37-.43.13-.15.16-.25.25-.41.08-.16 0-.32-.04-.45-.05-.13-.55-1.33-.75-1.82-.2-.48-.4-.42-.55-.42h-.46c-.16 0-.41.06-.62.31-.21.25-.81.79-.81 1.94 0 1.15.83 2.25.94 2.41.11.15 1.63 2.49 3.95 3.49.55.24.98.38 1.32.49.55.18 1.06.16 1.46.1.45-.07 1.47-.6 1.68-1.18.21-.59.21-1.08.15-1.18-.07-.11-.23-.18-.48-.31Z"
                  />
                </svg>
                {t('cta.order_primary')}
              </a>
              <a
                href={`tel:${SITE.phone}`}
                class="inline-flex items-center gap-2 rounded-[var(--radius-pill)] border border-white/40 px-5 py-3 text-sm font-medium text-white transition-colors duration-150 hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
              >
                {SITE.phoneDisplay}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
