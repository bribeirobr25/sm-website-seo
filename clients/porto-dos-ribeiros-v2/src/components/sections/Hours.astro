---
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section
  aria-labelledby="hours-heading"
  class="border-y border-[var(--color-border)] bg-[var(--color-sage)]/25"
>
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-16">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p
          class="inline-flex items-center gap-2 rounded-full bg-[var(--color-open)]/15 px-3 py-1.5 text-[11px] font-medium uppercase tracking-[0.18em] text-[var(--color-open-deep)]"
        >
          <span
            class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-open)]"
            aria-hidden="true"></span>
          {t('labels.open_now')}
        </p>
        <h2
          id="hours-heading"
          class="mt-4 font-display text-3xl leading-[1.1] sm:text-4xl"
          style="font-family: var(--font-display); font-weight: 600"
        >
          {t('home.hours.title')}
        </h2>
        <p class="mt-3 max-w-md text-base text-[var(--color-text-muted)]">
          {t('home.hours.sub')}
        </p>
      </div>

      <dl class="grid grid-cols-1 gap-x-8 gap-y-1 sm:grid-cols-2">
        {
          SITE.hours.map((window) => (
            <div class="flex items-baseline justify-between border-b border-[var(--color-border)] py-3">
              <dt class="text-base font-medium">{t(`days.${window.key}`)}</dt>
              <dd class="tabular text-base text-[var(--color-text-muted)]">
                <time>{window.open}</time>
                {' – '}
                <time>{window.close === '24:00' ? '00:00' : window.close}</time>
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
    <p class="mt-4 text-xs italic text-[var(--color-text-muted)]">
      {t('home.hours.footnote')}
    </p>
  </div>
</section>
