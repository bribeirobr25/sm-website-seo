---
type Props = {
  value: number;
  max?: number;
  size?: number;
  ariaLabel: string;
  class?: string;
};

const { value, max = 5, size = 18, ariaLabel, class: extraClass } = Astro.props;
const fillPercent = Math.max(0, Math.min(100, (value / max) * 100));
---

<span
  role="img"
  aria-label={ariaLabel}
  class:list={['relative inline-block leading-none', extraClass]}
  style={`width:${size * max + (max - 1) * 2}px;height:${size}px`}
>
  <span class="absolute inset-0 flex gap-[2px] text-[var(--color-border)]" aria-hidden="true">
    {
      Array.from({ length: max }).map(() => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width={size}
          height={size}
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path d="M12 2 L14.6 8.6 L21.8 9.2 L16.4 13.9 L18 21 L12 17.3 L6 21 L7.6 13.9 L2.2 9.2 L9.4 8.6 Z" />
        </svg>
      ))
    }
  </span>
  <span
    class="absolute inset-y-0 left-0 flex gap-[2px] overflow-hidden text-[var(--color-accent)]"
    style={`width:${fillPercent}%`}
    aria-hidden="true"
  >
    {
      Array.from({ length: max }).map(() => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width={size}
          height={size}
          viewBox="0 0 24 24"
          fill="currentColor"
          style={`min-width:${size}px`}
        >
          <path d="M12 2 L14.6 8.6 L21.8 9.2 L16.4 13.9 L18 21 L12 17.3 L6 21 L7.6 13.9 L2.2 9.2 L9.4 8.6 Z" />
        </svg>
      ))
    }
  </span>
</span>
