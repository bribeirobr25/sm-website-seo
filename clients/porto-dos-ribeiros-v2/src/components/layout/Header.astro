---
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';
import LangSwitcher from './LangSwitcher.astro';

type Props = {
  locale: Locale;
  currentPath: string;
};

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);
---

<header
  class="sticky top-0 z-30 border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur supports-[backdrop-filter]:bg-[var(--color-bg)]/75"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex items-center justify-between py-3.5">
      <a
        href={locale === 'pt' ? '/' : '/en/'}
        class="font-display text-lg font-semibold tracking-tight sm:text-xl"
        aria-label="Porto dos Ribeiros"
        style="font-family: var(--font-display)"
      >
        Porto dos Ribeiros
      </a>

      <div class="flex items-center gap-2 sm:gap-4">
        <LangSwitcher locale={locale} currentPath={currentPath} />
        <a
          href={SITE.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t('cta.whatsapp')}
          class="inline-flex items-center gap-1.5 rounded-[var(--radius-pill)] bg-[var(--color-accent)] px-4 py-2 text-sm font-semibold text-[var(--color-text)] transition-transform duration-150 hover:scale-[1.03] active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent-deep)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-bg)]"
        >
          {t('cta.order_short')}
        </a>
      </div>
    </div>
  </div>
</header>
