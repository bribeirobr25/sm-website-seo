---
import { LOCALE_LABEL, LOCALES, type Locale, localizePath } from '../../lib/site.ts';

type Props = {
  locale: Locale;
  currentPath: string;
};

const { locale, currentPath } = Astro.props;
---

<div class="flex items-center gap-1 text-sm" role="group" aria-label="Language">
  {
    LOCALES.map((target, index) => {
      const isActive = target === locale;
      const href = localizePath(currentPath, target);
      return (
        <>
          <a
            href={href}
            hreflang={target}
            lang={target}
            aria-current={isActive ? 'true' : undefined}
            class:list={[
              'rounded-md px-2 py-1 transition-colors',
              isActive
                ? 'font-semibold text-[var(--color-text)]'
                : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)]',
            ]}
          >
            {LOCALE_LABEL[target]}
          </a>
          {index < LOCALES.length - 1 && (
            <span aria-hidden="true" class="text-[var(--color-border)]">·</span>
          )}
        </>
      );
    })
  }
</div>
