---
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <div
      class="rounded-2xl bg-[var(--color-sage)]/30 p-8 sm:p-12"
    >
      <div class="grid gap-8 sm:grid-cols-[1.2fr_1fr] sm:items-center sm:gap-12">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-text-muted)]">
            {t('footer.subscribe_kicker')}
          </p>
          <h2
            class="mt-2 font-display text-2xl leading-tight sm:text-3xl"
            style="font-family: var(--font-display); font-weight: 600"
          >
            {t('footer.subscribe_title')}
          </h2>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">
            {t('footer.subscribe_sub')}
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:items-end">
          <a
            href={SITE.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-[var(--radius-pill)] bg-[var(--color-accent)] px-5 py-3 text-sm font-semibold text-[var(--color-text)] transition-transform duration-150 hover:scale-[1.03] active:scale-95"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="currentColor"
            >
              <path
                d="M19.05 4.91A10 10 0 0 0 12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.83-1.27A10 10 0 0 0 22 12a10 10 0 0 0-2.95-7.09Zm-7.05 15.4a8.3 8.3 0 0 1-4.23-1.16l-.3-.18-2.86.75.76-2.79-.2-.32A8.31 8.31 0 1 1 12 20.31Zm4.55-6.22c-.25-.13-1.47-.72-1.7-.81-.23-.08-.4-.13-.56.13-.16.25-.65.81-.79.97-.15.16-.29.18-.54.05-.25-.13-1.06-.39-2.02-1.25a7.6 7.6 0 0 1-1.4-1.74c-.15-.25 0-.39.11-.51.11-.11.25-.29.37-.43.13-.15.16-.25.25-.41.08-.16 0-.32-.04-.45-.05-.13-.55-1.33-.75-1.82-.2-.48-.4-.42-.55-.42h-.46c-.16 0-.41.06-.62.31-.21.25-.81.79-.81 1.94 0 1.15.83 2.25.94 2.41.11.15 1.63 2.49 3.95 3.49.55.24.98.38 1.32.49.55.18 1.06.16 1.46.1.45-.07 1.47-.6 1.68-1.18.21-.59.21-1.08.15-1.18-.07-.11-.23-.18-.48-.31Z"
              />
            </svg>
            {t('footer.save_whatsapp')}
          </a>
          <p class="tabular text-sm text-[var(--color-text-muted)]">
            {SITE.phoneDisplay}
          </p>
        </div>
      </div>
    </div>

    <div class="mt-14 grid gap-10 sm:grid-cols-3">
      <div>
        <p class="font-display text-lg font-semibold" style="font-family: var(--font-display)">
          {t('footer.legal_name')}
        </p>
        <p
          class="mt-1 font-display text-sm italic text-[var(--color-text-muted)]"
          style="font-family: var(--font-display); font-style: italic"
          lang="pt"
        >
          {t('footer.brand_motto')}
        </p>
        <address class="mt-3 not-italic text-sm leading-relaxed text-[var(--color-text-muted)]">
          {SITE.address.street}<br />
          {SITE.address.postal}
          {SITE.address.city}, Portugal
        </address>
        <p class="mt-3 text-xs italic text-[var(--color-text-muted)]">
          {t('footer.legal_note')}
        </p>
      </div>

      <div class="text-sm">
        <p class="text-xs font-medium uppercase tracking-[0.12em] text-[var(--color-text-muted)]">
          {t('labels.phone')}
        </p>
        <a
          href={`tel:${SITE.phone}`}
          class="tabular mt-1 block hover:text-[var(--color-accent-deep)]"
        >
          {SITE.phoneDisplay}
        </a>
        <p class="mt-4 text-xs font-medium uppercase tracking-[0.12em] text-[var(--color-text-muted)]">
          {t('labels.whatsapp')}
        </p>
        <a
          href={SITE.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="tabular mt-1 block hover:text-[var(--color-accent-deep)]"
        >
          {SITE.phoneDisplay}
        </a>
        <div class="mt-4 flex gap-3 text-sm text-[var(--color-text-muted)]">
          <a
            href={SITE.socials.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-text)]"
          >
            Instagram
          </a>
          <a
            href={SITE.socials.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-text)]"
          >
            Facebook
          </a>
        </div>
      </div>

      <div class="text-sm">
        <ul class="space-y-2">
          <li>
            <a
              href={SITE.complaintsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[var(--color-text-muted)] hover:text-[var(--color-text)]"
            >
              {t('footer.complaints_link')}
            </a>
          </li>
          <li>
            <a
              href={locale === 'pt'
                ? '/politica-de-privacidade'
                : '/en/privacy-policy'}
              class="text-[var(--color-text-muted)] hover:text-[var(--color-text)]"
            >
              {t('footer.privacy')}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <p class="mt-12 text-xs text-[var(--color-text-muted)]">
      {t('footer.made_with')}
    </p>
  </div>
</footer>
