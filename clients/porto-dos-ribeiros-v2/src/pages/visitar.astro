---
import StubBody from '../components/sections/StubBody.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { resolveMetadata } from '../lib/metadata.ts';
import { useTranslations } from '../lib/site.ts';

const locale = 'pt' as const;
const t = useTranslations(locale);
const metadata = resolveMetadata({
  title: t('visit.meta_title'),
  description: t('visit.meta_description'),
  locale,
  path: '/visitar',
});
---

<BaseLayout metadata={metadata}>
  <StubBody locale={locale} />
</BaseLayout>
