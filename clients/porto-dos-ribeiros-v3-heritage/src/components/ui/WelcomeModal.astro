---
import { type Locale, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<dialog
  id="porto-welcome"
  class="m-auto w-[calc(100%-2rem)] max-w-md rounded-md border-2 border-[var(--color-accent)] bg-[var(--color-surface)] p-0 text-[var(--color-text)] shadow-[var(--shadow-float)] backdrop:bg-black/75 sm:max-w-lg"
  open
>
  <div class="relative">
    <form method="dialog" class="absolute top-3 right-3 z-10">
      <button
        type="submit"
        class="flex h-9 w-9 items-center justify-center rounded-full text-[var(--color-text-muted)] transition-colors duration-150 hover:text-[var(--color-text)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)]"
        aria-label={t('welcome.close_aria')}
      >
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="22"
          height="22"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </form>

    <div class="border-b-2 border-dashed border-[var(--color-border-light)] px-8 pt-10 pb-6 text-center">
      <p
        class="text-[10px] font-medium uppercase tracking-[0.32em] text-[var(--color-accent)]"
      >
        {t('welcome.kicker')}
      </p>
      <p
        class="mt-3 font-display text-2xl italic leading-tight sm:text-3xl"
        style="font-family: var(--font-display); font-style: italic; font-weight: 500"
        lang="pt"
      >
        {t('welcome.greeting')}
      </p>
      <p
        class="mt-2 font-display text-[40px] leading-none tracking-tight sm:text-5xl"
        style="font-family: var(--font-display); font-weight: 600"
      >
        Porto dos Ribeiros
      </p>
    </div>

    <div class="px-8 py-6 text-center text-sm leading-relaxed text-[var(--color-text-muted)]">
      <p>{t('welcome.body')}</p>
      <p class="mt-4 font-display text-base italic text-[var(--color-accent)]" lang="pt" style="font-style: italic">
        {t('welcome.signature')}
      </p>
    </div>

    <form method="dialog" class="border-t-2 border-dashed border-[var(--color-border-light)] px-8 pt-6 pb-8 text-center">
      <button
        type="submit"
        class="inline-flex items-center justify-center gap-2 rounded-sm border border-[var(--color-accent)] bg-transparent px-8 py-2.5 text-xs font-medium uppercase tracking-[0.24em] text-[var(--color-accent)] transition-colors duration-150 hover:bg-[var(--color-accent)] hover:text-[var(--color-bg)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-surface)]"
      >
        {t('welcome.enter')}
      </button>
    </form>
  </div>
</dialog>

<script is:inline>
  (function () {
    const modal = document.getElementById('porto-welcome');
    if (!modal) return;

    const STORAGE_KEY = 'porto-welcome-dismissed';
    const dismissed = (() => {
      try {
        return sessionStorage.getItem(STORAGE_KEY) === '1';
      } catch {
        return false;
      }
    })();

    if (dismissed) {
      modal.remove();
      return;
    }

    // Upgrade to true modal (with backdrop) when JS is available.
    if (typeof modal.showModal === 'function') {
      modal.close();
      modal.showModal();
    }

    modal.addEventListener('close', () => {
      try {
        sessionStorage.setItem(STORAGE_KEY, '1');
      } catch {
        // sessionStorage may be blocked; degrade silently.
      }
    });
  })();
</script>
