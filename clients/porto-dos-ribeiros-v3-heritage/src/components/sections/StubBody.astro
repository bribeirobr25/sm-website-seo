---
import { type Locale, localizePath, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6 sm:py-32">
  <p
    class="text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-text-muted)]"
  >
    Porto dos Ribeiros
  </p>
  <h1
    class="mt-3 font-display text-4xl leading-tight sm:text-5xl"
    style="font-family: var(--font-display); font-weight: 600"
  >
    {t('stub.title')}
  </h1>
  <p class="mt-4 text-base text-[var(--color-text-muted)]">
    {t('stub.subtitle')}
  </p>
  <a
    href={localizePath('/', locale)}
    class="mt-8 inline-flex items-center gap-1.5 text-sm font-medium underline decoration-[var(--color-accent)]/40 underline-offset-4 hover:decoration-[var(--color-accent)]"
  >
    ← {t('stub.back_home')}
  </a>
</section>
