---
import { Image } from 'astro:assets';
import coxinha from '../../assets/images/coxinha.jpg';
import jardineira from '../../assets/images/Jardineira.png';
import strogonoff from '../../assets/images/strogonoff.png';
import { type Locale, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);

const spreads = [
  { key: 'strogonoff', image: strogonoff, align: 'left' as const },
  { key: 'jardineira', image: jardineira, align: 'right' as const },
  { key: 'coxinha', image: coxinha, align: 'left' as const },
];
---

<section
  aria-labelledby="menu-heading"
  class="bg-[var(--color-bg)]"
>
  <div class="mx-auto max-w-5xl px-4 py-20 sm:px-6 sm:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <p
        class="text-[11px] font-medium uppercase tracking-[0.32em] text-[var(--color-accent)]"
      >
        {t('home.menu_preview.kicker')}
      </p>
      <h2
        id="menu-heading"
        class="mt-4 font-display text-3xl leading-tight sm:text-4xl lg:text-5xl"
        style="font-family: var(--font-display); font-weight: 600"
      >
        {t('home.menu_preview.title')}
      </h2>
      <p class="mt-6 text-base leading-relaxed text-[var(--color-text-muted)] sm:text-lg">
        {t('home.menu_preview.intro')}
      </p>
    </div>

    <div class="mt-20 space-y-20 sm:space-y-28">
      {
        spreads.map((spread) => (
          <article class="grid gap-10 lg:grid-cols-2 lg:items-center lg:gap-16">
            <div class:list={[spread.align === 'right' && 'lg:order-2']}>
              <div class="relative aspect-[5/6] overflow-hidden rounded-sm border border-[var(--color-border-light)]">
                <Image
                  src={spread.image}
                  alt={t(`home.menu_preview.items.${spread.key}.name`)}
                  widths={[400, 640, 800]}
                  sizes="(max-width: 1024px) 100vw, 480px"
                  format="webp"
                  quality={75}
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              </div>
            </div>
            <div class:list={[spread.align === 'right' && 'lg:order-1']}>
              <p class="text-[10px] font-medium uppercase tracking-[0.28em] text-[var(--color-accent)]">
                {t(`home.menu_preview.items.${spread.key}.label`)}
              </p>
              <h3
                class="mt-3 font-display text-2xl italic sm:text-3xl"
                style="font-family: var(--font-display); font-style: italic; font-weight: 500"
              >
                {t(`home.menu_preview.items.${spread.key}.name`)}
              </h3>
              <p class="mt-5 text-base leading-relaxed text-[var(--color-text-muted)]">
                {t(`home.menu_preview.items.${spread.key}.story`)}
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-20 border-t border-[var(--color-border)] pt-10 text-center">
      <p class="font-display text-base italic text-[var(--color-text-muted)]" style="font-style: italic">
        {t('home.menu_preview.more_note')}
      </p>
      <p class="mt-6 text-xs italic text-[var(--color-text-subtle)]">
        {t('home.menu_preview.price_note')}
      </p>
    </div>
  </div>
</section>
