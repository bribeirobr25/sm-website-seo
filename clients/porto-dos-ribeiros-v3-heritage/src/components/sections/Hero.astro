---
import { Image } from 'astro:assets';
import heroPicanha from '../../assets/images/picanha.png';
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative overflow-hidden border-b border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-5xl px-4 py-20 sm:px-6 sm:py-28">
    <div class="grid gap-14 lg:grid-cols-[1.2fr_0.8fr] lg:items-end lg:gap-20">
      <div>
        <p
          class="text-[11px] font-medium uppercase tracking-[0.32em] text-[var(--color-accent)]"
        >
          {t('home.hero.kicker')}
        </p>
        <h1
          class="mt-6 font-display text-[42px] italic leading-[1.08] sm:text-5xl lg:text-6xl"
          style="font-family: var(--font-display); font-style: italic; font-weight: 500"
        >
          {t('home.hero.headline')}
        </h1>
        <p
          class="mt-8 max-w-md text-base leading-relaxed text-[var(--color-text-muted)] sm:text-lg"
        >
          {t('home.hero.body')}
        </p>
        <p
          class="mt-8 font-display text-lg italic text-[var(--color-accent)] sm:text-xl"
          style="font-family: var(--font-display); font-style: italic"
          lang="pt"
        >
          {t('home.hero.brand_signature')}
        </p>

        <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-4 border-t border-[var(--color-border-light)] pt-6 text-sm">
          <a
            href={`tel:${SITE.phone}`}
            class="tabular text-[var(--color-text)] hover:text-[var(--color-accent)]"
          >
            {SITE.phoneDisplay}
          </a>
          <a
            href={SITE.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-muted)] underline decoration-[var(--color-accent)]/40 underline-offset-4 hover:text-[var(--color-text)] hover:decoration-[var(--color-accent)]"
          >
            {t('cta.whatsapp')}
          </a>
          <a
            href={SITE.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-muted)] underline decoration-[var(--color-accent)]/40 underline-offset-4 hover:text-[var(--color-text)] hover:decoration-[var(--color-accent)]"
          >
            {t('cta.directions')}
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="relative aspect-[3/4] overflow-hidden rounded-sm border border-[var(--color-border-light)]">
          <Image
            src={heroPicanha}
            alt={t('home.hero.image_alt')}
            widths={[400, 640, 800, 1024]}
            sizes="(max-width: 1024px) 100vw, 480px"
            format="webp"
            quality={75}
            loading="eager"
            fetchpriority="high"
            class="h-full w-full object-cover"
          />
          <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[var(--color-bg)]/30 to-transparent"
          ></div>
        </div>
        <div
          class="mt-4 flex items-center gap-3 text-[10px] uppercase tracking-[0.28em] text-[var(--color-text-subtle)]"
        >
          <span class="h-px flex-1 bg-[var(--color-border-light)]"></span>
          <span>{t('home.hero.image_caption')}</span>
          <span class="h-px flex-1 bg-[var(--color-border-light)]"></span>
        </div>
      </div>
    </div>
  </div>
</section>
