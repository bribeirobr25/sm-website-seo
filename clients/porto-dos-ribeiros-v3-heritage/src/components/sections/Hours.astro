---
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section
  aria-labelledby="hours-heading"
  class="border-y border-[var(--color-border)] bg-[var(--color-bg-deep)]"
>
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20">
    <div class="text-center">
      <p
        class="text-[11px] font-medium uppercase tracking-[0.32em] text-[var(--color-accent)]"
      >
        {t('home.hours.kicker')}
      </p>
      <h2
        id="hours-heading"
        class="mt-4 font-display text-2xl italic sm:text-3xl"
        style="font-family: var(--font-display); font-style: italic; font-weight: 500"
      >
        {t('home.hours.title')}
      </h2>
    </div>

    <dl class="mt-10 space-y-3 text-base">
      {
        SITE.hours.map((window) => (
          <div class="flex flex-wrap items-baseline justify-center gap-x-6 gap-y-1">
            <dt class="font-display text-base italic text-[var(--color-text-muted)]" style="font-style: italic">
              {t(`days.${window.key}`)}
            </dt>
            <dd class="tabular text-base text-[var(--color-text)]">
              <time>{window.open}</time>
              <span class="mx-2 text-[var(--color-text-subtle)]">·</span>
              <time>{window.close === '24:00' ? '00:00' : window.close}</time>
            </dd>
          </div>
        ))
      }
    </dl>

    <p class="mt-10 text-center text-xs italic text-[var(--color-text-subtle)]">
      {t('home.hours.footnote')}
    </p>
  </div>
</section>
