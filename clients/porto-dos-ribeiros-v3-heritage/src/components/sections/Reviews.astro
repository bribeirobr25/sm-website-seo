---
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';
import StarRating from '../ui/StarRating.astro';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);

const ratingAria = t('labels.rating_aria').replace('{value}', SITE.rating.value.toFixed(1));
const countText = t('home.reviews.trust_count').replace('{count}', SITE.rating.count.toString());
const gbpHref = 'https://www.google.com/search?q=Porto+dos+Ribeiros+Comida+Brasileira+Porto#lrd';
---

<section
  aria-labelledby="reviews-heading"
  class="bg-[var(--color-bg)]"
>
  <div class="mx-auto max-w-5xl px-4 py-20 sm:px-6 sm:py-28">
    <div class="grid gap-14 lg:grid-cols-[1fr_0.7fr] lg:items-center lg:gap-20">
      <div class="lg:order-2">
        <figure class="relative pl-10 sm:pl-16">
          <span
            aria-hidden="true"
            class="absolute -top-4 left-0 font-display text-[120px] leading-none text-[var(--color-accent)]/40 sm:text-[160px]"
            style="font-family: var(--font-display); font-weight: 700"
          >
            “
          </span>
          <blockquote>
            <p
              class="font-display text-xl italic leading-relaxed text-[var(--color-text)] sm:text-2xl lg:text-3xl"
              style="font-family: var(--font-display); font-style: italic; font-weight: 400"
            >
              {t('home.reviews.feature_quote')}
            </p>
            <figcaption class="mt-6 text-sm text-[var(--color-text-muted)]">
              <span class="font-medium text-[var(--color-text)]">
                {t('home.reviews.feature_author')}
              </span>
              <span aria-hidden="true" class="mx-2">·</span>
              <span>{t('home.reviews.feature_when')}</span>
            </figcaption>
          </blockquote>
        </figure>
      </div>

      <div class="lg:order-1">
        <p
          class="text-[11px] font-medium uppercase tracking-[0.32em] text-[var(--color-accent)]"
        >
          {t('home.reviews.kicker')}
        </p>
        <h2
          id="reviews-heading"
          class="mt-4 font-display text-3xl italic leading-tight sm:text-4xl"
          style="font-family: var(--font-display); font-style: italic; font-weight: 500"
        >
          {t('home.reviews.title')}
        </h2>

        <div class="mt-8 flex items-center gap-3">
          <StarRating value={SITE.rating.value} ariaLabel={ratingAria} size={20} />
          <span class="font-display text-xl text-[var(--color-text)] tabular">
            {SITE.rating.value.toFixed(1).replace('.', locale === 'pt' ? ',' : '.')}
          </span>
          <span class="text-sm text-[var(--color-text-muted)]">{countText}</span>
        </div>

        <a
          href={gbpHref}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t('home.reviews.see_more_aria')}
          class="mt-6 inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] underline decoration-[var(--color-accent)]/40 underline-offset-4 hover:text-[var(--color-text)] hover:decoration-[var(--color-accent)]"
        >
          {t('cta.more_reviews')}
        </a>

        <!-- Heritage stamp — "Desde 2023" badge -->
        <div class="mt-14 inline-flex items-center gap-4 border-y border-[var(--color-border-light)] py-4 pr-6">
          <div
            class="relative flex h-16 w-16 shrink-0 items-center justify-center rounded-full border-2 border-[var(--color-stamp)]"
            aria-hidden="true"
          >
            <span class="font-display text-base font-bold tracking-tight text-[var(--color-stamp)]" style="font-family: var(--font-display); font-weight: 700">
              2023
            </span>
          </div>
          <div>
            <p class="text-[10px] font-medium uppercase tracking-[0.28em] text-[var(--color-stamp)]">
              {t('home.reviews.stamp_kicker')}
            </p>
            <p class="mt-1 font-display text-sm italic text-[var(--color-text-muted)]" style="font-style: italic">
              {t('home.reviews.stamp_text')}
            </p>
          </div>
        </div>
      </div>
    </div>

    <p class="mt-16 text-center text-xs italic text-[var(--color-text-subtle)]">
      {t('home.reviews.disclaimer')}
    </p>
  </div>
</section>
