---
import type { Locale } from '../../lib/site.ts';
import LangSwitcher from './LangSwitcher.astro';

type Props = {
  locale: Locale;
  currentPath: string;
};

const { locale, currentPath } = Astro.props;
---

<header
  class="border-b border-[var(--color-border)] bg-[var(--color-bg-deep)]/95 backdrop-blur supports-[backdrop-filter]:bg-[var(--color-bg-deep)]/80"
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="flex items-center justify-between py-4">
      <a
        href={locale === 'pt' ? '/' : '/en/'}
        class="font-display text-base font-semibold uppercase tracking-[0.18em] sm:text-lg"
        aria-label="Porto dos Ribeiros"
        style="font-family: var(--font-display)"
      >
        Porto dos Ribeiros
      </a>
      <LangSwitcher locale={locale} currentPath={currentPath} />
    </div>
  </div>
</header>
