---
import { type Locale, SITE, useTranslations } from '../../lib/site.ts';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20">
    <div class="text-center">
      <p
        class="font-display text-lg italic text-[var(--color-accent)]"
        style="font-family: var(--font-display); font-style: italic"
        lang="pt"
      >
        {t('footer.brand_motto')}
      </p>
      <p
        class="mt-3 font-display text-base font-semibold uppercase tracking-[0.18em] text-[var(--color-text)]"
        style="font-family: var(--font-display)"
      >
        {t('footer.legal_name')}
      </p>
      <address class="mt-3 not-italic text-sm leading-relaxed text-[var(--color-text-muted)]">
        {SITE.address.street}<br />
        {SITE.address.postal} {SITE.address.city}, Portugal
      </address>
    </div>

    <div class="mt-12 grid gap-y-8 text-center text-sm sm:grid-cols-3 sm:gap-x-10 sm:text-left">
      <div>
        <p class="text-[10px] font-medium uppercase tracking-[0.28em] text-[var(--color-text-muted)]">
          {t('labels.phone')}
        </p>
        <a
          href={`tel:${SITE.phone}`}
          class="tabular mt-2 inline-block text-[var(--color-text)] hover:text-[var(--color-accent)]"
        >
          {SITE.phoneDisplay}
        </a>
      </div>
      <div>
        <p class="text-[10px] font-medium uppercase tracking-[0.28em] text-[var(--color-text-muted)]">
          {t('labels.whatsapp')}
        </p>
        <a
          href={SITE.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="tabular mt-2 inline-block text-[var(--color-text)] hover:text-[var(--color-accent)]"
        >
          {SITE.phoneDisplay}
        </a>
      </div>
      <div>
        <p class="text-[10px] font-medium uppercase tracking-[0.28em] text-[var(--color-text-muted)]">
          {t('footer.social_label')}
        </p>
        <div class="mt-2 flex justify-center gap-4 text-[var(--color-text)] sm:justify-start">
          <a
            href={SITE.socials.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-accent)]"
          >
            Instagram
          </a>
          <a
            href={SITE.socials.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-accent)]"
          >
            Facebook
          </a>
        </div>
      </div>
    </div>

    <div class="mt-14 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 border-t border-[var(--color-border)] pt-8 text-xs text-[var(--color-text-subtle)]">
      <a
        href={SITE.complaintsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[var(--color-text-muted)]"
      >
        {t('footer.complaints_link')}
      </a>
      <span aria-hidden="true">·</span>
      <a
        href={locale === 'pt' ? '/politica-de-privacidade' : '/en/privacy-policy'}
        class="hover:text-[var(--color-text-muted)]"
      >
        {t('footer.privacy')}
      </a>
    </div>

    <p class="mt-6 text-center text-xs italic text-[var(--color-text-subtle)]">
      {t('footer.legal_note')}
    </p>
    <p class="mt-3 text-center text-[10px] text-[var(--color-text-subtle)]">
      {t('footer.made_with')}
    </p>
  </div>
</footer>
