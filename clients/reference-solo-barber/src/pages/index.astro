---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Hero from '@/components/sections/Hero.astro';
import Services from '@/components/sections/Services.astro';
import About from '@/components/sections/About.astro';
import Gallery from '@/components/sections/Gallery.astro';
import Reviews from '@/components/sections/Reviews.astro';
import Visit from '@/components/sections/Visit.astro';
import { SITE } from '@/lib/site';
---

<BaseLayout
  title={SITE.name}
  description={`${SITE.tagline}. Corte, barba e combo. Vila Madalena, São Paulo. Agendamento online via Trinks.`}
>
  <Header />
  <main id="main">
    <Hero />
    <Services />
    <About />
    <Gallery />
    <Reviews />
    <Visit />
  </main>
  <Footer />
</BaseLayout>
