---
import { SITE } from '@/lib/site';
import Button from '@/components/ui/Button.astro';
import Placeholder from '@/components/ui/Placeholder.astro';
---

<section class="section bg-bg">
  <div class="container-page">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      <div class="space-y-6">
        <p class="text-sm uppercase tracking-wider text-text-muted">
          {SITE.address.neighborhood} · São Paulo
        </p>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl text-text leading-tight">
          {SITE.tagline}
        </h1>

        <p class="text-lg text-text-muted leading-relaxed max-w-prose">
          Corte clássico, barba aparada na navalha e a conversa que sobra. Desde {SITE.foundedYear},
          o Tio Edu atende quem prefere a cadeira certa à fila do shopping.
        </p>

        <div class="flex flex-wrap gap-3 pt-2">
          <Button
            href={SITE.booking.url}
            target="_blank"
            variant="primary"
            size="lg"
            dataEvent="booking_started"
            dataSourceSection="hero"
          >
            {SITE.booking.label}
          </Button>

          <Button
            href={`https://wa.me/${SITE.whatsapp}`}
            target="_blank"
            variant="secondary"
            size="lg"
            dataEvent="whatsapp_click"
            dataSourceSection="hero"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="mr-2"
              aria-hidden="true"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.296-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"
              ></path>
            </svg>
            WhatsApp
          </Button>
        </div>

        <div class="pt-4 text-sm text-text-muted tabular">
          Aberto Ter–Sex 9h–19h · Sáb 9h–17h
        </div>
      </div>

      <!--
        Hero photo — DRAFT: replace with owner-supplied photo of the
        physical shop interior (chair + mirror + warm light).
        Per beauty.md §11.5: real photo, not stock; consent-cleared.
      -->
      <Placeholder
        label="Hero photo — interior da barbearia, cadeira + espelho"
        aspectRatio="4 / 5"
        rounded={true}
      />
    </div>
  </div>
</section>
