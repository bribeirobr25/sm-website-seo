---
/**
 * About — Bart & Pomade Barbershop V2 (dark-dominant rebuild).
 *
 * Drops V1's StatCallouts row per `beauty.md` §13 anti-pattern. Pure
 * narrative with one inline pull-quote callout. Dark register throughout.
 */
import type { Locale } from '@/lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const eyebrow = locale === 'de' ? 'ÜBER DIE WERKSTATT' : 'ABOUT THE SHOP';
const h2 =
  locale === 'de'
    ? 'Schere zuerst. Klinge zweitens. Pomade als Abschluss.'
    : 'Scissors first. Blade second. Pomade to finish.';

const p1 =
  locale === 'de'
    ? 'Erik Lundström hat das Barber-Handwerk in Stockholm gelernt, klassische skandinavische Schnitt-Tradition mit Schere und Kamm. Pavel Markovic kam 2016 aus Sofia dazu — fünfzehn Jahre Klingenarbeit in der Schwarzmeer-Tradition. Zusammen haben sie Bart & Pomade in der Boxhagener Straße eröffnet, zwei Häuser vom Markt entfernt.'
    : 'Erik Lundström learned the barber craft in Stockholm — classic Scandinavian scissor-and-comb tradition. Pavel Markovic joined in 2016 from Sofia — fifteen years of blade work in the Black-Sea tradition. Together they opened Bart & Pomade on Boxhagener Straße, two doors from the market.';

const pullQuote =
  locale === 'de'
    ? '„Maschine ist erlaubt — aber sie kommt nach der Schere, nicht davor."'
    : '"Clippers are allowed — but they come after the scissors, not before."';

const p2 =
  locale === 'de'
    ? 'Heute sind wir vier Barber an fünf Stühlen. Jeder Termin ist mindestens 30 Minuten. Eigene Pomade-Linie seit 2019, in Berlin produziert. Whisky am Stuhl auf Wunsch.'
    : 'Today we are four barbers at five chairs. Every appointment is at least 30 minutes. Our own pomade line since 2019, made in Berlin. Whisky at the chair on request.';
---

<section class="bg-bg">
  <div class="container-page py-20 sm:py-28">
    <div class="max-w-3xl">
      <p class="text-[11px] tracking-[0.32em] uppercase text-accent font-bold mb-4">{eyebrow}</p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl text-text leading-[1.05] uppercase tracking-tight font-bold">
        {h2}
      </h2>
      <div class="mt-8 space-y-5 text-lg text-text-muted leading-relaxed">
        <p>{p1}</p>
      </div>

      <blockquote class="my-10 pl-6 border-l-4 border-accent-secondary">
        <p class="font-display text-2xl sm:text-3xl text-accent leading-[1.3] uppercase tracking-tight font-bold">
          {pullQuote}
        </p>
      </blockquote>

      <div class="space-y-5 text-lg text-text-muted leading-relaxed">
        <p>{p2}</p>
      </div>
    </div>
  </div>
</section>
