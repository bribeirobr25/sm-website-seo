---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
const locale = 'de' as const;
---

<BaseLayout
  title="Seite nicht gefunden"
  description="404 — Diese Seite finden wir gerade nicht."
  locale={locale}
  noindex={true}
>
  <Header locale={locale} />
  <main id="main">
    <section class="bg-bg">
      <div class="container-page py-24 sm:py-32 max-w-xl mx-auto text-center">
        <p class="text-xs uppercase tracking-[0.25em] text-text-muted">404</p>
        <h1 class="mt-4 font-display text-4xl sm:text-5xl text-text">
          Diese Seite finden wir gerade nicht.
        </h1>
        <p class="mt-6 text-text-muted leading-relaxed">
          Vielleicht meinten Sie die Leistungen? Oder die Kanzlei? Hier sind ein paar Wege zurück:
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/" class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-sm bg-text text-bg hover:bg-accent-deep transition-colors">
            Zur Startseite
          </a>
          <a href="/leistungen" class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-sm bg-surface text-text border border-border hover:bg-surface-elev transition-colors">
            Leistungen
          </a>
          <a href="/kanzlei" class="inline-flex items-center justify-center px-6 py-3 min-h-[48px] text-base font-medium rounded-sm bg-surface text-text border border-border hover:bg-surface-elev transition-colors">
            Kanzlei
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
