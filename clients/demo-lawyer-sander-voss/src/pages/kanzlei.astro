---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import MapEmbed from '@/components/sections/MapEmbed.astro';
import VisitPreview from '@/components/sections/VisitPreview.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

const locale = 'de' as const;
const mapsUrl = `https://maps.google.com/?q=${encodeURIComponent(`${SITE.address.street}, ${SITE.address.postalCode} ${SITE.address.city}`)}`;
const dayLabelsDE = { Mon: 'Mo', Tue: 'Di', Wed: 'Mi', Thu: 'Do', Fri: 'Fr', Sat: 'Sa', Sun: 'So' };
---

<BaseLayout
  title={`Kanzlei — ${SITE.name}`}
  description="Sander & Voss Rechtsanwälte in Berlin Mitte. Friedrichstraße 95. Sprechzeiten Mo–Fr, Termine nach Vereinbarung auch außerhalb."
  locale={locale}
  alternateLocaleUrl="/en/firm"
>
  <Header locale={locale} />
  <main id="main">
    <section class="bg-bg">
      <div class="container-page py-16 sm:py-24">
        <div class="max-w-3xl">
          <p class="text-xs uppercase tracking-[0.25em] text-accent-deep font-semibold">Über die Kanzlei</p>
          <h1 class="mt-3 font-display text-4xl sm:text-5xl lg:text-6xl text-text leading-[1.05]">
            Vier Partner. Ein Schreibtisch. Eine Rechnung.
          </h1>
          <div class="mt-8 space-y-5 text-lg text-text-muted leading-relaxed">
            <p>
              Sander &amp; Voss wurde 2014 von Dr. Katrin Sander (vorher Linklaters, Fachanwältin für Steuerrecht) und Lukas Voss (vorher Hengeler Mueller, M&amp;A) gegründet. Die Friedrichstraße 95 — zwischen Stadtmitte und Französischer Straße — war von Anfang an die Adresse.
            </p>
            <p>
              Seitdem sind zwei weitere Partner dazugekommen: Dr. Aisha El-Hamid (2017, Arbeitsrecht + Betriebsverfassung) und Maximilian Schreier (2019, Datenschutz, vorher beim Bundesdatenschutzbeauftragten). Vier Partner, zwei Associates, eine Assistentin. Mehr soll es auch nicht werden — wer bei uns anruft, soll einen Partner ans Telefon bekommen, nicht eine Vermittlungsstelle.
            </p>
            <p>
              Mandanten sind überwiegend Berliner Mittelstand und Start-ups: SaaS-Anbieter im Aufbau, Familienunternehmen im Übergang, Berufsträger mit Steuerfragen, Arbeitgeber mit Kündigungsschutzklagen. Bundesweit beraten wir auch — die meisten Mandate verlangen aber Berlin-Präsenz.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-bg" aria-hidden="true">
      <div class="container-page pb-8">
        <div class="aspect-[16/9] lg:aspect-[5/2] rounded-sm overflow-hidden border border-border">
          <img
            src="/img/photo/location.jpg"
            alt=""
            width="2400"
            height="3600"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
        </div>
        <p class="mt-3 text-xs text-text-muted/70 italic">Friedrichstraße · Berlin Mitte (Stockfotografie · Unsplash CC0)</p>
      </div>
    </section>

    <section class="bg-surface-elev">
      <div class="container-page py-16 sm:py-20">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
          <div class="bg-surface rounded-sm p-8 border border-border space-y-2">
            <p class="font-display text-2xl text-text">{SITE.name}</p>
            <p class="text-text-muted">{SITE.address.street}</p>
            <p class="text-text-muted">{SITE.address.postalCode} {SITE.address.city} — {SITE.address.neighborhood}</p>
            <p class="text-text-muted pt-2">
              <a href={`tel:${SITE.phone}`} class="text-accent-deep hover:text-text underline tabular">{SITE.phoneDisplay}</a>
            </p>
            <p class="text-text-muted">
              <a href={`mailto:${SITE.email}`} class="text-accent-deep hover:text-text underline">{SITE.email}</a>
            </p>
            <div class="pt-4 flex flex-wrap gap-3">
              <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-5 py-3 min-h-[44px] text-base font-medium rounded-sm bg-text text-white hover:bg-accent-deep hover:text-white transition-colors">
                In Google Maps öffnen.
              </a>
            </div>
          </div>

          <div class="bg-surface rounded-sm p-8 border border-border space-y-5">
            <p class="text-xs uppercase tracking-[0.25em] text-accent-deep font-semibold">Erreichbarkeit</p>
            <div>
              <p class="font-display text-xl text-text">{SITE.hours.summer.label.de}</p>
              <dl class="mt-3 grid grid-cols-[auto_1fr] gap-x-6 gap-y-1 text-base tabular max-w-xs">
                {SITE.hours.summer.days.map((h) => (
                  <>
                    <dt class="text-text-muted">{dayLabelsDE[h.day as keyof typeof dayLabelsDE]}</dt>
                    <dd class="text-text">{h.open && h.close ? `${h.open} – ${h.close}` : 'geschlossen'}</dd>
                  </>
                ))}
              </dl>
            </div>
            <div class="pt-3 border-t border-border">
              <p class="font-display text-xl text-text">{SITE.hours.winter.label.de}</p>
              <p class="mt-2 text-text-muted leading-relaxed">
                Termine außerhalb der Sprechzeiten gerne nach Absprache — auch werktags 8–20 und samstags 10–14. Bitte am Telefon vereinbaren.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-bg">
      <div class="container-page py-16 sm:py-20">
        <div class="max-w-2xl mb-8 space-y-3">
          <p class="text-[11px] tracking-[0.25em] uppercase text-accent-deep font-semibold">Anfahrt</p>
          <h2 class="font-display text-3xl sm:text-4xl text-text leading-[1.1]">Mit Auto, BVG oder zu Fuß.</h2>
          <p class="text-text-muted leading-relaxed">
            U2 / U6 Stadtmitte (3 Min.), U2 Hausvogteiplatz (5 Min.), S-Bahn Friedrichstraße (8 Min.). Parkhaus Markgrafenstraße 100 Meter, Tagespauschale 16 €.
          </p>
        </div>
        <MapEmbed
          lat={SITE.geo.lat}
          lng={SITE.geo.lng}
          zoom={16}
          markerLabel="Sander & Voss · Friedrichstraße 95"
          title="Karte: Sander & Voss, Friedrichstraße 95, 10117 Berlin"
          provider="openstreetmap"
          aspect="16/9"
        />
      </div>
    </section>

    <VisitPreview locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
