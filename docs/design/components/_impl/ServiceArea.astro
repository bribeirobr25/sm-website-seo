---
/**
 * ServiceArea — service-region display (postcode list or map polygon).
 * Spec: docs/design/components/service-area.md (added 2026-05-23)
 *
 * Critical for trades + mobile services (mobile groomer, in-home physio,
 * mobile mechanic). Doubles as a Local-SEO signal: lists postcodes the
 * business covers as crawlable text + emits AreaServed schema.
 *
 * Two display variants:
 *   - 'postcode-grid' (default): clean 4-col postcode grid, plain text
 *   - 'list-with-map': postcode list + adjacent MapEmbed
 *   - 'inline-pills': pills for inline mention in body copy
 */

interface ServiceAreaRegion {
  /** Region name (Berlin district, suburb, city) */
  name: string;
  /** Postcodes covered (comma-separated string or array) */
  postcodes: string[];
  /** Optional travel-fee note */
  feeNote?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  regions: ServiceAreaRegion[];
  /** Display variant */
  variant?: 'postcode-grid' | 'inline-pills' | 'list';
  /** Footnote / fee disclaimer */
  footnote?: string;
  /** AreaServed schema emission — true by default for SEO */
  emitSchema?: boolean;
  /** Service offering name (for schema) */
  serviceName?: string;
  class?: string;
}

const {
  eyebrow,
  heading,
  intro,
  regions,
  variant = 'postcode-grid',
  footnote,
  emitSchema = true,
  serviceName,
  class: extraClass = '',
} = Astro.props;

const schema = emitSchema
  ? {
      '@context': 'https://schema.org',
      '@type': 'Service',
      ...(serviceName ? { name: serviceName } : {}),
      areaServed: regions.flatMap((r) =>
        r.postcodes.map((postcode) => ({
          '@type': 'PostalCodeSpecification',
          postalCode: postcode,
          addressRegion: r.name,
        }))
      ),
    }
  : null;
---

<section class:list={['ad-service-area', extraClass]} aria-labelledby={heading ? 'service-area-heading' : undefined}>
  <div class="container-page py-16 sm:py-20">
    {(eyebrow || heading || intro) && (
      <header class="max-w-2xl mb-10 space-y-3">
        {eyebrow && <p class="text-[11px] tracking-[0.25em] uppercase text-accent font-semibold">{eyebrow}</p>}
        {heading && (
          <h2 id="service-area-heading" class="font-display text-3xl sm:text-4xl text-text leading-[1.1]">
            {heading}
          </h2>
        )}
        {intro && <p class="text-lg text-text-muted leading-relaxed">{intro}</p>}
      </header>
    )}

    {variant === 'postcode-grid' && (
      <div class="space-y-10 max-w-4xl">
        {regions.map((r) => (
          <div>
            <h3 class="font-display text-lg text-text">{r.name}</h3>
            {r.feeNote && <p class="text-sm text-text-muted mt-1">{r.feeNote}</p>}
            <ul class="mt-3 grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-x-4 gap-y-2 list-none p-0 font-mono text-sm tabular-nums">
              {r.postcodes.map((pc) => (
                <li class="text-text-muted">{pc}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    )}

    {variant === 'inline-pills' && (
      <div class="max-w-3xl flex flex-wrap gap-2">
        {regions.flatMap((r) => r.postcodes).map((pc) => (
          <span class="ad-service-pill">{pc}</span>
        ))}
      </div>
    )}

    {variant === 'list' && (
      <ul class="max-w-3xl space-y-3 list-none p-0">
        {regions.map((r) => (
          <li class="border-b border-border pb-3">
            <p class="font-display text-lg text-text">{r.name}</p>
            <p class="text-sm text-text-muted mt-1 font-mono tabular-nums">{r.postcodes.join(' · ')}</p>
            {r.feeNote && <p class="text-xs italic text-text-muted mt-1">{r.feeNote}</p>}
          </li>
        ))}
      </ul>
    )}

    {footnote && (
      <p class="mt-10 max-w-3xl text-xs italic text-text-muted leading-relaxed">{footnote}</p>
    )}
  </div>

  {schema && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</section>

<style>
  .ad-service-pill {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
  }
</style>
