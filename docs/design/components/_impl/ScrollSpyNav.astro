---
/**
 * ScrollSpyNav — sticky in-page nav with active-section highlighting.
 * Spec: docs/design/components/scroll-spy-nav.md (added 2026-05-23)
 *
 * Sticky anchor-link bar (typically below the main header). Uses
 * IntersectionObserver to highlight the active section. Pure CSS for
 * smooth scrolling + scroll-margin offset (account for sticky header).
 *
 * High-leverage on long single-page sites: restaurants with menu/about/
 * reservations sections, salons with services/team/gallery.
 */

interface NavItem {
  /** Anchor id (target section's id, without #) */
  targetId: string;
  /** Visible label */
  label: string;
}

interface Props {
  items: NavItem[];
  /** Top offset (CSS value) to account for any sticky header above this nav (default 0) */
  topOffset?: string;
  /** Variant — 'underline' (default, active item gets underline) | 'pill' (active item gets background pill) */
  variant?: 'underline' | 'pill';
  /** Section scroll-margin-top — written to each target section's style via JS for correct anchor offset (default 96px) */
  scrollMarginTop?: string;
  class?: string;
}

const {
  items,
  topOffset = '0',
  variant = 'underline',
  scrollMarginTop = '96px',
  class: extraClass = '',
} = Astro.props;
---

<nav
  class:list={['ad-scrollspy', `ad-scrollspy--${variant}`, extraClass]}
  style={`top: ${topOffset};`}
  aria-label="Page sections"
  data-scroll-margin-top={scrollMarginTop}
>
  <div class="container-page">
    <ul class="ad-scrollspy-list">
      {items.map((item) => (
        <li>
          <a
            href={`#${item.targetId}`}
            data-scrollspy-target={item.targetId}
            class="ad-scrollspy-link"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .ad-scrollspy {
    position: sticky;
    z-index: 20;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .ad-scrollspy-list {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    padding-block: 0.75rem;
    list-style: none;
    margin: 0;
    scrollbar-width: none;
  }
  .ad-scrollspy-list::-webkit-scrollbar { display: none; }
  .ad-scrollspy-link {
    display: inline-block;
    padding: 0.375rem 0;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--motion-fast) ease;
    border-bottom: 2px solid transparent;
  }
  .ad-scrollspy-link:hover { color: var(--color-text); }
  .ad-scrollspy-link[aria-current="true"] { color: var(--color-accent); }
  .ad-scrollspy--underline .ad-scrollspy-link[aria-current="true"] {
    border-bottom-color: var(--color-accent);
  }
  .ad-scrollspy--pill .ad-scrollspy-link {
    border: 0;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-full);
  }
  .ad-scrollspy--pill .ad-scrollspy-link[aria-current="true"] {
    background: var(--color-accent);
    color: var(--color-bg);
  }
  @media (prefers-reduced-motion: no-preference) {
    html { scroll-behavior: smooth; }
  }
</style>

<script>
  const nav = document.querySelector<HTMLElement>('.ad-scrollspy');
  if (nav) {
    const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>('[data-scrollspy-target]'));
    const scrollMargin = nav.dataset.scrollMarginTop ?? '96px';
    // Apply scroll-margin-top to each target section so anchor-jump lands below sticky header
    links.forEach((link) => {
      const id = link.dataset.scrollspyTarget;
      if (!id) return;
      const section = document.getElementById(id);
      if (section) section.style.scrollMarginTop = scrollMargin;
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            links.forEach((link) => {
              if (link.dataset.scrollspyTarget === id) {
                link.setAttribute('aria-current', 'true');
              } else {
                link.removeAttribute('aria-current');
              }
            });
          }
        });
      },
      { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
    );

    links.forEach((link) => {
      const section = document.getElementById(link.dataset.scrollspyTarget ?? '');
      if (section) observer.observe(section);
    });
  }
</script>
