---
/**
 * Button — primary + secondary + ghost variants.
 *
 * Primary pattern: `bg-accent text-bg hover:bg-text hover:text-bg`
 *   - Default: accent bg + page-bg color text (high contrast by design)
 *   - Hover: text-color bg + page-bg color text (inverted AAA contrast)
 *   - Both states ≥ 4.5:1 by construction. No dark-on-dark muddy hover.
 *
 * REQUIRES `src/styles/global.css` body rule wrapped in `@layer base { ... }`.
 * Without this, Tailwind v4 `.text-bg` is silently shadowed by the body's
 * inherited `color: var(--color-text)`, producing dark-on-dark CTAs.
 * See `docs/design/DESIGN-BEST-PRACTICES.md` §7 "CTA contrast — Tailwind v4
 * @layer base requirement" (added 2026-05-25 after this bug shipped to 6
 * portfolio demos and was caught in user review).
 */

interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  target?: string;
  rel?: string;
  ariaLabel?: string;
  dataEvent?: string;
  dataSourceSection?: string;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  target,
  rel,
  ariaLabel,
  dataEvent,
  dataSourceSection,
  class: extraClass = '',
} = Astro.props;

const base =
  'inline-flex items-center justify-center font-medium rounded-md transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent active:scale-[0.98] disabled:opacity-50 disabled:pointer-events-none';

const variantClass = {
  primary: 'bg-accent text-bg hover:bg-text hover:text-bg',
  secondary: 'bg-surface text-text border border-border hover:bg-surface-elev',
  ghost: 'text-text-muted hover:text-accent',
}[variant];

const sizeClass = {
  sm: 'px-3 py-2 text-sm min-h-[44px]',
  md: 'px-5 py-3 text-base min-h-[48px]',
  lg: 'px-7 py-4 text-lg min-h-[52px]',
}[size];

const cls = `${base} ${variantClass} ${sizeClass} ${extraClass}`;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  target={target}
  rel={target === '_blank' ? rel ?? 'noopener noreferrer' : rel}
  class={cls}
  aria-label={ariaLabel}
  data-event={dataEvent}
  data-source-section={dataSourceSection}
>
  <slot />
</Tag>
