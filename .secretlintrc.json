{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend"
    },
    {
      "id": "@secretlint/secretlint-rule-no-dotenv"
    },
    {
      "id": "@secretlint/secretlint-rule-pattern",
      "options": {
        "patterns": [
          {
            "name": "Resend API key",
            "pattern": "/re_[A-Za-z0-9_]{20,}/g"
          },
          {
            "name": "Stripe live secret key",
            "pattern": "/sk_live_[A-Za-z0-9]{20,}/g"
          },
          {
            "name": "Stripe test secret key",
            "pattern": "/sk_test_[A-Za-z0-9]{20,}/g"
          },
          {
            "name": "Sentry DSN with token",
            "pattern": "/https:\\/\\/[a-f0-9]{32}@[a-z0-9.]+\\.ingest\\.(de\\.)?sentry\\.io\\/[0-9]+/g"
          },
          {
            "name": "Anthropic API key",
            "pattern": "/sk-ant-(?:api\\d+-|admin\\d+-)?[A-Za-z0-9_-]{40,}/g"
          },
          {
            "name": "OpenAI API key",
            "pattern": "/sk-(?:proj-)?[A-Za-z0-9]{20,}/g"
          },
          {
            "name": "Vercel personal access token",
            "pattern": "/[A-Za-z0-9]{24}\\.(?:vercel|vc)\\./g"
          },
          {
            "name": "GitHub fine-grained PAT",
            "pattern": "/github_pat_[A-Za-z0-9_]{82}/g"
          },
          {
            "name": "Upstash Redis REST token",
            "pattern": "/[A-Za-z0-9]{30,}AAAA[A-Za-z0-9]{20,}/g"
          },
          {
            "name": "Hex-encoded JWT secret (≥ 48 chars, suspicious)",
            "pattern": "/JWT_SECRET\\s*=\\s*['\"]?[a-f0-9]{48,}['\"]?/g"
          }
        ]
      }
    }
  ]
}
